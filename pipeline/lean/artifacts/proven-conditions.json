    {
      "theorem": "gid_inbounds_when_dispatch_fits",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "global_invocation_id.{component} indexes storage buffer",
      "precondition": "workgroup_size.{component} * num_workgroups.{component} <= buffer_element_count",
      "eliminates": "min(gid.{component}, arrayLength(&buf) - 1) -> gid.{component}",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "gid_plus_offset_inbounds_when_dispatch_fits",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "global_invocation_id.{component} + constant indexes storage buffer",
      "precondition": "workgroup_size.{component} * num_workgroups.{component} + constant <= buffer_element_count",
      "eliminates": "min(gid.{component} + constant, arrayLength(&buf) - 1) -> gid.{component} + constant",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "gid_times_stride_plus_offset_inbounds_when_dispatch_fits",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "global_invocation_id.{component} * constant + constant indexes storage buffer",
      "precondition": "workgroup_size.{component} * num_workgroups.{component} * stride + offset <= buffer_element_count",
      "eliminates": "min(gid.{component} * stride + offset, arrayLength(&buf) - 1) -> gid.{component} * stride + offset",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "gid_plus_bounded_loop_index_inbounds_when_dispatch_fits",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "canonical counted-loop local i with global_invocation_id.{component} + i + constant indexing a storage buffer",
      "precondition": "either for (var i = 0; i < limit; i = i + 1) or var i = 0; loop { if (i >= limit) { break; } ... continuing { i = i + 1; } } AND workgroup_size.{component} * num_workgroups.{component} + limit + offset <= buffer_element_count",
      "eliminates": "min(gid.{component} + i + offset, arrayLength(&buf) - 1) -> gid.{component} + i + offset",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "gid_affine_plus_scaled_loop_index_inbounds_when_dispatch_fits",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "canonical counted-loop local i with global_invocation_id.{component} * gid_stride + i * loop_stride + constant indexing a storage buffer",
      "precondition": "supported counted-loop form with i < limit, gid_stride > 0, loop_stride > 0, and workgroup_size.{component} * num_workgroups.{component} * gid_stride + limit * loop_stride + offset <= buffer_element_count",
      "eliminates": "min(gid.{component} * gid_stride + i * loop_stride + offset, arrayLength(&buf) - 1) -> gid.{component} * gid_stride + i * loop_stride + offset",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "gid_tiled_index_plus_offset_inbounds_when_dispatch_fits",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "(global_invocation_id.{component} / tile_width) * tile_stride + (global_invocation_id.{component} % tile_width) + constant indexes storage buffer",
      "precondition": "tile_width > 0 AND tile_width <= tile_stride AND (((workgroup_size.{component} * num_workgroups.{component} - 1) / tile_width) + 1) * tile_stride + offset <= buffer_element_count",
      "eliminates": "min(tiled_index + offset, arrayLength(&buf) - 1) -> tiled_index + offset",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "flat_index_2d_inbounds",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "gid.y * width + gid.x indexes storage buffer",
      "precondition": "ws.x * nwg.x <= width AND ws.y * nwg.y <= height AND width * height <= buffer_element_count",
      "eliminates": "min(flat_index, arrayLength(&buf) - 1) -> flat_index",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "flat_index_2d_plus_offset_inbounds",
      "module": "Doe.Shader.ComputeBounds",
      "category": "lean_required",
      "pattern": "gid.y * width + gid.x + constant indexes storage buffer",
      "precondition": "ws.x * nwg.x <= width AND ws.y * nwg.y <= height AND width * height + offset <= buffer_element_count",
      "eliminates": "min(flat_index + offset, arrayLength(&buf) - 1) -> flat_index + offset",
      "runtimePath": "runtime/zig/src/doe_wgsl/ir_transform_robustness.zig:clamp_runtime_sized"
    },
    {
      "theorem": "guarded_gid_texture_coords_2d_inbounds",
