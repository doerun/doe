{
  "schemaVersion": 2,
  "artifactKind": "csl_simulator_plan",
  "target": "wse3",
  "contract": "explicit_simulator_launch",
  "driver": {
    "protocol": "doe.csl.simulator/v1",
    "executableEnvVar": "DOE_CSL_SIM_EXECUTABLE",
    "failClosedIfMissing": true
  },
  "inputs": {
    "hostPlanArtifactPath": "host-plan.json",
    "runtimeConfigPath": "runtime-config.json",
    "compileRootPath": "compile",
    "compileTargets": [
      {
        "name": "tiled-matmul",
        "layout": "tiled-matmul/layout.csl",
        "peProgram": "tiled-matmul/pe_program.csl",
        "sourceWgslPath": "bench/out/dual-compile-evidence/tiled-matmul/source.wgsl",
        "compileParams": {"P": 2, "Mt": 8, "Kt": 8, "Nt": 8}
      }
    ]
  },
  "runtime": {
    "peGrid": {"width": 2, "height": 2},
    "prefillLaunchCount": 1,
    "decodeLaunchCount": 0,
    "weightMappingCount": 0,
    "stateBufferCount": 0,
    "maxDecodeTokens": 0,
    "timeoutMs": 60000,
    "batchSize": 1,
    "eosTokenId": null
  },
  "outputs": {
    "stdoutPath": "stdout.log",
    "stderrPath": "stderr.log",
    "tracePath": "trace.json"
  }
}
