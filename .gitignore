# Nested mirror artifacts (accidental local copies)
bench/vendor/
/fawn/

# Cerebras SDK packages, examples, and generated compile/run outputs are local
# evidence only. Do not publish SDK-distributed files or cslc products.
csl-extras-*/
csl-extras-*.tar.gz
cerebras-software-eula.pdf
sdk-cbcore-*.sif
cerebras_sdk*.whl
cerebras-appliance*.whl
cerebras_appliance*.whl
*.elf
*.pelf
runtime/zig/examples/simulator/**/compile/compiled/
runtime/zig/examples/simulator/**/compile/**/out*.json
runtime/zig/examples/simulator/**/compile/**/sim.log
runtime/zig/examples/simulator/**/compile/**/simfab_traces/
runtime/zig/examples/simulator/**/compile/**/corefile.cs1

# Streaming executor hand-written CSL kernel sources — these are source
# code, not generated artifacts, and are required by the runners in
# bench/runners/csl-runners/streaming_executor_*.py. The rest of
# bench/out/streaming-executor (compile outputs, ELFs, traces) stays
# ignored.
!bench/out/streaming-executor/
!bench/out/streaming-executor/*-source/
!bench/out/streaming-executor/*-source/**/*.csl

# Cerebras SDK compile outputs — ELFs, cslc metadata, and SDK logs are
# "direct product of Software" under the Cerebras EULA and must not be
# redistributed. User-authored .csl source under
# examples/simulator/*/compile/<name>/ stays tracked; the sibling
# compile/compiled/ tree and any cslc/SDK log output does not.
runtime/zig/examples/simulator/*/compile/compiled/
runtime/zig/examples/**/compile/compiled/
**/compile/compiled/
**/*.elf
**/*.pelf
**/driver-logs/
runtime/zig/examples/simulator/*/stderr.log
runtime/zig/examples/simulator/*/stdout.log
runtime/zig/examples/simulator/*/sim.log
runtime/zig/examples/**/sim_core.*

# Cerebras SDK fabric-routing tmpdirs — `cs_python` / `cslc` write
# `wio_flows_tmpdir.<rand>/wio_flows.json` into the process CWD as a
# side effect; runner wrappers should `cd` into a workspace dir, but
# until then ignore the leftovers anywhere they land.
wio_flows_tmpdir.*/

# Cerebras SDK scratch files that escape to repo root when runners
# don't cd into a workspace dir. Same root cause as wio_flows_tmpdir
# above. Anchored with leading / to avoid hiding legitimate same-named
# files in subtrees.
/sim.log
/sim_stats.json
/simconfig.json
/plan.json
/logs/
/io_port-*.json
/transformer_layer_shape-*.json
/transformer_layer_shape-*-compile-errors.txt
/gemma4_e2b_manifest_attention_core-*.json
/stage3_*-compile-errors.txt
# Cerebras SDK scratch dir at repo root: cslc emits compiled binaries
# into ./executables/ when invoked from repo root cwd. Runners should
# set DOE_CSL_SCRATCH_CWD or pass cwd= so this dir does not appear at
# repo root, but ignore it as defense in depth.
/executables/

# cslc emits zero-byte kernel-module fragments at repo root when
# invoked without a scratch cwd (e.g. `Relu`). Same root cause as the
# blocks above; ignore as defense in depth.
/Relu
