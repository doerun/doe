{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawn.local/schemas/nursery/browser_projection_manifest.schema.json",
  "title": "BrowserProjectionManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "sourceWorkloadsPath",
    "sourceWorkloadsSha256",
    "rulesPath",
    "rulesSha256",
    "projectionContractHash",
    "sourceWorkloadCount",
    "rows"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "sourceWorkloadsPath": {
      "type": "string",
      "minLength": 1
    },
    "sourceWorkloadsSha256": {
      "$ref": "#/$defs/hashHex"
    },
    "rulesPath": {
      "type": "string",
      "minLength": 1
    },
    "rulesSha256": {
      "$ref": "#/$defs/hashHex"
    },
    "projectionContractHash": {
      "$ref": "#/$defs/hashHex"
    },
    "sourceWorkloadCount": {
      "type": "integer",
      "minimum": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/row"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "hashHex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "row": {
      "type": "object",
      "required": [
        "sourceWorkloadId",
        "sourceWorkloadName",
        "domain",
        "projectionClass",
        "layerTarget",
        "scenarioTemplate",
        "comparabilityExpectation",
        "requiredStatus",
        "claimScope",
        "claimLanguage",
        "projectionNote"
      ],
      "properties": {
        "sourceWorkloadId": {
          "type": "string",
          "minLength": 1
        },
        "sourceWorkloadName": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "projectionClass": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "non_projectable"
          ]
        },
        "layerTarget": {
          "type": "string",
          "enum": [
            "l1_browser_api",
            "l0_only"
          ]
        },
        "scenarioTemplate": {
          "type": "string",
          "minLength": 1
        },
        "comparabilityExpectation": {
          "type": "string",
          "enum": [
            "strict",
            "component",
            "none"
          ]
        },
        "requiredStatus": {
          "type": "string",
          "enum": [
            "ok",
            "not_applicable"
          ]
        },
        "claimScope": {
          "type": "string",
          "enum": [
            "l1_strict_candidate",
            "l1_component_only",
            "l0_only_no_claim"
          ]
        },
        "claimLanguage": {
          "type": "string",
          "minLength": 1
        },
        "projectionNote": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
