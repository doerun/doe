{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Package Dispatch Prefix Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "profileMode",
    "deltaMethod",
    "runtimeHost",
    "provider",
    "workloadId",
    "planPath",
    "planId",
    "planHash",
    "commandRepeat",
    "fullPlanCommandRepeat",
    "sampleCount",
    "preparedSession",
    "residentBufferLoads",
    "executorDryRun",
    "includeFullPlan",
    "traceDir",
    "dispatchCount",
    "stabilityDiagnostics",
    "dispatches",
    "artifactHash"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "kind": { "const": "package_dispatch_prefix_profile" },
    "profileMode": { "const": "dispatch-prefix-terminal-wait" },
    "deltaMethod": { "const": "adjacent-prefix-subtraction-diagnostic" },
    "runtimeHost": { "type": "string", "enum": ["node", "bun"] },
    "provider": { "type": "string", "minLength": 1 },
    "workloadId": { "type": "string", "minLength": 1 },
    "planPath": { "type": "string", "minLength": 1 },
    "planId": { "type": "string", "minLength": 1 },
    "planHash": { "type": "string", "minLength": 1 },
    "commandRepeat": { "type": "integer", "minimum": 1 },
    "fullPlanCommandRepeat": { "type": "integer", "minimum": 1 },
    "sampleCount": { "type": "integer", "minimum": 1 },
    "preparedSession": { "type": "boolean" },
    "residentBufferLoads": { "type": "boolean" },
    "executorDryRun": { "type": "boolean" },
    "includeFullPlan": { "type": "boolean" },
    "traceDir": { "type": "string", "minLength": 1 },
    "adjacentDeltaRankingLimit": { "type": "integer", "minimum": 1 },
    "adjacentDeltaRankings": { "$ref": "#/$defs/adjacentDeltaRankings" },
    "stabilityDiagnostics": { "$ref": "#/$defs/stabilityDiagnostics" },
    "dispatchCount": { "type": "integer", "minimum": 1 },
    "dispatches": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dispatchPrefix" }
    },
    "fullPlanResidualNs": { "$ref": "#/$defs/fullPlanResidual" },
    "fullPlanPhaseResidualRanking": { "$ref": "#/$defs/fullPlanPhaseResidualRanking" },
    "fullPlan": { "$ref": "#/$defs/fullPlan" },
    "artifactHash": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "nsSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "min",
        "median",
        "p95",
        "max",
        "mean",
        "range",
        "p95ToMedianPermille",
        "maxToMedianPermille"
      ],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "min": { "type": "integer", "minimum": 0 },
        "median": { "type": "integer", "minimum": 0 },
        "p95": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 },
        "mean": { "type": "integer", "minimum": 0 },
        "range": { "type": "integer", "minimum": 0 },
        "p95ToMedianPermille": { "type": "integer", "minimum": 0 },
        "maxToMedianPermille": { "type": "integer", "minimum": 0 }
      }
    },
    "phaseBreakdownNs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writeMaterializeTotalNs",
        "writeQueueWriteTotalNs",
        "dispatchEncodeApiTotalNs",
        "copyEncodeApiTotalNs",
        "submitCommandEncoderFinishTotalNs",
        "submitQueueSubmitTotalNs",
        "submitQueueWaitTotalNs",
        "submitCommandPrepTotalNs",
        "submitAddonCallTotalNs",
        "submitAddonCommandReplayTotalNs",
        "submitAddonCommandReplayPrepareTotalNs",
        "submitAddonCommandReplayRecordTotalNs",
        "submitAddonCommandReplayCopyTotalNs",
        "submitAddonQueueSubmitTotalNs",
        "submitAddonCommandBufferEndTotalNs",
        "submitAddonSyncPrepareTotalNs",
        "submitAddonDriverSubmitTotalNs",
        "submitAddonFlushTotalNs",
        "submitPostSubmitBookkeepingTotalNs",
        "submitQueueFlushTotalNs",
        "submitQueueFlushWaitCompletedTotalNs",
        "submitQueueFlushDeferredCopyTotalNs",
        "submitQueueFlushDeferredResolveTotalNs",
        "submitQueueWaitBookkeepingTotalNs",
        "readbackTotalNs",
        "readbackMapReadCopyUnmapTotalNs",
        "readbackMapReadCopyUnmapQueueWaitCompletedTotalNs",
        "readbackMapReadCopyUnmapDeferredCopyTotalNs",
        "readbackMapReadCopyUnmapDeferredResolveTotalNs",
        "readbackMapReadCopyUnmapMapTotalNs",
        "readbackMapReadCopyUnmapCopyTotalNs",
        "readbackMapReadCopyUnmapUnmapTotalNs",
        "readbackMapAsyncTotalNs",
        "readbackGetMappedRangeTotalNs",
        "readbackHostCopyTotalNs",
        "readbackNativeReadCopyTotalNs",
        "readbackUnmapTotalNs",
        "readbackValidationTotalNs",
        "readbackCaptureTotalNs"
      ],
      "properties": {
        "writeMaterializeTotalNs": { "type": "integer", "minimum": 0 },
        "writeQueueWriteTotalNs": { "type": "integer", "minimum": 0 },
        "dispatchEncodeApiTotalNs": { "type": "integer", "minimum": 0 },
        "copyEncodeApiTotalNs": { "type": "integer", "minimum": 0 },
        "submitCommandEncoderFinishTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueSubmitTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueWaitTotalNs": { "type": "integer", "minimum": 0 },
        "submitCommandPrepTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCallTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCommandReplayTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCommandReplayPrepareTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCommandReplayRecordTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCommandReplayCopyTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonQueueSubmitTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCommandBufferEndTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonSyncPrepareTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonDriverSubmitTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonFlushTotalNs": { "type": "integer", "minimum": 0 },
        "submitPostSubmitBookkeepingTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushWaitCompletedTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushDeferredCopyTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushDeferredResolveTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueWaitBookkeepingTotalNs": { "type": "integer", "minimum": 0 },
        "readbackTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapQueueWaitCompletedTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapDeferredCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapDeferredResolveTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapMapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapUnmapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapAsyncTotalNs": { "type": "integer", "minimum": 0 },
        "readbackGetMappedRangeTotalNs": { "type": "integer", "minimum": 0 },
        "readbackHostCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackNativeReadCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackUnmapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackValidationTotalNs": { "type": "integer", "minimum": 0 },
        "readbackCaptureTotalNs": { "type": "integer", "minimum": 0 }
      }
    },
    "phaseBreakdownSummaryNs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writeMaterializeTotalNs",
        "writeQueueWriteTotalNs",
        "dispatchEncodeApiTotalNs",
        "copyEncodeApiTotalNs",
        "submitCommandEncoderFinishTotalNs",
        "submitQueueSubmitTotalNs",
        "submitQueueWaitTotalNs",
        "submitCommandPrepTotalNs",
        "submitAddonCallTotalNs",
        "submitAddonCommandReplayTotalNs",
        "submitAddonCommandReplayPrepareTotalNs",
        "submitAddonCommandReplayRecordTotalNs",
        "submitAddonCommandReplayCopyTotalNs",
        "submitAddonQueueSubmitTotalNs",
        "submitAddonCommandBufferEndTotalNs",
        "submitAddonSyncPrepareTotalNs",
        "submitAddonDriverSubmitTotalNs",
        "submitAddonFlushTotalNs",
        "submitPostSubmitBookkeepingTotalNs",
        "submitQueueFlushTotalNs",
        "submitQueueFlushWaitCompletedTotalNs",
        "submitQueueFlushDeferredCopyTotalNs",
        "submitQueueFlushDeferredResolveTotalNs",
        "submitQueueWaitBookkeepingTotalNs",
        "readbackTotalNs",
        "readbackMapReadCopyUnmapTotalNs",
        "readbackMapReadCopyUnmapQueueWaitCompletedTotalNs",
        "readbackMapReadCopyUnmapDeferredCopyTotalNs",
        "readbackMapReadCopyUnmapDeferredResolveTotalNs",
        "readbackMapReadCopyUnmapMapTotalNs",
        "readbackMapReadCopyUnmapCopyTotalNs",
        "readbackMapReadCopyUnmapUnmapTotalNs",
        "readbackMapAsyncTotalNs",
        "readbackGetMappedRangeTotalNs",
        "readbackHostCopyTotalNs",
        "readbackNativeReadCopyTotalNs",
        "readbackUnmapTotalNs",
        "readbackValidationTotalNs",
        "readbackCaptureTotalNs"
      ],
      "properties": {
        "writeMaterializeTotalNs": { "$ref": "#/$defs/nsSummary" },
        "writeQueueWriteTotalNs": { "$ref": "#/$defs/nsSummary" },
        "dispatchEncodeApiTotalNs": { "$ref": "#/$defs/nsSummary" },
        "copyEncodeApiTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitCommandEncoderFinishTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueSubmitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueWaitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitCommandPrepTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonCallTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonCommandReplayTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonCommandReplayPrepareTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonCommandReplayRecordTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonCommandReplayCopyTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonQueueSubmitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonCommandBufferEndTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonSyncPrepareTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonDriverSubmitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitAddonFlushTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitPostSubmitBookkeepingTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueFlushTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueFlushWaitCompletedTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueFlushDeferredCopyTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueFlushDeferredResolveTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueWaitBookkeepingTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapReadCopyUnmapTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapReadCopyUnmapQueueWaitCompletedTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapReadCopyUnmapDeferredCopyTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapReadCopyUnmapDeferredResolveTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapReadCopyUnmapMapTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapReadCopyUnmapCopyTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapReadCopyUnmapUnmapTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackMapAsyncTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackGetMappedRangeTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackHostCopyTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackNativeReadCopyTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackUnmapTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackValidationTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackCaptureTotalNs": { "$ref": "#/$defs/nsSummary" }
      }
    },
    "packageFastPathStats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dispatchFlush", "flushAndMap", "commandBufferBuild"],
      "properties": {
        "dispatchFlush": { "type": "integer", "minimum": 0 },
        "flushAndMap": { "type": "integer", "minimum": 0 },
        "commandBufferBuild": { "type": "integer", "minimum": 0 }
      }
    },
    "packageNativeFastPaths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appleFastPathCompiled",
        "queueFlush",
        "queueFlushBreakdown",
        "computeDispatchFlush",
        "computeDispatchFlushBreakdown",
        "computeDispatchBatchFlush",
        "computeDispatchBatchCopyFlush",
        "computeDispatchBatchCopyFlushBreakdown",
        "bufferMapReadCopyUnmap"
      ],
      "properties": {
        "appleFastPathCompiled": { "type": "boolean" },
        "queueFlush": { "type": "boolean" },
        "queueFlushBreakdown": { "type": "boolean" },
        "queueWriteBufferBatch": { "type": "boolean" },
        "queueWriteBufferBatchDataPtrs": { "type": "boolean" },
        "computeDispatchFlush": { "type": "boolean" },
        "computeDispatchFlushBreakdown": { "type": "boolean" },
        "computeDispatchBatchFlush": { "type": "boolean" },
        "computeDispatchBatchCopyFlush": { "type": "boolean" },
        "computeDispatchBatchCopyFlushBreakdown": { "type": "boolean" },
        "computePrewarmDispatchBindings": { "type": "boolean" },
        "bufferMapReadCopyUnmap": { "type": "boolean" }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampleIndex",
        "traceMetaPath",
        "traceJsonlPath",
        "executionTotalNs",
        "executionSetupTotalNs",
        "executionEncodeTotalNs",
        "executionSubmitWaitTotalNs",
        "hostCommandOrchestrationTotalNs",
        "executionDispatchCount",
        "submitQueueWaitTotalNs",
        "readbackTotalNs",
        "readbackQueueWaitNs",
        "phaseBreakdownNs",
        "readbackCaptureCount"
      ],
      "properties": {
        "sampleIndex": { "type": "integer", "minimum": 0 },
        "traceMetaPath": { "type": "string", "minLength": 1 },
        "traceJsonlPath": { "type": "string", "minLength": 1 },
        "executionTotalNs": { "type": "integer", "minimum": 0 },
        "executionSetupTotalNs": { "type": "integer", "minimum": 0 },
        "executionEncodeTotalNs": { "type": "integer", "minimum": 0 },
        "executionSubmitWaitTotalNs": { "type": "integer", "minimum": 0 },
        "hostCommandOrchestrationTotalNs": { "type": "integer", "minimum": 0 },
        "executionDispatchCount": { "type": "integer", "minimum": 0 },
        "submitQueueWaitTotalNs": { "type": "integer", "minimum": 0 },
        "readbackTotalNs": { "type": "integer", "minimum": 0 },
        "readbackQueueWaitNs": { "type": "integer", "minimum": 0 },
        "packageReadbackMode": {
          "type": "string",
          "enum": ["native-map-read-copy-unmap", "mapAsync"]
        },
        "phaseBreakdownNs": { "$ref": "#/$defs/phaseBreakdownNs" },
        "packageNativeFastPaths": { "$ref": "#/$defs/packageNativeFastPaths" },
        "packageFastPathStats": { "$ref": "#/$defs/packageFastPathStats" },
        "readbackCaptureCount": { "type": "integer", "minimum": 0 },
        "lastReadbackCapture": { "$ref": "#/$defs/readbackCapture" }
      }
    },
    "readbackCapture": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repeatIndex", "stepIndex", "stepId", "byteLength", "sha256"],
      "properties": {
        "repeatIndex": { "type": "integer", "minimum": 0 },
        "stepIndex": { "type": "integer", "minimum": 0 },
        "stepId": { "type": "string", "minLength": 1 },
        "byteLength": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "decodedU32Le": { "type": "integer", "minimum": 0 }
      }
    },
    "fullPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampleCount",
        "executionTotalNs",
        "executionSubmitWaitTotalNs",
        "submitQueueWaitTotalNs",
        "hostCommandOrchestrationTotalNs",
        "phaseBreakdownNs",
        "samples"
      ],
      "properties": {
        "sampleCount": { "type": "integer", "minimum": 1 },
        "executionTotalNs": { "$ref": "#/$defs/nsSummary" },
        "executionSubmitWaitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueWaitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackTotalNs": { "$ref": "#/$defs/nsSummary" },
        "hostCommandOrchestrationTotalNs": { "$ref": "#/$defs/nsSummary" },
        "phaseBreakdownNs": { "$ref": "#/$defs/phaseBreakdownSummaryNs" },
        "samples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sample" }
        }
      }
    },
    "adjacentDeltaRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dispatchOrdinal",
        "stepIndex",
        "stepId",
        "moduleId",
        "entryPoint",
        "metric",
        "previousDispatchOrdinal",
        "previousStepId",
        "currentMedianNs",
        "previousMedianNs",
        "deltaNs",
        "positiveMeansCurrentPrefixAddedCost"
      ],
      "properties": {
        "dispatchOrdinal": { "type": "integer", "minimum": 1 },
        "stepIndex": { "type": "integer", "minimum": 0 },
        "stepId": { "type": "string", "minLength": 1 },
        "moduleId": { "type": "string", "minLength": 1 },
        "entryPoint": { "type": "string", "minLength": 1 },
        "semanticOpId": { "type": "string", "minLength": 1 },
        "semanticStage": { "type": "string", "minLength": 1 },
        "semanticPhase": { "type": "string", "minLength": 1 },
        "semanticTokenIndex": { "type": "integer", "minimum": 0 },
        "semanticLayerIndex": { "type": "integer", "minimum": 0 },
        "metric": {
          "type": "string",
          "enum": [
            "executionTotalNs",
            "executionSubmitWaitTotalNs",
            "submitQueueWaitTotalNs",
            "readbackTotalNs",
            "hostCommandOrchestrationTotalNs"
          ]
        },
        "previousDispatchOrdinal": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "previousStepId": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "currentMedianNs": { "type": "integer", "minimum": 0 },
        "previousMedianNs": { "type": "integer", "minimum": 0 },
        "deltaNs": { "type": "integer" },
        "positiveMeansCurrentPrefixAddedCost": { "type": "boolean" }
      }
    },
    "adjacentDeltaRankings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionTotalNs",
        "executionSubmitWaitTotalNs",
        "submitQueueWaitTotalNs",
        "readbackTotalNs",
        "hostCommandOrchestrationTotalNs"
      ],
      "properties": {
        "executionTotalNs": {
          "type": "array",
          "items": { "$ref": "#/$defs/adjacentDeltaRecord" }
        },
        "executionSubmitWaitTotalNs": {
          "type": "array",
          "items": { "$ref": "#/$defs/adjacentDeltaRecord" }
        },
        "submitQueueWaitTotalNs": {
          "type": "array",
          "items": { "$ref": "#/$defs/adjacentDeltaRecord" }
        },
        "readbackTotalNs": {
          "type": "array",
          "items": { "$ref": "#/$defs/adjacentDeltaRecord" }
        },
        "hostCommandOrchestrationTotalNs": {
          "type": "array",
          "items": { "$ref": "#/$defs/adjacentDeltaRecord" }
        }
      }
    },
    "fullPlanResidualMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fullPlanMedianNs",
        "lastPrefixMedianNs",
        "residualNs",
        "positiveMeansFullPlanHasExtraCost"
      ],
      "properties": {
        "fullPlanMedianNs": { "type": "integer", "minimum": 0 },
        "lastPrefixMedianNs": { "type": "integer", "minimum": 0 },
        "residualNs": { "type": "integer" },
        "positiveMeansFullPlanHasExtraCost": { "type": "boolean" }
      }
    },
    "stabilityStatus": {
      "type": "string",
      "enum": ["stable", "unstable", "insufficient-samples"]
    },
    "stabilityRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "metric",
        "sampleCount",
        "medianNs",
        "p95ToMedianPermille",
        "maxToMedianPermille",
        "status"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["fullPlan", "dispatchPrefix"]
        },
        "metric": {
          "type": "string",
          "enum": [
            "executionTotalNs",
            "executionSubmitWaitTotalNs",
            "readbackTotalNs",
            "hostCommandOrchestrationTotalNs"
          ]
        },
        "dispatchOrdinal": { "type": "integer", "minimum": 1 },
        "stepId": { "type": "string", "minLength": 1 },
        "sampleCount": { "type": "integer", "minimum": 0 },
        "medianNs": { "type": "integer", "minimum": 0 },
        "p95ToMedianPermille": { "type": "integer", "minimum": 0 },
        "maxToMedianPermille": { "type": "integer", "minimum": 0 },
        "status": { "$ref": "#/$defs/stabilityStatus" }
      }
    },
    "stabilityDiagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis",
        "minSampleCount",
        "p95ToMedianPermilleThreshold",
        "maxToMedianPermilleThreshold",
        "overallStatus",
        "metricCount",
        "unstableMetricCount",
        "insufficientSampleMetricCount",
        "records"
      ],
      "properties": {
        "basis": { "const": "summary-p95-and-max-to-median-permille" },
        "minSampleCount": { "type": "integer", "minimum": 1 },
        "p95ToMedianPermilleThreshold": { "type": "integer", "minimum": 1 },
        "maxToMedianPermilleThreshold": { "type": "integer", "minimum": 1 },
        "overallStatus": { "$ref": "#/$defs/stabilityStatus" },
        "metricCount": { "type": "integer", "minimum": 0 },
        "unstableMetricCount": { "type": "integer", "minimum": 0 },
        "insufficientSampleMetricCount": { "type": "integer", "minimum": 0 },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/stabilityRecord" }
        }
      }
    },
    "fullPlanResidual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "lastDispatchOrdinal", "lastStepId", "metrics"],
      "properties": {
        "basis": { "const": "full-plan-median-minus-last-dispatch-prefix-median" },
        "lastDispatchOrdinal": { "type": "integer", "minimum": 1 },
        "lastStepId": { "type": "string", "minLength": 1 },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "executionTotalNs",
            "executionSubmitWaitTotalNs",
            "submitQueueWaitTotalNs",
            "readbackTotalNs",
            "hostCommandOrchestrationTotalNs"
          ],
          "properties": {
            "executionTotalNs": { "$ref": "#/$defs/fullPlanResidualMetric" },
            "executionSubmitWaitTotalNs": { "$ref": "#/$defs/fullPlanResidualMetric" },
            "submitQueueWaitTotalNs": { "$ref": "#/$defs/fullPlanResidualMetric" },
            "readbackTotalNs": { "$ref": "#/$defs/fullPlanResidualMetric" },
            "hostCommandOrchestrationTotalNs": { "$ref": "#/$defs/fullPlanResidualMetric" }
          }
        }
      }
    },
    "fullPlanPhaseResidualRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "fullPlanMedianNs",
        "lastPrefixMedianNs",
        "residualNs",
        "positiveMeansFullPlanHasExtraCost"
      ],
      "properties": {
        "phase": { "type": "string", "minLength": 1 },
        "fullPlanMedianNs": { "type": "integer", "minimum": 0 },
        "lastPrefixMedianNs": { "type": "integer", "minimum": 0 },
        "residualNs": { "type": "integer" },
        "positiveMeansFullPlanHasExtraCost": { "type": "boolean" }
      }
    },
    "fullPlanPhaseResidualRanking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "lastDispatchOrdinal", "lastStepId", "phases"],
      "properties": {
        "basis": {
          "const": "full-plan-phase-median-minus-last-dispatch-prefix-phase-median"
        },
        "lastDispatchOrdinal": { "type": "integer", "minimum": 1 },
        "lastStepId": { "type": "string", "minLength": 1 },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/fullPlanPhaseResidualRecord" }
        }
      }
    },
    "dispatchPrefix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dispatchOrdinal",
        "stepIndex",
        "stepId",
        "moduleId",
        "entryPoint",
        "workgroups",
        "stepLimit",
        "sampleCount",
        "executionTotalNs",
        "executionSubmitWaitTotalNs",
        "submitQueueWaitTotalNs",
        "hostCommandOrchestrationTotalNs",
        "phaseBreakdownNs",
        "deltaFromPreviousMedianExecutionTotalNs",
        "deltaFromPreviousMedianSubmitWaitNs",
        "samples"
      ],
      "properties": {
        "dispatchOrdinal": { "type": "integer", "minimum": 1 },
        "stepIndex": { "type": "integer", "minimum": 0 },
        "stepId": { "type": "string", "minLength": 1 },
        "moduleId": { "type": "string", "minLength": 1 },
        "entryPoint": { "type": "string", "minLength": 1 },
        "workgroups": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "integer", "minimum": 1 }
        },
        "semanticOpId": { "type": "string", "minLength": 1 },
        "semanticStage": { "type": "string", "minLength": 1 },
        "semanticPhase": { "type": "string", "minLength": 1 },
        "semanticTokenIndex": { "type": "integer", "minimum": 0 },
        "semanticLayerIndex": { "type": "integer", "minimum": 0 },
        "stepLimit": { "type": "integer", "minimum": 1 },
        "sampleCount": { "type": "integer", "minimum": 1 },
        "executionTotalNs": { "$ref": "#/$defs/nsSummary" },
        "executionSubmitWaitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "submitQueueWaitTotalNs": { "$ref": "#/$defs/nsSummary" },
        "readbackTotalNs": { "$ref": "#/$defs/nsSummary" },
        "hostCommandOrchestrationTotalNs": { "$ref": "#/$defs/nsSummary" },
        "phaseBreakdownNs": { "$ref": "#/$defs/phaseBreakdownSummaryNs" },
        "deltaFromPreviousMedianExecutionTotalNs": { "type": "integer" },
        "deltaFromPreviousMedianSubmitWaitNs": { "type": "integer" },
        "samples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sample" }
        }
      }
    }
  }
}
