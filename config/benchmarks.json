    }
  ],
  "matrix": [
    {
      "metricId": "encode_overhead_ns",
      "description": "CPU-side command encoding overhead"
    },
    {
      "metricId": "validation_overhead_ns",
      "description": "CPU-side validation overhead"
    },
    {
      "metricId": "submit_latency_p50_ms",
      "description": "Queue submit latency p50"
    },
    {
      "metricId": "submit_latency_p95_ms",
      "description": "Queue submit latency p95"
    },
    {
      "metricId": "submit_latency_p99_ms",
      "description": "Queue submit latency p99"
    },
    {
      "metricId": "allocations_per_frame",
      "description": "Heap/allocation churn proxy"
    }
  ],
  "workloads": [
    {
      "workloadId": "compute_small_kernels_100k",
      "description": "High-frequency tiny compute dispatches"
    },
    {
      "workloadId": "mixed_encode_submit",
      "description": "Representative mixed encode + submit loop"
    }
