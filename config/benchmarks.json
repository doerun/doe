  "comparisonContract": {
    "claimStates": ["scaffold", "directional", "substantiated"],
    "requiredMetricsForIncumbentClaim": [
      "encode_overhead_ns",
      "validation_overhead_ns",
      "submit_latency_p95_ms",
      "allocations_per_frame"
