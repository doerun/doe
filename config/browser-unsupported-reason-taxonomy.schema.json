{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/browser-unsupported-reason-taxonomy.schema.json",
  "title": "Browser unsupported reason taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactKind", "taxonomyId", "codes"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "browser_unsupported_reason_taxonomy" },
    "taxonomyId": { "type": "string", "minLength": 1 },
    "codes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ReasonCode" }
    }
  },
  "$defs": {
    "ReasonCode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reasonCode", "category", "capabilities", "statuses", "developerVisible"],
      "properties": {
        "reasonCode": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "category": {
          "enum": [
            "supported",
            "diagnostic",
            "unsupported",
            "fallback",
            "blocked",
            "policy",
            "failure"
          ]
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "webgpu_runtime",
              "canvas_fusion",
              "external_texture",
              "local_ai",
              "scheduler",
              "webgpu_effect",
              "pipeline_cache",
              "shader_link",
              "capture_policy",
              "cts_subset",
              "recovery_parity"
            ]
          }
        },
        "statuses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "supported",
              "unsupported",
              "fallback",
              "blocked",
              "diagnostic",
              "fail"
            ]
          }
        },
        "developerVisible": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  }
}
