{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/native-no-fallback-report.schema.json",
  "title": "Native no-fallback report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactKind", "strictNoFallback", "status", "rows", "summary"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "native_no_fallback_report" },
    "strictNoFallback": { "type": "boolean", "const": true },
    "status": { "enum": ["pass", "fail"] },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Row" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rowCount", "passCount", "failCount", "failureCodes"],
      "properties": {
        "rowCount": { "type": "integer", "minimum": 0 },
        "passCount": { "type": "integer", "minimum": 0 },
        "failCount": { "type": "integer", "minimum": 0 },
        "failureCodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/Failure" }
        }
      }
    }
  },
  "$defs": {
    "Hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "Failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "Row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runReceiptPath",
        "runReceiptSha256",
        "product",
        "runtimeHost",
        "executionBackend",
        "fallbackUsed",
        "status",
        "failureCodes"
      ],
      "properties": {
        "runReceiptPath": { "type": "string", "minLength": 1 },
        "runReceiptSha256": { "$ref": "#/$defs/Hash" },
        "product": { "type": "string", "minLength": 1 },
        "runtimeHost": { "type": "string", "minLength": 1 },
        "executionBackend": { "type": "string", "minLength": 1 },
        "fallbackUsed": { "type": "boolean", "const": false },
        "status": { "enum": ["pass", "fail"] },
        "failureCodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/Failure" }
        }
      }
    }
  }
}
