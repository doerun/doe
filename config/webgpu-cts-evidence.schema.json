{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn WebGPU CTS Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "lastUpdated", "ctsSource", "ctsRevision", "evidence"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "lastUpdated": { "type": "string" },
    "ctsSource": { "type": "string", "minLength": 1 },
    "ctsRevision": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["query", "bucket", "status", "surface", "host", "os", "backend", "artifactPath"],
        "properties": {
          "query": { "type": "string", "minLength": 1 },
          "bucket": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "skip", "not_run"]
          },
          "surface": {
            "type": "string",
            "enum": ["compute", "full", "browser", "package", "native"]
          },
          "host": { "type": "string", "minLength": 1 },
          "os": { "type": "string", "minLength": 1 },
          "backend": { "type": "string", "minLength": 1 },
          "artifactPath": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
