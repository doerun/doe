{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config/doe-wgsl-runtime-config.schema.json",
  "title": "DOE WGSL CSL runtime config artifact",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": { "const": "sdk-runtime-command" }
        },
        "required": ["mode"]
      },
      "then": {
        "required": ["command"]
      }
    }
  ],
  "required": [
    "schemaVersion",
    "artifactKind",
    "target",
    "contract",
    "mode",
    "runtimeExecutableEnvVar",
    "modelConfig",
    "maxDecodeTokens",
    "timeoutMs",
    "batchSize",
    "weightMappings",
    "stateBuffers"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "csl_runtime_config" },
    "target": { "type": "string", "const": "wse3" },
    "contract": { "type": "string", "const": "explicit_runtime_config" },
    "mode": {
      "type": "string",
      "enum": ["compile-only", "sdk-runtime-command"]
    },
    "runtimeExecutableEnvVar": {
      "type": "string",
      "const": "DOE_CSL_RUNTIME_EXECUTABLE"
    },
    "cmaddrEnvVar": {
      "type": "string",
      "const": "DOE_CSL_CMADDR"
    },
    "command": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "modelConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hiddenDim",
        "numHeads",
        "headDim",
        "numLayers",
        "vocabSize",
        "maxSeqLen",
        "quantFormat",
        "ffnExpansionFactor",
        "ffnMatrixCount"
      ],
      "properties": {
        "hiddenDim": { "type": "integer", "minimum": 1 },
        "numHeads": { "type": "integer", "minimum": 1 },
        "headDim": { "type": "integer", "minimum": 1 },
        "globalHeadDim": { "type": "integer", "minimum": 0 },
        "numKeyValueHeads": { "type": "integer", "minimum": 1 },
        "numLayers": { "type": "integer", "minimum": 1 },
        "vocabSize": { "type": "integer", "minimum": 1 },
        "maxSeqLen": { "type": "integer", "minimum": 1 },
        "quantFormat": { "type": "string", "enum": ["f16", "q4k", "q8_0"] },
        "ffnExpansionFactor": { "type": "integer", "minimum": 1 },
        "ffnMatrixCount": { "type": "integer", "minimum": 1 },
        "pleWidth": { "type": "integer", "minimum": 0 },
        "pleVocabSize": { "type": "integer", "minimum": 0 }
      }
    },
    "maxDecodeTokens": { "type": "integer", "minimum": 0 },
    "timeoutMs": { "type": "integer", "minimum": 0 },
    "batchSize": { "type": "integer", "minimum": 1 },
    "weightMappingStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "proofStatus", "reason", "syntheticWeights"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["artifact_backed", "blocked"]
        },
        "proofStatus": {
          "type": "string",
          "enum": ["not_proven"]
        },
        "reason": { "type": "string", "minLength": 1 },
        "syntheticWeights": { "type": "boolean", "const": false }
      }
    },
    "weightMappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "shard",
          "path",
          "sha256",
          "peBuffer",
          "peRange",
          "dtype",
          "tensor",
          "offsetBytes",
          "shape",
          "quant"
        ],
        "properties": {
          "shard": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "peBuffer": { "type": "string", "minLength": 1 },
          "peRange": {
            "type": "array",
            "prefixItems": [
              { "type": "integer", "minimum": 0 },
              { "type": "integer", "minimum": 0 }
            ],
            "minItems": 2,
            "maxItems": 2
          },
          "dtype": { "type": "string", "enum": ["f16", "u8_q4k", "u8_q8"] },
          "weightKey": { "type": "string", "minLength": 1 },
          "tensorName": { "type": "string", "minLength": 1 },
          "tensor": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "layout": { "type": "string", "minLength": 1 },
          "shape": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 1 }
          },
          "byteSize": { "type": "integer", "minimum": 0 },
          "byteOffset": { "type": "integer", "minimum": 0 },
          "offsetBytes": { "type": "integer", "minimum": 0 },
          "spans": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "shardIndex",
                "shardPath",
                "shardSha256",
                "offset",
                "size"
              ],
              "properties": {
                "shardIndex": { "type": "integer", "minimum": 0 },
                "shardPath": { "type": "string", "minLength": 1 },
                "shardSha256": { "type": "string", "minLength": 1 },
                "offset": { "type": "integer", "minimum": 0 },
                "size": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "sourceTransform": {
            "type": "object",
            "additionalProperties": true
          },
          "quant": {
            "type": "object",
            "additionalProperties": false,
            "required": ["format", "storageDtype"],
            "properties": {
              "format": { "type": "string", "minLength": 1 },
              "storageDtype": { "type": "string", "minLength": 1 },
              "sourceDtype": { "type": "string", "minLength": 1 },
              "blockSizeElements": { "type": "integer", "minimum": 1 },
              "blockSizeBytes": { "type": "integer", "minimum": 1 },
              "encoding": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "weightIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelId",
        "manifestPath",
        "manifestSha256",
        "weightSetId",
        "weightSetSha256",
        "declaredShardCount",
        "requiredWeightCount",
        "mappedWeightCount",
        "missingWeightCount",
        "missingWeightKeys",
        "requiredWeightKeysSha256",
        "mappedWeightKeysSha256"
      ],
      "properties": {
        "modelId": { "type": "string", "minLength": 1 },
        "manifestPath": { "type": "string", "minLength": 1 },
        "manifestSha256": { "type": "string", "minLength": 1 },
        "weightSetId": { "type": "string", "minLength": 1 },
        "weightSetSha256": { "type": "string", "minLength": 1 },
        "declaredShardCount": { "type": "integer", "minimum": 0 },
        "requiredWeightCount": { "type": "integer", "minimum": 0 },
        "mappedWeightCount": { "type": "integer", "minimum": 0 },
        "missingWeightCount": { "type": "integer", "minimum": 0 },
        "missingWeightKeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredWeightKeysSha256": { "type": "string", "minLength": 1 },
        "mappedWeightKeysSha256": { "type": "string", "minLength": 1 }
      }
    },
    "memoryPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grid",
        "residencyMode",
        "totalModelBytes",
        "totalPersistentBytes",
        "totalStreamedBytes",
        "persistentBytesPerPe",
        "streamedWorkingSetBytesPerPe",
        "fits"
      ],
      "properties": {
        "grid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "residencyMode": {
          "type": "string",
          "enum": ["full_resident", "layer_streaming"]
        },
        "totalModelBytes": { "type": "integer", "minimum": 0 },
        "totalPersistentBytes": { "type": "integer", "minimum": 0 },
        "totalStreamedBytes": { "type": "integer", "minimum": 0 },
        "persistentBytesPerPe": { "type": "integer", "minimum": 0 },
        "streamedWorkingSetBytesPerPe": { "type": "integer", "minimum": 0 },
        "fits": { "type": "boolean" }
      }
    },
    "stateBuffers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "bytesPerPe"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["kv_cache", "position", "scratch"] },
          "bytesPerPe": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "hostIoLayout": {
      "type": "array",
      "items": { "$ref": "#/$defs/hostIoLayoutEntry" }
    }
  },
  "$defs": {
    "hostIoLayoutEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "bufferRole",
        "hostAction",
        "dtype",
        "peGrid",
        "roi",
        "order",
        "elementsPerPe",
        "bytesPerPe",
        "totalElements",
        "totalBytes",
        "sourceIdentity"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "bufferRole": {
          "type": "string",
          "enum": [
            "weight",
            "state",
            "tokenized_prompt",
            "logits_output",
            "generated_tokens_output"
          ]
        },
        "hostAction": {
          "type": "string",
          "enum": ["memcpy_h2d", "memcpy_d2h", "allocate_device"]
        },
        "dtype": {
          "type": "string",
          "enum": ["bytes", "f16", "float32", "u8_q4k", "u8_q8", "uint32"]
        },
        "peGrid": { "$ref": "#/$defs/peGrid" },
        "roi": { "$ref": "#/$defs/peRoi" },
        "order": {
          "type": "string",
          "enum": ["host_linear", "row_major_pe_range"]
        },
        "elementsPerPe": { "type": "integer", "minimum": 0 },
        "bytesPerPe": { "type": "integer", "minimum": 0 },
        "totalElements": { "type": "integer", "minimum": 0 },
        "totalBytes": { "type": "integer", "minimum": 0 },
        "sourceIdentity": { "$ref": "#/$defs/hostIoSourceIdentity" }
      }
    },
    "peGrid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "peRoi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height", "peStart", "peEnd"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "peStart": { "type": "integer", "minimum": 0 },
        "peEnd": { "type": "integer", "minimum": 0 }
      }
    },
    "hostIoSourceIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "synthetic"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "doppler_reference_generated_tokens_contract",
            "doppler_reference_tensor_contract",
            "rdrr_weight_shard",
            "runtime_state_buffer",
            "tokenized_prompt"
          ]
        },
        "path": { "type": "string" },
        "sha256": { "type": "string" },
        "source": { "type": "string" },
        "tensor": { "type": "string" },
        "offsetBytes": { "type": "integer", "minimum": 0 },
        "synthetic": { "type": "boolean", "const": false }
      }
    }
  }
}
