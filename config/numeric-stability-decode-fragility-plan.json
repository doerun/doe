        "access revocation",
        "secret redaction"
      ]
    },
    {
      "familyId": "structured-generation",
      "examples": [
        "tool choice",
        "JSON booleans",
        "moderation labels"
      ]
    }
  ],
  "promotionRequirements": {
    "requireActualSelectedTokenChange": true,
    "requireMeaningfulToken": true,
    "maxDecodeStepIndex": 3,
    "requireWithinPolicyStability": true,
    "requireUpstreamDisagreement": true,
    "requireSuffixReplayDivergence": true,
    "minimumPromotableScore": 3.0,
    "rejectionReasons": [
      "missing-required-field",
      "selected-token-unchanged",
      "meaningless-token",
      "late-decode-position",
      "within-policy-instability",
      "missing-upstream-disagreement",
      "missing-suffix-replay",
      "suffix-replay-converged",
      "score-below-threshold"
    ]
  },
  "suffixReplayPolicy": {
    "minReplaySteps": 1,
    "maxReplaySteps": 4,
    "requiredForPromotion": true,
    "notes": [
      "Short suffix replay is used only to confirm semantic consequence after a real selected-token flip has already been observed.",
      "The replay budget is intentionally small so this remains a promotion filter instead of a new generation mode."
    ]
  },
  "rankingBuckets": [
    {
      "bucketId": "promotable",
      "description": "Real selected-token flip with semantic consequence and score above the promotion threshold.",
      "minimumScore": 3.0
    },
    {
      "bucketId": "investigate",
      "description": "Interesting decode-boundary fragility that needs more evidence or better suffix consequence before promotion.",
      "minimumScore": 1.5
    },
    {
      "bucketId": "reject",
      "description": "Fails the current promotion bar or lacks meaningful decode consequence.",
      "minimumScore": 0.0
    }
  ],
  "backendExpansionOrder": [
    {
      "backendId": "apple:metal",
      "priority": 1,
      "reason": "Land the decode receipt and promotion loop on the backend with the current strongest ordinary-execution numeric-governance evidence."
    },
    {
      "backendId": "amd:vulkan",
      "priority": 2,
      "reason": "Demonstrate that the decode-governance contract is runtime-level and portable beyond one backend."
    }
  ]
}
