{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doe compare taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "axes",
    "aliases",
    "productFamilies",
    "promotedRunCoverage"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 3
    },
    "axes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platformLanes",
        "surfaces",
        "products",
        "runtimeHosts",
        "temperatures",
        "targetKinds",
        "presetIds",
        "workloadIds",
        "executorInputBoundaries"
      ],
      "properties": {
        "platformLanes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "surfaces": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "products": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "runtimeHosts": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "temperatures": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "targetKinds": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "presetIds": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "workloadIds": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "executorInputBoundaries": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaceShortNames",
        "repoSurfaceByProductAndRuntimeHost"
      ],
      "properties": {
        "surfaceShortNames": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "repoSurfaceByProductAndRuntimeHost": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repoSurfaceAlias"
          },
          "minItems": 1
        }
      }
    },
    "productFamilies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/productFamily"
      },
      "minItems": 1
    },
    "promotedRunCoverage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promotedCoverage"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "repoSurfaceAlias": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "product",
        "runtimeHost",
        "repoSurface"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "runtimeHost": {
          "type": "string",
          "minLength": 1
        },
        "repoSurface": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "productFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "surface",
        "product",
        "runtimeHost",
        "temperature",
        "targetKind",
        "executorInputBoundary",
        "structuralPlatformLanes",
        "theoreticalConcreteTargetIds"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "runtimeHost": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "string",
          "minLength": 1
        },
        "targetKind": {
          "type": "string",
          "minLength": 1
        },
        "executorInputBoundary": {
          "type": "string",
          "minLength": 1
        },
        "structuralPlatformLanes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "theoreticalConcreteTargetIds": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "promotedCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "familyId",
        "platformLane",
        "targetIds"
      ],
      "properties": {
        "familyId": {
          "type": "string",
          "minLength": 1
        },
        "platformLane": {
          "type": "string",
          "minLength": 1
        },
        "targetIds": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    }
  }
}
