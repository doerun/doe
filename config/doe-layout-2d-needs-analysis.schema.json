{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.doe.deco/doe-layout-2d-needs-analysis.schema.json",
  "title": "Doe layout emitter 2-D needs analysis",
  "description": "Per-pattern audit of CSL layout emitters that tells us which actually need 2-D widening for the Gemma4 Doppler->Doe->Cerebras plan's Build-order step 2 (full-grid kernel compile sweep). Not every 1-D emitter overflows the SDK's i16 memcpy-width ceiling at 31B shapes: per-token, per-head, and per-tile width semantics keep most under i16. Regenerated by bench/tools/analyze_layout_2d_needs.py; sha256-bound to emit_csl_layout.zig so stale analyses are caught.",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactKind",
    "emitterSourcePath",
    "emitterSourceSha256",
    "patterns",
    "summary"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "artifactKind": { "const": "doe_layout_2d_needs_analysis" },
    "emitterSourcePath": { "type": "string" },
    "emitterSourceSha256": { "type": "string" },
    "planBuildOrderStep": { "type": "integer", "minimum": 1, "maximum": 7 },
    "planDocPath": { "type": "string" },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["emitter", "pattern", "currentGrid", "widenedTo2D", "needs2DFor31B"],
        "properties": {
          "emitter": { "type": "string" },
          "emitterLine": { "type": "integer", "minimum": 1 },
          "pattern": { "type": "string" },
          "currentGrid": { "type": "string" },
          "widthSemantic": { "type": "string" },
          "widenedTo2D": { "type": "boolean" },
          "needs2DFor31B": {
            "oneOf": [
              { "type": "boolean" },
              { "type": "string", "enum": ["likely"] }
            ]
          },
          "stepDependency": {
            "type": "integer",
            "minimum": 1,
            "maximum": 7,
            "description": "If present, this emitter's 2-D-need is unresolvable without the named Build-order step first landing its shape-emission output."
          },
          "rationale": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["totalEmitters", "widenedTo2D", "needs2DAndNotYet", "noWideningNeeded"],
      "properties": {
        "totalEmitters": { "type": "integer", "minimum": 0 },
        "widenedTo2D": { "type": "integer", "minimum": 0 },
        "needs2DAndNotYet": { "type": "array", "items": { "type": "string" } },
        "needs2DLikelyAuditNeeded": { "type": "array", "items": { "type": "string" } },
        "noWideningNeeded": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Ordering constraints between the audit's findings and other Build-order steps. Surfaced so the sweep report can flag cross-step blockers rather than silently assuming independence.",
      "properties": {
        "step2DependsOnStep1ForPatterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "finding": { "type": "string" },
        "blocksSweepCompletion": { "type": "boolean" }
      }
    },
    "notes": { "type": "string" }
  }
}
