{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Drop-in ABI Behavior Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "defaultMode", "laneModes", "strictFallbackForbidden"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "defaultMode": {
      "type": "string",
      "enum": ["dawn_ownership", "mixed_ownership", "doe_metal_ownership", "doe_vulkan_ownership", "doe_d3d12_ownership"]
    },
    "laneModes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["dawn_ownership", "mixed_ownership", "doe_metal_ownership", "doe_vulkan_ownership", "doe_d3d12_ownership"]
      }
    },
    "strictFallbackForbidden": { "type": "boolean" }
  }
}
