{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "doe-tsir-manifest-lowering.schema.json",
  "title": "Manifest lowering entry",
  "description": "One entry in the manifest's `integrityExtensions.lowerings[]` array. Binds a kernel's TSIR identity to the target + compiler versions under which it was lowered.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "backend",
    "compilerVersion",
    "emitterDigest",
    "exactness",
    "frontendVersion",
    "kernelRef",
    "rejectionReasons",
    "targetDescriptorCorrectnessHash",
    "tsirRealizationDigest",
    "tsirSemanticDigest"
  ],
  "properties": {
    "backend": { "type": "string", "minLength": 1 },
    "compilerVersion": { "type": "string", "minLength": 1 },
    "emitterDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "exactness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class"],
      "allOf": [
        {
          "if": {
            "properties": { "class": { "const": "bit_exact_solo" } },
            "required": ["class"]
          },
          "then": {
            "properties": {
              "algorithmExactInvariants": { "maxItems": 0 },
              "toleranceEpsilon": { "const": 0 },
              "toleranceMetric": { "const": "" }
            }
          }
        },
        {
          "if": {
            "properties": { "class": { "const": "algorithm_exact" } },
            "required": ["class"]
          },
          "then": {
            "required": ["algorithmExactInvariants"],
            "properties": {
              "algorithmExactInvariants": { "minItems": 1 },
              "toleranceEpsilon": { "const": 0 },
              "toleranceMetric": { "const": "" }
            }
          }
        },
        {
          "if": {
            "properties": { "class": { "const": "tolerance_bounded" } },
            "required": ["class"]
          },
          "then": {
            "required": ["toleranceEpsilon", "toleranceMetric"],
            "properties": {
              "algorithmExactInvariants": { "maxItems": 0 },
              "toleranceEpsilon": { "exclusiveMinimum": 0 },
              "toleranceMetric": { "minLength": 1 }
            }
          }
        }
      ],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["bit_exact_solo", "algorithm_exact", "tolerance_bounded"]
        },
        "algorithmExactInvariants": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "reduction_order",
              "tree_shape",
              "accum_dtype",
              "associativity_grouping"
            ]
          }
        },
        "toleranceMetric": { "type": "string" },
        "toleranceEpsilon": { "type": "number" }
      }
    },
    "frontendVersion": { "type": "string" },
    "kernelRef": { "type": "string", "minLength": 1 },
    "rejectionReasons": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "tsir_subgroup_unlowerable",
          "tsir_pe_budget_exhausted",
          "tsir_collective_not_representable",
          "tsir_dependence_unanalyzable",
          "tsir_source_not_affine",
          "tsir_target_unfit"
        ]
      }
    },
    "targetDescriptorCorrectnessHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "tsirRealizationDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "tsirSemanticDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
