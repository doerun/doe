{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/native-resource-reuse-receipts.schema.json",
  "title": "Native resource reuse receipts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactKind", "receiptStatus", "rows", "failureCodes"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "native_resource_reuse_receipts" },
    "receiptStatus": { "enum": ["pass", "fail"] },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Row" }
    },
    "failureCodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Failure" }
    }
  },
  "$defs": {
    "Row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receiptId",
        "workloadId",
        "backend",
        "reuseKind",
        "semanticsAllowReuse",
        "reuseApplied",
        "resourceIdentityPreserved",
        "commandOrderPreserved",
        "claimEligible",
        "fallbackApplied",
        "hiddenFallbackAllowed"
      ],
      "properties": {
        "receiptId": { "type": "string", "minLength": 1 },
        "workloadId": { "type": "string", "minLength": 1 },
        "backend": { "enum": ["doe_metal", "doe_vulkan", "doe_d3d12"] },
        "reuseKind": {
          "enum": ["command_encoder", "pipeline", "bind_group", "buffer", "texture"]
        },
        "semanticsAllowReuse": { "type": "boolean" },
        "reuseApplied": { "type": "boolean" },
        "resourceIdentityPreserved": { "type": "boolean" },
        "commandOrderPreserved": { "type": "boolean" },
        "claimEligible": { "type": "boolean" },
        "fallbackApplied": { "type": "boolean" },
        "hiddenFallbackAllowed": { "type": "boolean", "const": false },
        "reasonCode": { "type": "string" }
      }
    },
    "Failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
