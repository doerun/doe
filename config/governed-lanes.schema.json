{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "lanes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "aliases": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "cubeEligible": {
            "type": "boolean"
          },
          "displayName": {
            "minLength": 1,
            "type": "string"
          },
          "governanceKind": {
            "enum": [
              "backend_runtime",
              "package_compare",
              "browser_gate",
              "browser_claim"
            ],
            "type": "string"
          },
          "hostProfiles": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "products": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "sourceReportTypes": {
            "items": {
              "enum": [
                "backend_compare_report",
                "node_package_compare_report",
                "bun_package_compare_report",
                "deno_package_compare_report",
                "browser_gate_report",
                "browser_claim_report"
              ],
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "surface": {
            "enum": [
              "backend_native",
              "node_package",
              "bun_package",
              "deno_package",
              "browser"
            ],
            "type": "string"
          }
        },
        "required": [
          "id",
          "displayName",
          "governanceKind",
          "surface",
          "hostProfiles",
          "sourceReportTypes",
          "cubeEligible"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "lanes"
  ],
  "title": "Fawn governed lane catalog",
  "type": "object"
}
