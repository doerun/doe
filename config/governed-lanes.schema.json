{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn governed lane catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "lanes"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "displayName",
          "governanceKind",
          "surface",
          "hostProfiles",
          "sourceReportTypes",
          "cubeEligible"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "governanceKind": {
            "type": "string",
            "enum": [
              "backend_runtime",
              "package_compare",
              "browser_gate",
              "browser_claim"
            ]
          },
          "surface": {
            "type": "string",
            "enum": [
              "backend_native",
              "node_package",
              "bun_package",
              "browser"
            ]
          },
          "hostProfiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "providerPairs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "sourceReportTypes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "backend_compare_report",
                "node_package_compare_report",
                "bun_package_compare_report",
                "browser_gate_report",
                "browser_claim_report"
              ]
            }
          },
          "cubeEligible": {
            "type": "boolean"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
