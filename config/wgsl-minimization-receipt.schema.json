{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/wgsl-minimization-receipt.schema.json",
  "title": "WGSL minimization receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactKind",
    "receiptId",
    "manifestPath",
    "corpusId",
    "source",
    "failure",
    "minimizationPolicy",
    "candidates"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "wgsl_minimization_receipt" },
    "receiptId": { "type": "string", "minLength": 1 },
    "manifestPath": { "type": "string", "minLength": 1 },
    "corpusId": { "type": "string", "minLength": 1 },
    "source": { "$ref": "#/$defs/SourceIdentity" },
    "failure": { "$ref": "#/$defs/FailureIdentity" },
    "minimizationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateStatus",
        "preservesOriginalIdentity",
        "freeFormDiagnosticCompared",
        "replayRequired"
      ],
      "properties": {
        "candidateStatus": { "type": "string", "const": "pending_replay" },
        "preservesOriginalIdentity": { "type": "boolean", "const": true },
        "freeFormDiagnosticCompared": { "type": "boolean", "const": false },
        "replayRequired": { "type": "boolean", "const": true }
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Candidate" }
    }
  },
  "$defs": {
    "Hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "SourceIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shaderId",
        "category",
        "sourcePath",
        "normalizedSourceSha256",
        "expectedValidity",
        "expectedBackendTargets",
        "shaderStages"
      ],
      "properties": {
        "shaderId": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "sourcePath": { "type": "string", "minLength": 1 },
        "normalizedSourceSha256": { "$ref": "#/$defs/Hash" },
        "expectedValidity": { "enum": ["valid", "invalid"] },
        "expectedBackendTargets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["msl", "spirv", "dxil", "hlsl"] }
        },
        "shaderStages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["compute", "vertex", "fragment"] }
        }
      }
    },
    "FailureIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "taxonomyCode", "diagnosticCategory", "backendTargets"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "taxonomyCode": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "diagnosticCategory": {
          "enum": ["syntax", "semantic", "type", "control_flow", "binding", "none"]
        },
        "backendTargets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["msl", "spirv", "dxil", "hlsl"] }
        }
      }
    },
    "Candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "transformation",
        "candidatePath",
        "normalizedSourceSha256",
        "parentSourceSha256",
        "retainedLineStart",
        "retainedLineEnd",
        "lineCount",
        "status",
        "replayRequired"
      ],
      "properties": {
        "candidateId": { "type": "string", "minLength": 1 },
        "transformation": {
          "enum": [
            "normalized_original",
            "diagnostic_line_window",
            "entrypoint_block",
            "drop_local_declarations"
          ]
        },
        "candidatePath": { "type": "string", "minLength": 1 },
        "normalizedSourceSha256": { "$ref": "#/$defs/Hash" },
        "parentSourceSha256": { "$ref": "#/$defs/Hash" },
        "retainedLineStart": { "type": "integer", "minimum": 1 },
        "retainedLineEnd": { "type": "integer", "minimum": 1 },
        "lineCount": { "type": "integer", "minimum": 1 },
        "status": { "type": "string", "const": "pending_replay" },
        "replayRequired": { "type": "boolean", "const": true }
      }
    }
  }
}
