{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Backend Runtime Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "defaultLane", "lanes"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 4 },
    "defaultLane": { "type": "string", "minLength": 1 },
    "selectionPolicyHashSeed": { "type": "string" },
    "cutoverPolicyPath": { "type": "string", "minLength": 1 },
    "lanes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["defaultBackend", "allowFallback", "strictNoFallback", "queueFamilyPolicy", "deferredSubmissionSyncPolicy"],
        "properties": {
          "defaultBackend": { "type": "string", "enum": ["dawn_delegate", "webkit_delegate", "doe_metal", "doe_vulkan", "doe_d3d12"] },
          "allowFallback": { "type": "boolean", "const": false },
          "strictNoFallback": { "type": "boolean", "const": true },
          "uploadPathPolicy": {
            "type": "string",
            "enum": ["allow_mapped_shortcuts", "staged_copy_only"]
          },
          "queueFamilyPolicy": {
            "type": "string",
            "enum": ["prefer_graphics_compute", "prefer_compute_only", "require_compute_only"]
          },
          "deferredSubmissionSyncPolicy": {
            "type": "string",
            "enum": ["prefer_timeline_semaphore", "require_fence_pool"]
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
