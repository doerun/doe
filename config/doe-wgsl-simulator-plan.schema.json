{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DOE WGSL CSL Simulator Plan Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactKind",
    "target",
    "contract",
    "driver",
    "inputs",
    "runtime",
    "outputs"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "artifactKind": { "type": "string", "const": "csl_simulator_plan" },
    "target": { "type": "string", "const": "wse3" },
    "contract": { "type": "string", "const": "explicit_simulator_launch" },
    "driver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "executableEnvVar", "failClosedIfMissing"],
      "properties": {
        "protocol": { "type": "string", "const": "doe.csl.simulator/v1" },
        "executableEnvVar": { "type": "string", "const": "DOE_CSL_SIM_EXECUTABLE" },
        "failClosedIfMissing": { "type": "boolean", "const": true },
        "executablePath": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostPlanArtifactPath", "runtimeConfigPath", "compileRootPath", "compileTargets"],
      "properties": {
        "hostPlanArtifactPath": { "type": "string", "minLength": 1 },
        "runtimeConfigPath": { "type": "string", "minLength": 1 },
        "compileRootPath": { "type": "string", "minLength": 1 },
        "compileTargets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "layout", "peProgram"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "layout": { "type": "string", "minLength": 1 },
              "peProgram": { "type": "string", "minLength": 1 },
              "sourceWgslPath": {
                "type": "string",
                "minLength": 1,
                "description": "Optional path (relative to repo root or absolute) of a WGSL source file. When present, the governed lane runner (bench/runners/run_csl_governed_lane.py::materialize_plan) invokes doe-csl-bundle-emitter to regenerate layout.csl + pe_program.csl from this WGSL at compile-input staging time, bypassing the static `compile/<target>/` fixture copy. Lets Doe's WGSL→CSL emitter chain be the single source of truth for the target's CSL; any emitter fix propagates to the lane without per-fixture updates. Absent (default) keeps the prior static-copy behavior for compatibility with hand-authored fixtures like the Gemma-3 270M manifest smoke."
              },
              "compileParams": {
                "type": "object",
                "additionalProperties": { "type": "integer" },
                "description": "Optional extra `--params key:value` bindings appended to the cslc command for this compileTarget. The default `width:{peGrid.width}` and `height:{peGrid.height}` bindings are always included; these entries extend (and may override) them. Used by kernels that declare additional top-level layout params — e.g., tiled_matmul needs `P:2,Mt:8,Kt:8,Nt:8` — so the governed plan stays the single source of truth for how each kernel is compiled."
              },
              "compileBlockedReason": {
                "type": "string",
                "minLength": 1,
                "description": "Typed fail-closed reason telling the SDK driver to skip cslc for this target because governed manifest compile-param projection proved the target shape cannot fit the current HostPlan grid/budget. The driver records a blocked compile target with this reason instead of hanging or surfacing a misleading SDK memory diagnostic."
              },
              "hostIoLayout": {
                "type": "object",
                "description": "Optional per-kernel host I/O layout directives. Same shape as csl-operation-graph.schema.json#hostIoLayout entries; embed.chunkedDispatch tells the Python host runner to iterate ceil(num_tokens / tokensPerChunk) launches and concatenate per-column slices across the hiddenShardCount axis of the PE grid. Kernels without a hostIoLayout use single-launch default dispatch."
              },
              "metadata": {
                "$ref": "#/$defs/compileTargetMetadata",
                "description": "Structured Zig-emitted binding metadata used by Python host-plan materialization instead of reparsing layout.csl/pe_program.csl text. Carries target phase, symbol shapes, staging/detile transforms, and weight-source hints."
              }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "peGrid",
        "prefillLaunchCount",
        "decodeLaunchCount",
        "weightMappingCount",
        "stateBufferCount",
        "maxDecodeTokens",
        "timeoutMs",
        "batchSize",
        "eosTokenId"
      ],
      "properties": {
        "peGrid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "prefillLaunchCount": { "type": "integer", "minimum": 0 },
        "decodeLaunchCount": { "type": "integer", "minimum": 0 },
        "weightMappingCount": { "type": "integer", "minimum": 0 },
        "stateBufferCount": { "type": "integer", "minimum": 0 },
        "maxDecodeTokens": { "type": "integer", "minimum": 0 },
        "timeoutMs": { "type": "integer", "minimum": 0 },
        "compileTimeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional per-cslc target timeout used by the SDK driver. This bounds diagnostic compile hangs while preserving the plan as the source of truth for the timeout."
        },
        "batchSize": { "type": "integer", "minimum": 1 },
        "eosTokenId": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdoutPath", "stderrPath", "tracePath"],
      "properties": {
        "stdoutPath": { "type": "string", "minLength": 1 },
        "stderrPath": { "type": "string", "minLength": 1 },
        "tracePath": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "compileTargetMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetPhase", "bindings"],
      "properties": {
        "targetPhase": {
          "type": "string",
          "enum": ["base", "prefill", "decode"]
        },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/bindingMetadata" }
        }
      }
    },
    "bindingMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "access",
        "elemType",
        "bindingShape",
        "perPeShape",
        "stagingTransform",
        "detileTransform",
        "weightSource"
      ],
      "properties": {
        "symbol": { "type": "string", "minLength": 1 },
        "access": {
          "type": "string",
          "enum": ["read", "write", "read_write"]
        },
        "elemType": { "type": "string", "minLength": 1 },
        "bindingShape": { "$ref": "#/$defs/bindingShape" },
        "perPeShape": { "$ref": "#/$defs/bindingShape" },
        "stagingTransform": {
          "anyOf": [{ "$ref": "#/$defs/bindingTransform" }, { "type": "null" }]
        },
        "detileTransform": {
          "anyOf": [{ "$ref": "#/$defs/bindingTransform" }, { "type": "null" }]
        },
        "weightSource": {
          "type": ["string", "null"],
          "enum": ["runtime_weight_mapping", null]
        }
      }
    },
    "bindingShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "elements"],
      "properties": {
        "kind": { "type": "string", "const": "csl_array" },
        "elements": { "type": "string", "minLength": 1 }
      }
    },
    "bindingTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "logical_matrix_to_summa_tiles",
            "weight_matrix_to_summa_tiles",
            "summa_tiles_to_logical_matrix",
            "logical_matrix_to_pe_rows",
            "pe_rows_to_logical_matrix",
            "logical_vector_to_dense_gemv_activation_shards",
            "tied_f16_embedding_to_dense_gemv_shards",
            "dense_gemv_row_shards_to_logits"
          ]
        },
        "matrixRole": { "type": "string", "minLength": 1 },
        "rowsFromInput": { "type": "string", "minLength": 1 }
      }
    }
  }
}
