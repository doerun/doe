{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/compute-services.schema.json",
  "type": "object",
  "required": ["schemaVersion", "moduleId", "artifactKind"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "moduleId": { "type": "string", "const": "fawn_compute_services" },
    "artifactKind": { "type": "string", "enum": ["request", "result", "policy"] },
    "version": { "type": "integer", "const": 1 },
    "promotedFromNursery": { "type": "boolean", "const": true },
    "promotedAt": { "type": "string", "format": "date" }
  },
  "allOf": [
    {
      "if": { "properties": { "artifactKind": { "const": "request" } } },
      "then": { "$ref": "#/$defs/request" }
    },
    {
      "if": { "properties": { "artifactKind": { "const": "result" } } },
      "then": { "$ref": "#/$defs/result" }
    },
    {
      "if": { "properties": { "artifactKind": { "const": "policy" } } },
      "then": { "$ref": "#/$defs/policy" }
    }
  ],
  "$defs": {
    "request": {
      "required": ["serviceId", "kernelId", "inputs", "dispatch", "policy"],
      "properties": {
        "serviceId": { "type": "string", "minLength": 1 },
        "kernelId": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "bytes"],
            "properties": {
              "kind": { "type": "string", "enum": ["buffer", "texture"] },
              "bytes": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "dispatch": {
          "type": "object",
          "required": ["x", "y", "z"],
          "properties": {
            "x": { "type": "integer", "minimum": 1 },
            "y": { "type": "integer", "minimum": 1 },
            "z": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "policy": {
          "type": "object",
          "required": ["safetyClass", "verificationMode"],
          "properties": {
            "safetyClass": { "type": "string", "minLength": 1 },
            "verificationMode": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      }
    },
    "result": {
      "required": ["serviceResult", "executionStats", "timingStats", "failureDetails", "traceLink"],
      "properties": {
        "serviceResult": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["ok", "fallback", "error"] }
          },
          "additionalProperties": false
        },
        "executionStats": {
          "type": "object",
          "required": ["dispatchCount", "bytesMoved"],
          "properties": {
            "dispatchCount": { "type": "integer", "minimum": 0 },
            "bytesMoved": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "timingStats": {
          "type": "object",
          "required": ["setupNs", "encodeNs", "submitNs", "dispatchNs"],
          "properties": {
            "setupNs": { "type": "integer", "minimum": 0 },
            "encodeNs": { "type": "integer", "minimum": 0 },
            "submitNs": { "type": "integer", "minimum": 0 },
            "dispatchNs": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "failureDetails": {
          "type": "object",
          "required": ["code"],
          "properties": {
            "code": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "traceLink": {
          "type": "object",
          "required": ["moduleIdentity", "requestHash", "policyHash", "resultHash"],
          "properties": {
            "moduleIdentity": { "type": "string", "minLength": 1 },
            "requestHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "policyHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "resultHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          },
          "additionalProperties": false
        }
      }
    },
    "policy": {
      "required": ["version", "promotedFromNursery", "promotedAt", "policy"],
      "properties": {
        "policy": {
          "type": "object",
          "required": ["services", "maxDispatchesPerRequest", "maxInputBytes"],
          "properties": {
            "services": {
              "type": "object",
              "required": ["sdf_atlas_upload", "path_mask_reduce"],
              "properties": {
                "sdf_atlas_upload": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "path_mask_reduce": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            },
            "maxDispatchesPerRequest": { "type": "integer", "minimum": 1 },
            "maxInputBytes": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      }
    }
  }
}
