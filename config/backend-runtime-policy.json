{
  "schemaVersion": 1,
  "defaultLane": "vulkan_oracle",
  "selectionPolicyHashSeed": "backend-runtime-policy-v1",
  "cutoverPolicyPath": "config/backend-cutover-policy.json",
  "rollbackSwitch": {
    "name": "force_dawn_oracle",
    "forceBackend": "dawn_oracle"
  },
  "lanes": {
    "vulkan_oracle": {
      "defaultBackend": "dawn_oracle",
      "allowFallback": true,
      "strictNoFallback": false,
      "notes": "Oracle benchmark/claim lane retained after app cutover"
    },
    "vulkan_app": {
      "defaultBackend": "zig_vulkan",
      "allowFallback": false,
      "strictNoFallback": true,
      "notes": "AMD Vulkan app lane after controlled cutover"
    },
    "metal_local_directional": {
      "defaultBackend": "zig_metal",
      "allowFallback": true,
      "strictNoFallback": false,
      "notes": "Directional diagnostics lane"
    },
    "metal_local_comparable": {
      "defaultBackend": "zig_metal",
      "allowFallback": false,
      "strictNoFallback": true,
      "notes": "Strict comparable lane"
    },
    "metal_local_release": {
      "defaultBackend": "zig_metal",
      "allowFallback": false,
      "strictNoFallback": true,
      "notes": "Strict release lane"
    },
    "metal_oracle": {
      "defaultBackend": "dawn_oracle",
      "allowFallback": true,
      "strictNoFallback": false,
      "notes": "Metal oracle benchmark lane"
    },
    "vulkan_local_directional": {
      "defaultBackend": "dawn_oracle",
      "allowFallback": true,
      "strictNoFallback": false,
      "notes": "Vulkan diagnostics lane"
    },
    "vulkan_local_comparable": {
      "defaultBackend": "zig_vulkan",
      "allowFallback": false,
      "strictNoFallback": true,
      "notes": "Strict comparable Vulkan lane"
    },
    "vulkan_local_release": {
      "defaultBackend": "zig_vulkan",
      "allowFallback": false,
      "strictNoFallback": true,
      "notes": "Strict local Vulkan release lane"
    },
    "metal_app": {
      "defaultBackend": "zig_metal",
      "allowFallback": false,
      "strictNoFallback": true,
      "notes": "Controlled cutover target"
    }
  }
}
