{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Benchmark Methodology Thresholds",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "timingSelection", "claimabilityDefaults", "timingScopeSanity", "reliability"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "timingSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minDispatchWindowNsWithoutEncode",
        "minDispatchWindowCoveragePercentWithoutEncode"
      ],
      "properties": {
        "minDispatchWindowNsWithoutEncode": { "type": "integer", "minimum": 0 },
        "minDispatchWindowCoveragePercentWithoutEncode": { "type": "number", "minimum": 0.0 }
      }
    },
    "claimabilityDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["localMinTimedSamples", "releaseMinTimedSamples"],
      "properties": {
        "localMinTimedSamples": { "type": "integer", "minimum": 0 },
        "releaseMinTimedSamples": { "type": "integer", "minimum": 0 }
      }
    },
    "timingScopeSanity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minOperationWallCoverageRatio",
        "maxOperationWallCoverageAsymmetryRatio"
      ],
      "properties": {
        "minOperationWallCoverageRatio": { "type": "number", "minimum": 0.0 },
        "maxOperationWallCoverageAsymmetryRatio": { "type": "number", "minimum": 1.0 }
      }
    },
    "reliability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "localRequiredPositivePercentiles",
        "releaseRequiredPositivePercentiles",
        "flakeBudgetPercent",
        "retryPolicy"
      ],
      "properties": {
        "localRequiredPositivePercentiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "releaseRequiredPositivePercentiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "flakeBudgetPercent": { "type": "number", "minimum": 0.0 },
        "retryPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxRetries", "retryOn"],
          "properties": {
            "maxRetries": { "type": "integer", "minimum": 0 },
            "retryOn": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
