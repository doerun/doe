{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "doe-parity-receipt.schema.json",
  "title": "Doe parity receipt",
  "description": "Emitted by bench/tools/doe_parity.py. One receipt per kernel per invocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactKind",
    "kernel",
    "exactnessClass",
    "inputsDigest",
    "comparisons",
    "rejectionReasons"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "artifactKind": { "type": "string", "const": "doe_parity_receipt" },
    "kernel": { "type": "string", "minLength": 1 },
    "exactnessClass": {
      "type": "string",
      "enum": ["bit_exact_solo", "algorithm_exact", "tolerance_bounded"]
    },
    "referenceHash": { "type": ["string", "null"] },
    "referenceSource": {
      "description": "Names the oracle regime that produced the reference hash. Bootstrap kernels use the Zig scalar interpreter; real kernels use Doppler's browser reference transcript. Absent receipts pre-date the re-scope.",
      "oneOf": [
        { "$ref": "#/$defs/referenceSourceZig" },
        { "$ref": "#/$defs/referenceSourceDoppler" }
      ]
    },
    "inputsDigest": { "type": "string" },
    "loweringIdentity": { "$ref": "#/$defs/loweringIdentity" },
    "comparisons": {
      "type": "array",
      "items": { "$ref": "#/$defs/comparison" }
    },
    "rejectionReasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "tsir_subgroup_unlowerable",
          "tsir_pe_budget_exhausted",
          "tsir_collective_not_representable",
          "tsir_dependence_unanalyzable",
          "tsir_source_not_affine",
          "tsir_target_unfit"
        ]
      }
    }
  },
  "$defs": {
    "hexDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "referenceSourceZig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "zig-tsir-oracle" },
        "detail": { "type": ["string", "null"] }
      }
    },
    "referenceSourceDoppler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "executionGraphHash", "sourceHash"],
      "properties": {
        "kind": { "type": "string", "const": "doppler-reference-transcript" },
        "executionGraphHash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "sourceHash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "transcriptPath": { "type": ["string", "null"] },
        "detail": { "type": ["string", "null"] }
      }
    },
    "loweringIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tsirSemanticDigest",
        "tsirRealizationDigest",
        "emitterDigest",
        "targetDescriptorCorrectnessHash"
      ],
      "properties": {
        "tsirSemanticDigest": { "$ref": "#/$defs/hexDigest" },
        "tsirRealizationDigest": { "$ref": "#/$defs/hexDigest" },
        "emitterDigest": { "$ref": "#/$defs/hexDigest" },
        "targetDescriptorCorrectnessHash": {
          "$ref": "#/$defs/hexDigest"
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "status"],
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["reference", "webgpu", "csl-simfabric", "csl-hardware"]
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "deferred", "not_implemented", "rejected"]
        },
        "backendHash": { "type": ["string", "null"] },
        "detail": { "type": ["string", "null"] }
      }
    }
  }
}
