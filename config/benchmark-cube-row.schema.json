{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Benchmark Cube Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "generatedAt",
    "sourceReportType",
    "sourceReportPath",
    "sourceConformance",
    "host",
    "surface",
    "providerPair",
    "comparisonView",
    "providerSet",
    "providers",
    "governedLaneIds",
    "workloadSet",
    "workloadId",
    "workloadDomain",
    "comparisonStatus",
    "claimStatus",
    "maturity",
    "metrics"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceReportType": {
      "type": "string",
      "enum": [
        "backend_compare_report",
        "node_package_compare_report",
        "bun_package_compare_report"
      ]
    },
    "sourceReportPath": {
      "type": "string",
      "minLength": 1
    },
    "sourceConformance": {
      "type": "string",
      "enum": [
        "canonical",
        "legacy_nonconformant"
      ]
    },
    "sourceConformanceReason": {
      "type": "string"
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileId",
        "os",
        "arch"
      ],
      "properties": {
        "profileId": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "arch": {
          "type": "string",
          "minLength": 1
        },
        "backend": {
          "type": "string",
          "minLength": 1
        },
        "gpuVendor": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "backend_native",
        "node_package",
        "bun_package"
      ]
    },
    "providerPair": {
      "type": "string",
      "minLength": 1
    },
    "comparisonView": {
      "type": "string",
      "minLength": 1
    },
    "providerSet": {
      "type": "string",
      "minLength": 1
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "governedLaneIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "workloadSet": {
      "type": "string",
      "minLength": 1
    },
    "workloadId": {
      "type": "string",
      "minLength": 1
    },
    "sourceWorkloadId": {
      "type": "string",
      "minLength": 1
    },
    "workloadDomain": {
      "type": "string",
      "minLength": 1
    },
    "comparisonStatus": {
      "type": "string",
      "enum": [
        "unsupported",
        "unimplemented",
        "diagnostic",
        "comparable",
        "claimable"
      ]
    },
    "claimStatus": {
      "type": "string",
      "enum": [
        "unsupported",
        "unimplemented",
        "diagnostic",
        "comparable",
        "claimable"
      ]
    },
    "maturity": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "prototype"
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baselineP50Ms",
        "comparisonP50Ms",
        "deltaP50Percent",
        "baselineP95Ms",
        "comparisonP95Ms",
        "baselineP99Ms",
        "comparisonP99Ms",
        "baselineSampleCount",
        "comparisonSampleCount"
      ],
      "properties": {
        "baselineP50Ms": {
          "type": [
            "number",
            "null"
          ]
        },
        "comparisonP50Ms": {
          "type": [
            "number",
            "null"
          ]
        },
        "deltaP50Percent": {
          "type": [
            "number",
            "null"
          ]
        },
        "baselineP95Ms": {
          "type": [
            "number",
            "null"
          ]
        },
        "comparisonP95Ms": {
          "type": [
            "number",
            "null"
          ]
        },
        "baselineP99Ms": {
          "type": [
            "number",
            "null"
          ]
        },
        "comparisonP99Ms": {
          "type": [
            "number",
            "null"
          ]
        },
        "baselineSampleCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "comparisonSampleCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    }
  }
}
