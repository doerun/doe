{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Comparability Obligation Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "obligationIds"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "obligationIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    }
  }
}
