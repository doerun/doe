{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doe Gemma-4 E2B manifest-shape runtime path",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactKind",
    "status",
    "verdict",
    "modelId",
    "inputs",
    "manifestShapeContract",
    "existingEvidence",
    "runtimeStages",
    "promotionCriteriaMet",
    "claimScope",
    "blockers",
    "nextOperatorReceipts",
    "errors"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": {
      "type": "string",
      "const": "doe_gemma4_e2b_manifest_shape_runtime_path"
    },
    "status": {
      "type": "string",
      "enum": ["blocked", "failed"]
    },
    "verdict": { "type": "string", "minLength": 1 },
    "modelId": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionManifest",
        "manifestShapeProbe",
        "cpuOracle",
        "attentionCoreReceipt",
        "modelReceipt"
      ],
      "properties": {
        "executionManifest": { "$ref": "#/$defs/FileLink" },
        "manifestShapeProbe": { "$ref": "#/$defs/FileLink" },
        "cpuOracle": { "$ref": "#/$defs/FileLink" },
        "attentionCoreReceipt": { "$ref": "#/$defs/FileLink" },
        "modelReceipt": { "$ref": "#/$defs/FileLink" }
      }
    },
    "manifestShapeContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hiddenSize",
        "numLayers",
        "localHeadDim",
        "globalHeadDim",
        "numAttentionHeads",
        "numKeyValueHeads",
        "numKvSharedLayers",
        "localAttentionLayerIndices",
        "globalAttentionLayerIndices",
        "pleWidth",
        "vocabSize"
      ],
      "properties": {
        "hiddenSize": { "type": "integer", "minimum": 1 },
        "numLayers": { "type": "integer", "minimum": 1 },
        "localHeadDim": { "type": "integer", "minimum": 1 },
        "globalHeadDim": { "type": "integer", "minimum": 1 },
        "numAttentionHeads": { "type": "integer", "minimum": 1 },
        "numKeyValueHeads": { "type": "integer", "minimum": 1 },
        "numKvSharedLayers": { "type": "integer", "minimum": 0 },
        "localAttentionLayerIndices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "globalAttentionLayerIndices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "pleWidth": { "type": "integer", "minimum": 1 },
        "vocabSize": { "type": "integer", "minimum": 1 }
      }
    },
    "existingEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestShapeProbeStatus",
        "cpuOracleStatus",
        "cpuOracleVerdict",
        "attentionCoreStatus",
        "attentionCoreVerdict",
        "attentionCoreCslRuntimeExecuted",
        "sdkLayoutSmokePromotionStatus",
        "sdkLayoutSmokeClaimScope"
      ],
      "properties": {
        "manifestShapeProbeStatus": { "type": ["string", "null"] },
        "cpuOracleStatus": { "type": ["string", "null"] },
        "cpuOracleVerdict": { "type": ["string", "null"] },
        "attentionCoreStatus": { "type": ["string", "null"] },
        "attentionCoreVerdict": { "type": ["string", "null"] },
        "attentionCoreCslRuntimeExecuted": { "type": ["boolean", "null"] },
        "sdkLayoutSmokePromotionStatus": { "type": ["string", "null"] },
        "sdkLayoutSmokeClaimScope": { "type": ["string", "null"] }
      }
    },
    "runtimeStages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/RuntimeStage" }
    },
    "promotionCriteriaMet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpuOracleLinked",
        "upstreamManifestShapeRecorded",
        "localGlobalHeadDimCoveredByPath",
        "groupedKvCoveredByPath",
        "embedUnembedCoveredByPath",
        "logitsParityCoveredByPath",
        "doeRuntimeExecuted",
        "cslRuntimeExecuted",
        "hardwareExecuted",
        "claimable"
      ],
      "properties": {
        "cpuOracleLinked": { "type": "boolean" },
        "upstreamManifestShapeRecorded": { "type": "boolean" },
        "localGlobalHeadDimCoveredByPath": { "type": "boolean" },
        "groupedKvCoveredByPath": { "type": "boolean" },
        "embedUnembedCoveredByPath": { "type": "boolean" },
        "logitsParityCoveredByPath": { "type": "boolean" },
        "doeRuntimeExecuted": { "const": false },
        "cslRuntimeExecuted": { "const": false },
        "hardwareExecuted": { "const": false },
        "claimable": { "const": false }
      }
    },
    "claimScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimable", "summary", "notClaimable"],
      "properties": {
        "claimable": { "const": false },
        "summary": { "type": "string", "minLength": 1 },
        "notClaimable": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "nextOperatorReceipts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "required", "expectedFields"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "expectedFields": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "FileLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "exists": { "type": "boolean" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "RuntimeStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "stageName",
        "status",
        "shape",
        "coverage",
        "blockers",
        "implementationWork"
      ],
      "properties": {
        "stageId": { "type": "string", "minLength": 1 },
        "stageName": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["blocked_doe_csl_runtime_missing"]
        },
        "shape": { "type": "object", "additionalProperties": true },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpuOracle", "doeCslRuntime", "hardware"],
          "properties": {
            "cpuOracle": { "type": "boolean" },
            "doeCslRuntime": { "const": false },
            "hardware": { "const": false }
          }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "implementationWork": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
