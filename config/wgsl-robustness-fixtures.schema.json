{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/wgsl-robustness-fixtures.schema.json",
  "title": "WGSL robustness fixtures",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactKind", "fixtureSetId", "rows"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "wgsl_robustness_fixtures" },
    "fixtureSetId": { "type": "string", "minLength": 1 },
    "rows": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/FixtureRow" }
    }
  },
  "$defs": {
    "Hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "FixtureRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixtureId",
        "patternClass",
        "sourcePath",
        "normalizedSourceSha256",
        "expectedTransform",
        "requiredNeedles",
        "browserWorkloadClasses"
      ],
      "properties": {
        "fixtureId": { "type": "string", "minLength": 1 },
        "patternClass": {
          "enum": ["bounds", "aliasing", "texture_dimension", "guard"]
        },
        "sourcePath": { "type": "string", "minLength": 1 },
        "normalizedSourceSha256": { "$ref": "#/$defs/Hash" },
        "expectedTransform": {
          "enum": ["clamp_inserted", "clamp_elided_when_proven", "guard_preserved"]
        },
        "requiredNeedles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "browserWorkloadClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "browser_shader",
              "canvas_workload",
              "webgpu_sample",
              "model_inference_kernel",
              "game_engine_shader"
            ]
          }
        }
      }
    }
  }
}
