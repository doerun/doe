{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://doe.local/config/pilot-evidence-receipt.schema.json",
  "title": "Doe pilot evidence receipt",
  "description": "Receipt shape for a pilot-candidate evidence bundle. One receipt captures the Doe-side reproduction (or negative reproduction) of a driving issue on a specific host, plus the artifact bundle and repro commands a recipient can re-run to verify the claim.",
  "type": "object",
  "required": [
    "schemaVersion",
    "pilotCandidate",
    "drivingIssue",
    "host",
    "doeBuild",
    "workload",
    "divergence",
    "artifactBundle",
    "methodology",
    "repro",
    "generatedAt"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "pilotCandidate": {
      "type": "object",
      "required": ["id", "tier", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Stable slug, e.g. 'huggingface-transformers-js' or 'microsoft-onnxruntime-web'."
        },
        "tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4,
          "description": "Tier per the pilot-candidate outreach doc: 1 = strongest ICP, 4 = browser-vendor."
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "drivingIssue": {
      "type": "object",
      "required": ["url", "summary"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Public issue URL anchoring the receipt (GitHub issue, forum post, bugzilla entry, etc.)."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "One-sentence restatement of what the issue reports."
        }
      }
    },
    "host": {
      "type": "object",
      "required": ["os", "gpu", "backend"],
      "additionalProperties": false,
      "properties": {
        "os": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical OS + arch string, e.g. 'linux-x86_64', 'macos-arm64', 'windows-x86_64'."
        },
        "gpu": {
          "type": "string",
          "minLength": 1,
          "description": "Adapter description as reported by the runtime or wgpu-info."
        },
        "driverVersion": {
          "type": "string"
        },
        "backend": {
          "type": "string",
          "enum": ["vulkan", "metal", "d3d12", "webgpu-browser", "cpu"],
          "description": "Runtime backend that executed the Doe-side reproduction."
        }
      }
    },
    "doeBuild": {
      "type": "object",
      "required": ["gitSha", "buildMode"],
      "additionalProperties": false,
      "properties": {
        "gitSha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "buildMode": {
          "type": "string",
          "enum": ["debug", "release", "releasefast", "releasesafe", "unknown"]
        },
        "leanVerified": {
          "type": "boolean",
          "description": "Whether the build consumed -Dlean-verified=true and therefore has proof-gated optimizations enabled."
        }
      }
    },
    "workload": {
      "type": "object",
      "required": ["description"],
      "additionalProperties": false,
      "properties": {
        "ref": {
          "type": "string",
          "description": "Optional repo-relative path to a workload definition (bench/workloads/...)."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Short description of what the reproduction actually exercises."
        }
      }
    },
    "divergence": {
      "type": "object",
      "required": ["reproduced", "divergenceKind", "notes"],
      "additionalProperties": false,
      "properties": {
        "reproduced": {
          "type": "boolean",
          "description": "True when the driving issue is observable on this host. False when Doe executes cleanly where the public issue reports failure — that's still outreach-useful evidence."
        },
        "divergenceKind": {
          "type": "string",
          "enum": [
            "no-divergence",
            "crash",
            "hang",
            "wrong-output",
            "validation-error",
            "adapter-lost",
            "fallback-to-cpu",
            "unsupported-feature"
          ]
        },
        "tracePath": {
          "type": "string",
          "description": "Optional repo-relative path to a Doe trace (meta+jsonl) capturing the observed behavior."
        },
        "notes": {
          "type": "string",
          "description": "Human-readable one-to-three-paragraph diagnosis of what happened and why it matches (or differs from) the driving issue."
        }
      }
    },
    "artifactBundle": {
      "type": "object",
      "required": ["path", "manifest"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Repo-relative directory that holds the bundle. Typically 'bench/out/pilot-evidence/<candidate>-<timestamp>/'."
        },
        "manifest": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "sha256", "sizeBytes"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "description": "Bundle-relative path (no leading slash)."
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "sizeBytes": {
                "type": "integer",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "trace-meta",
                  "trace-jsonl",
                  "compare-report",
                  "claim-report",
                  "run-receipt",
                  "screenshot",
                  "log",
                  "model",
                  "shader",
                  "other"
                ]
              }
            }
          }
        }
      }
    },
    "methodology": {
      "type": "object",
      "required": ["notes"],
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "How the reproduction was set up: harness used, timing source, sample counts, any deviations from a pristine matched run."
        },
        "knownCaveats": {
          "type": "string",
          "description": "Explicit caveats a recipient should know before citing this receipt (adapter-dependent behavior, non-deterministic paths, missing hardware, etc.)."
        }
      }
    },
    "repro": {
      "type": "object",
      "required": ["commands"],
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Ordered shell commands a recipient runs from the repo root to re-execute the reproduction."
        },
        "envVars": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional environment variables the commands depend on (DOE_* toggles, backend pins, model roots, etc.)."
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp for when the receipt was emitted."
    }
  }
}
