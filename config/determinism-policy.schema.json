{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doe-gpu.dev/config/determinism-policy.schema.json",
  "title": "Doe determinism policy registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "registryVersion",
    "policyRegistryPath",
    "proofArtifactPath",
    "candidateSetSources",
    "stableToken",
    "stableChoice",
    "reviewedChoice"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "registryVersion": { "type": "string", "minLength": 1 },
    "policyRegistryPath": { "type": "string", "minLength": 1 },
    "proofArtifactPath": { "type": "string", "minLength": 1 },
    "candidateSetSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["fixture-declared", "registry-resolved", "source-report-resolved"]
      }
    },
    "stableToken": { "$ref": "#/$defs/stableTokenPolicy" },
    "stableChoice": { "$ref": "#/$defs/stableChoicePolicy" },
    "reviewedChoice": { "$ref": "#/$defs/reviewedChoicePolicy" }
  },
  "additionalProperties": false,
  "$defs": {
    "proofLink": {
      "type": "object",
      "required": ["theorem", "module", "category", "relation", "artifactPath"],
      "properties": {
        "theorem": { "type": "string", "minLength": 1 },
        "module": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["tautological", "comptime_verified", "lean_verified", "lean_fixture", "lean_required"]
        },
        "relation": { "type": "string", "minLength": 1 },
        "artifactPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "proofLinkSetByTriggerMode": {
      "type": "object",
      "required": ["exact-max-tie", "candidate-margin-band"],
      "properties": {
        "exact-max-tie": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proofLink" }
        },
        "candidate-margin-band": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proofLink" }
        }
      },
      "additionalProperties": false
    },
    "stableTokenPolicy": {
      "type": "object",
      "required": [
        "policyId",
        "comparator",
        "tieBreakRule",
        "selectedBy",
        "proofLinks"
      ],
      "properties": {
        "policyId": { "type": "string", "minLength": 1 },
        "comparator": { "const": "scalar-f32-greedy" },
        "tieBreakRule": { "const": "lowest-index-among-max" },
        "selectedBy": { "const": "stable-token-policy" },
        "proofLinks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proofLink" }
        }
      },
      "additionalProperties": false
    },
    "stableChoicePolicy": {
      "type": "object",
      "required": [
        "baseRuleId",
        "defaultPolicyId",
        "evaluatorKind",
        "selectedBy",
        "proofLinksByTriggerMode"
      ],
      "properties": {
        "baseRuleId": { "type": "string", "minLength": 1 },
        "defaultPolicyId": { "type": "string", "minLength": 1 },
        "evaluatorKind": { "const": "fixed-priority" },
        "selectedBy": {
          "type": "object",
          "required": ["policy", "fallback"],
          "properties": {
            "policy": { "const": "stable-choice-policy" },
            "fallback": { "const": "stable-token-fallback" }
          },
          "additionalProperties": false
        },
        "proofLinksByTriggerMode": { "$ref": "#/$defs/proofLinkSetByTriggerMode" }
      },
      "additionalProperties": false
    },
    "reviewedChoicePolicy": {
      "type": "object",
      "required": [
        "baseRuleId",
        "defaultPolicyId",
        "evaluatorKind",
        "selectedBy",
        "decisionAcceptanceReasons",
        "proofLinksByTriggerMode"
      ],
      "properties": {
        "baseRuleId": { "type": "string", "minLength": 1 },
        "defaultPolicyId": { "type": "string", "minLength": 1 },
        "evaluatorKind": { "const": "explicit-review-decision" },
        "selectedBy": {
          "type": "object",
          "required": ["decision", "fallback"],
          "properties": {
            "decision": { "const": "reviewed-choice-decision" },
            "fallback": { "const": "stable-token-fallback" }
          },
          "additionalProperties": false
        },
        "decisionAcceptanceReasons": {
          "type": "object",
          "required": ["accepted", "notTriggered", "notInCandidateSet", "notAmbiguous"],
          "properties": {
            "accepted": { "const": "reviewed-choice-decision" },
            "notTriggered": { "const": "stable-token-fallback/not-triggered" },
            "notInCandidateSet": { "const": "stable-token-fallback/not-in-candidate-set" },
            "notAmbiguous": { "const": "stable-token-fallback/not-ambiguous" }
          },
          "additionalProperties": false
        },
        "proofLinksByTriggerMode": { "$ref": "#/$defs/proofLinkSetByTriggerMode" }
      },
      "additionalProperties": false
    }
  }
}
