{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Benchmark Configuration",
  "description": "Defines baselines, metrics matrix, workloads, and comparison contract for Fawn benchmark runs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "baselines", "matrix", "workloads", "comparisonContract"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "baselines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["baselineId", "language", "role", "repo"],
        "properties": {
          "baselineId": { "type": "string", "minLength": 1 },
          "language": { "type": "string", "enum": ["cpp", "rust", "zig"] },
          "role": { "type": "string", "enum": ["incumbent_reference", "candidate"] },
          "repo": { "type": "string", "format": "uri" }
        }
      },
      "minItems": 1
    },
    "matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metricId", "description"],
        "properties": {
          "metricId": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "workloads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["workloadId", "description"],
        "properties": {
          "workloadId": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "comparisonContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claimStates",
        "requiredMetricsForIncumbentClaim",
        "requiredBaselines",
        "requiredMetadataFields",
        "attributionMethod"
      ],
      "properties": {
        "claimStates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["scaffold", "directional", "substantiated"]
          },
          "minItems": 1
        },
        "requiredMetricsForIncumbentClaim": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "requiredBaselines": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "requiredMetadataFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "attributionMethod": {
          "type": "object",
          "additionalProperties": false,
          "required": ["zig", "lean", "incumbents"],
          "properties": {
            "zig": { "type": "string" },
            "lean": { "type": "string" },
            "incumbents": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
