{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CSL Runtime Fixture Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactKind", "fixtures"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "csl_runtime_fixture_registry" },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fixture" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "fixtureId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "kernelPattern": {
      "type": "string",
      "enum": [
        "attention_decode",
        "attention_linear",
        "attention_tiled",
        "element_wise",
        "fused_gemv_dequant",
        "gather",
        "kv_write",
        "reduction",
        "rope",
        "sample",
        "tiled_matmul"
      ]
    },
    "backendStatus": {
      "type": "string",
      "enum": [
        "artifact_present",
        "compile_validated",
        "runtime_ready",
        "compile_ready",
        "blocked",
        "missing",
        "not_wired"
      ]
    },
    "backendCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vulkan", "metal", "d3d12", "csl"],
      "properties": {
        "vulkan": { "$ref": "#/$defs/backendStatus" },
        "metal": { "$ref": "#/$defs/backendStatus" },
        "d3d12": { "$ref": "#/$defs/backendStatus" },
        "csl": { "$ref": "#/$defs/backendStatus" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceWgslPath", "simulatorPlanPath", "hostPlanPath", "runtimeConfigPath"],
      "properties": {
        "sourceWgslPath": { "$ref": "#/$defs/path" },
        "sourceEvidenceDir": { "$ref": "#/$defs/path" },
        "simulatorPlanPath": { "$ref": "#/$defs/path" },
        "hostPlanPath": { "$ref": "#/$defs/path" },
        "runtimeConfigPath": { "$ref": "#/$defs/path" },
        "runnerPath": { "$ref": "#/$defs/path" },
        "governedLaneReportPath": { "$ref": "#/$defs/path" },
        "driverResultPath": { "$ref": "#/$defs/path" },
        "tracePath": { "$ref": "#/$defs/path" }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kernelPattern",
        "runtimeMode",
        "governedStatus",
        "backendCoverage",
        "evidence",
        "nextAction"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/fixtureId" },
        "kernelPattern": { "$ref": "#/$defs/kernelPattern" },
        "runtimeMode": {
          "type": "string",
          "enum": ["sdk-runtime-command", "compile-only"]
        },
        "governedStatus": {
          "type": "string",
          "enum": ["runtime_ready", "compile_ready", "blocked"]
        },
        "backendCoverage": { "$ref": "#/$defs/backendCoverage" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "reduceStrategy": {
          "type": "string",
          "description": "How the kernel produces its final output across PEs. 'none' = each PE's output is independent, no reduction. 'on_device_fabric' = fabric allreduce chain runs on WSE; host reads final result (legacy; prefer on_device_fabric_validated). 'on_device_fabric_validated' = fabric allreduce with verified teardown. 'on_device_fabric_quarantined' = fabric path exists but has a known teardown stall; still used when a host-partial fallback isn't wired. 'host_partial' = each PE exports a partial; host does the final reduction (legacy alias of host_reduce_partial). 'host_reduce_partial' = same contract, canonical name. Split into validated/quarantined at the plan §'Clean up fabric/partial semantics' ask.",
          "enum": [
            "none",
            "on_device_fabric",
            "on_device_fabric_validated",
            "on_device_fabric_quarantined",
            "host_partial",
            "host_reduce_partial"
          ]
        },
        "reduceStrategyNote": {
          "type": "string",
          "description": "Optional free-form note explaining the reduceStrategy choice — especially useful for quarantined entries ('known async-send teardown stall at…') and host_partial fallbacks ('fabric allreduce blocked on…'). When present, the dashboard and plan §6 taxonomy doc should surface it."
        },
        "nextAction": { "type": "string", "minLength": 1 }
      }
    }
  }
}
