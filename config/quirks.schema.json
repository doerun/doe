{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Driver Quirk Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "quirkId",
    "scope",
    "match",
    "action",
    "safetyClass",
    "verificationMode",
    "proofLevel",
    "provenance"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "quirkId": { "type": "string", "minLength": 3 },
    "scope": {
      "type": "string",
      "enum": ["alignment", "barrier", "layout", "driver_toggle", "memory"]
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "api"],
      "properties": {
        "vendor": { "type": "string" },
        "deviceFamily": { "type": "string" },
        "driverRange": { "type": "string" },
        "api": { "type": "string", "enum": ["vulkan", "metal", "d3d12", "webgpu"] }
      }
    },
    "action": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "params"],
          "properties": {
            "kind": { "const": "use_temporary_buffer" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["bufferAlignmentBytes"],
              "properties": {
                "bufferAlignmentBytes": { "type": "integer", "minimum": 1 },
                "reason": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "params"],
          "properties": {
            "kind": { "const": "toggle" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["toggle"],
              "properties": {
                "toggle": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "no_op" }
          }
        }
      ]
    },
    "safetyClass": {
      "type": "string",
      "enum": ["low", "moderate", "high", "critical"]
    },
    "verificationMode": {
      "type": "string",
      "enum": ["guard_only", "lean_preferred", "lean_required"]
    },
    "proofLevel": {
      "type": "string",
      "enum": ["proven", "guarded", "rejected"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceRepo", "sourcePath", "sourceCommit", "observedAt"],
      "properties": {
        "sourceRepo": { "type": "string" },
        "sourcePath": { "type": "string" },
        "sourceCommit": { "type": "string" },
        "observedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
