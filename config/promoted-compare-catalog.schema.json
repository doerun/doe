{
  "$defs": {
    "entry": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "not": {
              "required": [
                "packageRuntime"
              ]
            }
          },
          "if": {
            "properties": {
              "surface": {
                "const": "package"
              }
            }
          },
          "then": {
            "required": [
              "packageRuntime"
            ]
          }
        }
      ],
      "oneOf": [
        {
          "not": {
            "required": [
              "workload"
            ]
          },
          "required": [
            "preset"
          ]
        },
        {
          "not": {
            "required": [
              "preset"
            ]
          },
          "required": [
            "workload"
          ]
        }
      ],
      "properties": {
        "backend": {
          "minLength": 1,
          "type": "string"
        },
        "benchmarkClass": {
          "minLength": 1,
          "type": "string"
        },
        "boundary": {
          "minLength": 1,
          "type": "string"
        },
        "comparisonView": {
          "minLength": 1,
          "type": "string"
        },
        "configPath": {
          "minLength": 1,
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "baselineExecutorId": {
          "minLength": 1,
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "packageRuntime": {
          "enum": [
            "node",
            "bun",
            "deno"
          ],
          "type": "string"
        },
        "preset": {
          "minLength": 1,
          "type": "string"
        },
        "products": {
          "additionalProperties": false,
          "properties": {
            "baseline": {
              "additionalProperties": false,
              "properties": {
                "executorId": {
                  "minLength": 1,
                  "type": "string"
                },
                "product": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "product",
                "executorId"
              ],
              "type": "object"
            },
            "comparison": {
              "additionalProperties": false,
              "properties": {
                "executorId": {
                  "minLength": 1,
                  "type": "string"
                },
                "product": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "product",
                "executorId"
              ],
              "type": "object"
            }
          },
          "required": [
            "baseline",
            "comparison"
          ],
          "type": "object"
        },
        "providerSet": {
          "minLength": 1,
          "type": "string"
        },
        "providers": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 2,
          "type": "array",
          "uniqueItems": true
        },
        "comparisonExecutorId": {
          "minLength": 1,
          "type": "string"
        },
        "runtimeHost": {
          "minLength": 1,
          "type": "string"
        },
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "temperature": {
          "$ref": "#/$defs/mode"
        },
        "workload": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "backend",
        "boundary",
        "runtimeHost",
        "temperature",
        "comparisonView",
        "providerSet",
        "providers",
        "surface",
        "mode",
        "benchmarkClass",
        "baselineExecutorId",
        "comparisonExecutorId",
        "configPath",
        "description"
      ],
      "type": "object"
    },
    "mode": {
      "enum": [
        "default",
        "cold",
        "warm"
      ],
      "type": "string"
    },
    "surface": {
      "enum": [
        "backend",
        "plan",
        "package"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "entries": {
      "items": {
        "$ref": "#/$defs/entry"
      },
      "minItems": 1,
      "type": "array"
    },
    "schemaVersion": {
      "const": 4,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "entries"
  ],
  "title": "Doe promoted compare catalog",
  "type": "object"
}
