{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doe-gpu.dev/config/determinism-trigger-policy.schema.json",
  "title": "Determinism trigger policy registry",
  "type": "object",
  "required": ["schemaVersion", "registryVersion", "policies"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "registryVersion": { "type": "string", "minLength": 1 },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/policy" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "policy": {
      "type": "object",
      "required": ["id", "description", "mode", "epsilon"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["exact-max-tie", "candidate-margin-band"] },
        "epsilon": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "exact-max-tie" } } },
          "then": { "properties": { "epsilon": { "type": "null" } } }
        },
        {
          "if": { "properties": { "mode": { "const": "candidate-margin-band" } } },
          "then": { "properties": { "epsilon": { "type": "number", "minimum": 0 } } }
        }
      ]
    }
  }
}
