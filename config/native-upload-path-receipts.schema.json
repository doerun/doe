{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/native-upload-path-receipts.schema.json",
  "title": "Native upload path receipts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactKind", "receiptStatus", "rows", "failureCodes"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "native_upload_path_receipts" },
    "receiptStatus": { "enum": ["pass", "fail"] },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Row" }
    },
    "failureCodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Failure" }
    }
  },
  "$defs": {
    "Row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receiptId",
        "workloadId",
        "backend",
        "payloadBytes",
        "uploadPath",
        "allocationClass",
        "copyCommandsRecorded",
        "strictComparable",
        "pathAsymmetry",
        "pathAsymmetryNote",
        "claimEligible",
        "fallbackApplied",
        "hiddenFallbackAllowed"
      ],
      "properties": {
        "receiptId": { "type": "string", "minLength": 1 },
        "workloadId": { "type": "string", "minLength": 1 },
        "backend": { "enum": ["doe_metal", "doe_vulkan", "doe_d3d12"] },
        "payloadBytes": { "type": "integer", "minimum": 0 },
        "uploadPath": {
          "enum": ["staging_copy", "mapped_fast_path", "shared_memory_write", "disabled"]
        },
        "allocationClass": {
          "enum": ["persistent", "pooled", "per_upload", "none"]
        },
        "copyCommandsRecorded": { "type": "integer", "minimum": 0 },
        "strictComparable": { "type": "boolean" },
        "pathAsymmetry": { "type": "boolean" },
        "pathAsymmetryNote": { "type": "string" },
        "claimEligible": { "type": "boolean" },
        "fallbackApplied": { "type": "boolean" },
        "hiddenFallbackAllowed": { "type": "boolean", "const": false },
        "reasonCode": { "type": "string" }
      }
    },
    "Failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
