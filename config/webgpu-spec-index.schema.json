{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn WebGPU spec index (JSONL)",
  "description": "One JSON object per line. First line is the header; remaining lines are surface-point records.",
  "$defs": {
    "implementationStatus": {
      "type": "string",
      "enum": ["unreviewed", "implemented", "partial", "not_wired", "blocked", "out_of_scope"]
    },
    "correctnessStatus": {
      "type": "string",
      "enum": ["unreviewed", "unit", "integration", "cts", "governed"]
    },
    "performanceStatus": {
      "type": "string",
      "enum": ["unreviewed", "diagnostic", "comparable", "claimable", "not_meaningful"]
    },
    "backendCell": {
      "type": "object",
      "description": "Compact backend cell. All fields optional; absent = default (unreviewed).",
      "additionalProperties": false,
      "properties": {
        "impl": { "$ref": "#/$defs/implementationStatus" },
        "correct": { "$ref": "#/$defs/correctnessStatus" },
        "perf": { "$ref": "#/$defs/performanceStatus" },
        "notes": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        }
      }
    },
    "header": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schemaVersion", "lastUpdated", "specFamily", "source", "backends", "defaults", "implVocab", "correctVocab", "perfVocab", "stats"],
      "properties": {
        "kind": { "const": "header" },
        "schemaVersion": { "type": "integer", "const": 4 },
        "lastUpdated": { "type": "string" },
        "specFamily": { "const": "webgpu-api" },
        "source": {
          "type": "object",
          "required": ["kind", "package", "version", "tarballUrl", "apiReference"],
          "properties": {
            "kind": { "const": "npm-package" },
            "package": { "type": "string" },
            "version": { "type": "string" },
            "tarballUrl": { "type": "string" },
            "apiReference": { "type": "string" }
          }
        },
        "backends": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaults": {
          "type": "object",
          "properties": {
            "impl": { "$ref": "#/$defs/implementationStatus" },
            "correct": { "$ref": "#/$defs/correctnessStatus" },
            "perf": { "$ref": "#/$defs/performanceStatus" }
          }
        },
        "implVocab": { "type": "array", "items": { "$ref": "#/$defs/implementationStatus" } },
        "correctVocab": { "type": "array", "items": { "$ref": "#/$defs/correctnessStatus" } },
        "perfVocab": { "type": "array", "items": { "$ref": "#/$defs/performanceStatus" } },
        "stats": {
          "type": "object",
          "properties": {
            "interfaceCount": { "type": "integer" },
            "interfaceMemberCount": { "type": "integer" },
            "stringUnionCount": { "type": "integer" },
            "stringUnionValueCount": { "type": "integer" }
          }
        }
      }
    },
    "interfaceRecord": {
      "type": "object",
      "required": ["kind", "name", "interfaceKind", "specUrl", "memberCount"],
      "properties": {
        "kind": { "const": "interface" },
        "name": { "type": "string" },
        "interfaceKind": { "enum": ["interface", "dictionary", "mixin", "constant-interface"] },
        "specUrl": { "type": "string" },
        "memberCount": { "type": "integer" },
        "extends": { "type": "array", "items": { "type": "string" } },
        "metal": { "$ref": "#/$defs/backendCell" },
        "vulkan": { "$ref": "#/$defs/backendCell" },
        "d3d12": { "$ref": "#/$defs/backendCell" },
        "browser": { "$ref": "#/$defs/backendCell" }
      }
    },
    "memberRecord": {
      "type": "object",
      "required": ["kind", "parent", "name", "memberKind"],
      "properties": {
        "kind": { "const": "member" },
        "parent": { "type": "string" },
        "name": { "type": "string" },
        "memberKind": { "enum": ["method", "property"] },
        "metal": { "$ref": "#/$defs/backendCell" },
        "vulkan": { "$ref": "#/$defs/backendCell" },
        "d3d12": { "$ref": "#/$defs/backendCell" },
        "browser": { "$ref": "#/$defs/backendCell" }
      }
    },
    "unionRecord": {
      "type": "object",
      "required": ["kind", "name", "specUrl", "valueCount"],
      "properties": {
        "kind": { "const": "union" },
        "name": { "type": "string" },
        "specUrl": { "type": "string" },
        "valueCount": { "type": "integer" },
        "metal": { "$ref": "#/$defs/backendCell" },
        "vulkan": { "$ref": "#/$defs/backendCell" },
        "d3d12": { "$ref": "#/$defs/backendCell" },
        "browser": { "$ref": "#/$defs/backendCell" }
      }
    },
    "valueRecord": {
      "type": "object",
      "required": ["kind", "parent", "name"],
      "properties": {
        "kind": { "const": "value" },
        "parent": { "type": "string" },
        "name": { "type": "string" },
        "metal": { "$ref": "#/$defs/backendCell" },
        "vulkan": { "$ref": "#/$defs/backendCell" },
        "d3d12": { "$ref": "#/$defs/backendCell" },
        "browser": { "$ref": "#/$defs/backendCell" }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/header" },
    { "$ref": "#/$defs/interfaceRecord" },
    { "$ref": "#/$defs/memberRecord" },
    { "$ref": "#/$defs/unionRecord" },
    { "$ref": "#/$defs/valueRecord" }
  ]
}
