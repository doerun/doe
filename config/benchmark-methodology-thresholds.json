{
  "schemaVersion": 1,
  "timingSelection": {
    "minDispatchWindowNsWithoutEncode": 500000,
    "minDispatchWindowCoveragePercentWithoutEncode": 1.0
  },
  "claimabilityDefaults": {
    "localMinTimedSamples": 7,
    "releaseMinTimedSamples": 15
  },
  "timingScopeSanity": {
    "minOperationWallCoverageRatio": 0.05,
    "maxOperationWallCoverageAsymmetryRatio": 128.0
  },
  "reliability": {
    "localRequiredPositivePercentiles": [
      "p50Percent",
      "p95Percent"
    ],
    "releaseRequiredPositivePercentiles": [
      "p50Percent",
      "p95Percent",
      "p99Percent"
    ],
    "flakeBudgetPercent": 5.0,
    "retryPolicy": {
      "maxRetries": 2,
      "retryOn": [
        "execution_error",
        "timing_policy_mismatch",
        "shader_artifact_missing"
      ]
    }
  }
}
