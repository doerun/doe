{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doe vs Tint compiler evidence report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactKind",
    "generatedAt",
    "comparisonStatus",
    "claimStatus",
    "corpus",
    "toolchains",
    "phaseModel",
    "rows",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "artifactKind": {
      "type": "string",
      "const": "tint-compiler-evidence"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "comparisonStatus": {
      "type": "string",
      "enum": ["comparable", "diagnostic"]
    },
    "claimStatus": {
      "type": "string",
      "enum": ["claimable", "diagnostic"]
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "sourceSha256"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "sourceSha256": {
          "$ref": "#/$defs/sha256"
        },
        "manifestPath": {
          "type": "string"
        }
      }
    },
    "toolchains": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doe", "tint"],
      "properties": {
        "doe": {
          "$ref": "#/$defs/toolchain"
        },
        "tint": {
          "$ref": "#/$defs/toolchain"
        },
        "tintWarm": {
          "$ref": "#/$defs/toolchain"
        }
      }
    },
    "phaseModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timingScope", "units", "requiredPhases"],
      "properties": {
        "timingScope": {
          "type": "string",
          "enum": ["phase", "whole-compile"]
        },
        "units": {
          "type": "string",
          "const": "ns"
        },
        "requiredPhases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/row"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rowCount", "comparableRows", "claimableRows", "reasons"],
      "properties": {
        "rowCount": {
          "type": "integer",
          "minimum": 0
        },
        "comparableRows": {
          "type": "integer",
          "minimum": 0
        },
        "claimableRows": {
          "type": "integer",
          "minimum": 0
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nullableSha256": {
      "anyOf": [
        {
          "$ref": "#/$defs/sha256"
        },
        {
          "type": "null"
        }
      ]
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "command", "sourceRevision"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceRevision": {
          "type": "string",
          "minLength": 1
        },
        "artifactPath": {
          "type": "string"
        },
        "artifactSha256": {
          "$ref": "#/$defs/nullableSha256"
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shaderId",
        "sourceSha256",
        "target",
        "shaderStage",
        "doe",
        "tint",
        "comparability",
        "claimability"
      ],
      "properties": {
        "shaderId": {
          "type": "string",
          "minLength": 1
        },
        "sourceSha256": {
          "$ref": "#/$defs/sha256"
        },
        "target": {
          "type": "string",
          "enum": ["msl", "spirv", "dxil", "hlsl"]
        },
        "shaderStage": {
          "type": "string",
          "enum": ["compute", "vertex", "fragment", "mixed"]
        },
        "doe": {
          "$ref": "#/$defs/compilerResult"
        },
        "tint": {
          "$ref": "#/$defs/compilerResult"
        },
        "comparability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reasons"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["comparable", "diagnostic"]
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "claimability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reasons"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["claimable", "diagnostic"]
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "deltaPercent": {
              "type": "object",
              "additionalProperties": {
                "type": ["number", "null"]
              }
            }
          }
        }
      }
    },
    "compilerResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "diagnosticCode",
        "outputSha256",
        "irSha256",
        "validationStatus",
        "validationTool",
        "phaseTimingsNs",
        "receiptPath"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "failed", "unsupported"]
        },
        "diagnosticCode": {
          "type": "string"
        },
        "outputSha256": {
          "$ref": "#/$defs/nullableSha256"
        },
        "irSha256": {
          "$ref": "#/$defs/nullableSha256"
        },
        "validationStatus": {
          "type": "string",
          "enum": ["passed", "failed", "not_run"]
        },
        "validationTool": {
          "type": "string"
        },
        "phaseTimingsNs": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "receiptPath": {
          "type": "string"
        }
      }
    }
  }
}
