{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Backend Cutover Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "cutover", "rollback"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "cutover": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetLane", "defaultBackend", "requiredComparablePasses", "requiredClaimablePasses"],
      "properties": {
        "targetLane": { "type": "string", "minLength": 1 },
        "defaultBackend": { "type": "string", "enum": ["dawn_delegate", "doe_metal", "doe_vulkan", "doe_d3d12"] },
        "requiredComparablePasses": { "type": "integer", "minimum": 1 },
        "requiredClaimablePasses": { "type": "integer", "minimum": 1 },
        "requireRollbackRehearsal": { "type": "boolean" }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["switchName", "switchBackend", "requiredCiValidation"],
      "properties": {
        "switchName": { "type": "string", "minLength": 1 },
        "switchBackend": { "type": "string", "enum": ["dawn_delegate", "doe_metal", "doe_vulkan", "doe_d3d12"] },
        "requiredCiValidation": { "type": "boolean" }
      }
    }
  }
}
