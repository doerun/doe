{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "doe-tsir-semantic.schema.json",
  "title": "TSIR semantic contract",
  "description": "Stable across compiler policy iteration. Hashed into tsir.semanticDigest.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "frontendVersion", "functions", "rejections"],
  "properties": {
    "contractVersion": { "type": "integer", "const": 1 },
    "frontendVersion": { "type": "string" },
    "functions": {
      "type": "array",
      "items": { "$ref": "#/$defs/function" }
    },
    "rejections": {
      "type": "array",
      "items": { "$ref": "#/$defs/rejection" }
    }
  },
  "$defs": {
    "scalarKind": {
      "type": "string",
      "enum": ["f32", "f16", "bf16", "i32", "u32"]
    },
    "associativity": {
      "type": "string",
      "enum": ["strict_ordered", "associative_allowed"]
    },
    "nanInfPolicy": { "type": "string", "enum": ["propagate", "quiet_mask"] },
    "exactnessClass": {
      "type": "string",
      "enum": ["bit_exact_solo", "algorithm_exact", "tolerance_bounded"]
    },
    "algorithmExactInvariant": {
      "type": "string",
      "enum": [
        "reduction_order",
        "tree_shape",
        "accum_dtype",
        "associativity_grouping"
      ]
    },
    "exactness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class"],
      "properties": {
        "class": { "$ref": "#/$defs/exactnessClass" },
        "algorithmExactInvariants": {
          "type": "array",
          "items": { "$ref": "#/$defs/algorithmExactInvariant" }
        },
        "toleranceMetric": { "type": "string" },
        "toleranceEpsilon": { "type": "number" }
      }
    },
    "familyHint": {
      "type": "string",
      "enum": [
        "unknown",
        "elementwise",
        "reduction",
        "gather",
        "rms_norm",
        "fused_gemv",
        "tiled_matmul",
        "attention_decode",
        "attention_tiled",
        "rope",
        "dequant",
        "sample",
        "embed"
      ]
    },
    "collectiveKind": {
      "type": "string",
      "enum": [
        "subgroup_add",
        "subgroup_min",
        "subgroup_max",
        "subgroup_mul",
        "subgroup_broadcast",
        "subgroup_ballot",
        "subgroup_shuffle",
        "subgroup_exclusive_scan",
        "subgroup_inclusive_scan",
        "workgroup_barrier",
        "fabric_reduce",
        "fabric_broadcast",
        "fabric_allreduce"
      ]
    },
    "bodyOp": {
      "type": "string",
      "enum": ["unknown", "fused_gemv", "rms_norm", "gather"]
    },
    "bindingRole": {
      "type": "string",
      "enum": ["matrix", "vector", "input", "scale", "indices", "table", "output"]
    },
    "axisRole": {
      "type": "string",
      "enum": ["output", "reduction", "hidden", "token"]
    },
    "bodyBindingRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bindingIndex", "role"],
      "properties": {
        "bindingIndex": { "type": "integer", "minimum": 0 },
        "role": { "$ref": "#/$defs/bindingRole" }
      }
    },
    "bodyAxisRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axisIndex", "role"],
      "properties": {
        "axisIndex": { "type": "integer", "minimum": 0 },
        "role": { "$ref": "#/$defs/axisRole" }
      }
    },
    "rmsNormFormula": {
      "type": "string",
      "enum": ["sum_squares_mean_epsilon_rsqrt_scale"]
    },
    "rmsNormReductionTarget": {
      "type": "string",
      "enum": ["intermediate_scalar"]
    },
    "rmsNormEpsilonSource": {
      "type": "string",
      "enum": ["uniform_field", "literal_f32"]
    },
    "rmsNormEpsilon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "path", "literalF32"],
      "properties": {
        "source": { "$ref": "#/$defs/rmsNormEpsilonSource" },
        "path": { "type": "string" },
        "literalF32": { "type": ["number", "null"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "source": { "const": "uniform_field" } }
          },
          "then": {
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "literalF32": { "const": null }
            }
          }
        },
        {
          "if": {
            "properties": { "source": { "const": "literal_f32" } }
          },
          "then": {
            "properties": {
              "path": { "const": "" },
              "literalF32": { "type": "number" }
            }
          }
        }
      ]
    },
    "rmsNormBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epsilon", "formula", "hiddenExtentAxis", "reductionTarget"],
      "properties": {
        "epsilon": { "$ref": "#/$defs/rmsNormEpsilon" },
        "formula": { "$ref": "#/$defs/rmsNormFormula" },
        "hiddenExtentAxis": { "type": "integer", "minimum": 0 },
        "reductionTarget": { "$ref": "#/$defs/rmsNormReductionTarget" }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "bindingRoles", "axisRoles"],
      "properties": {
        "op": { "$ref": "#/$defs/bodyOp" },
        "bindingRoles": {
          "type": "array",
          "items": { "$ref": "#/$defs/bodyBindingRole" }
        },
        "axisRoles": {
          "type": "array",
          "items": { "$ref": "#/$defs/bodyAxisRole" }
        },
        "rmsNorm": { "$ref": "#/$defs/rmsNormBody" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "op": { "const": "rms_norm" } }
          },
          "then": { "required": ["rmsNorm"] },
          "else": { "not": { "required": ["rmsNorm"] } }
        }
      ]
    },
    "rejection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "nodePath", "detail"],
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "tsir_subgroup_unlowerable",
            "tsir_pe_budget_exhausted",
            "tsir_collective_not_representable",
            "tsir_dependence_unanalyzable",
            "tsir_source_not_affine",
            "tsir_target_unfit"
          ]
        },
        "nodePath": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "buffer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "group", "binding", "logicalShape", "elem", "readWrite"],
      "properties": {
        "name": { "type": "string" },
        "group": { "type": "integer", "minimum": 0 },
        "binding": { "type": "integer", "minimum": 0 },
        "logicalShape": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "elem": { "$ref": "#/$defs/scalarKind" },
        "readWrite": { "type": "boolean" }
      }
    },
    "axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "lowerBound", "upperBound", "step"],
      "properties": {
        "name": { "type": "string" },
        "lowerBound": { "type": "string" },
        "upperBound": { "type": "string" },
        "step": { "type": "string" }
      }
    },
    "reductionOp": {
      "type": "string",
      "enum": ["sum", "product", "min", "max"]
    },
    "reduction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "op", "contract", "targetBinding"],
      "properties": {
        "axis": { "type": "integer", "minimum": 0 },
        "op": { "$ref": "#/$defs/reductionOp" },
        "contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["accumulation", "associativity", "nanInf"],
          "properties": {
            "accumulation": { "$ref": "#/$defs/scalarKind" },
            "associativity": { "$ref": "#/$defs/associativity" },
            "nanInf": { "$ref": "#/$defs/nanInfPolicy" }
          }
        },
        "targetBinding": { "type": "integer", "minimum": 0 }
      }
    },
    "collective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "axis", "exactness", "dtype"],
      "properties": {
        "kind": { "$ref": "#/$defs/collectiveKind" },
        "axis": { "type": "integer" },
        "exactness": { "$ref": "#/$defs/exactness" },
        "dtype": { "$ref": "#/$defs/scalarKind" }
      }
    },
    "function": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "familyHint", "axes", "bindings", "body", "reductions", "collectives", "sourceDigest"],
      "properties": {
        "name": { "type": "string" },
        "familyHint": { "$ref": "#/$defs/familyHint" },
        "axes": { "type": "array", "items": { "$ref": "#/$defs/axis" } },
        "bindings": { "type": "array", "items": { "$ref": "#/$defs/buffer" } },
        "body": { "$ref": "#/$defs/body" },
        "reductions": { "type": "array", "items": { "$ref": "#/$defs/reduction" } },
        "collectives": { "type": "array", "items": { "$ref": "#/$defs/collective" } },
        "sourceDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
