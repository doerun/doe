{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Benchmark Cube Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "hostProfiles",
    "providerPairs",
    "surfaces",
    "workloadSets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "hostProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "displayName",
          "os",
          "arch"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "os": {
            "type": "string",
            "minLength": 1
          },
          "arch": {
            "type": "string",
            "minLength": 1
          },
          "backend": {
            "type": "string",
            "minLength": 1
          },
          "gpuVendor": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "providerPairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "surface",
          "displayName",
          "left",
          "right"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "surface": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "left": {
            "type": "string",
            "minLength": 1
          },
          "right": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "displayName",
          "maturity",
          "primarySupport",
          "defaultMissingStatus",
          "expectedHostProfiles",
          "providerPairs",
          "workloadSets",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "maturity": {
            "type": "string",
            "enum": [
              "primary",
              "secondary",
              "prototype"
            ]
          },
          "primarySupport": {
            "type": "string",
            "enum": [
              "backend",
              "node",
              "bun"
            ]
          },
          "defaultMissingStatus": {
            "type": "string",
            "enum": [
              "unsupported",
              "unimplemented",
              "diagnostic",
              "comparable",
              "claimable"
            ]
          },
          "expectedHostProfiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "providerPairs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "workloadSets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "workloadSets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "displayName",
          "domains"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
