{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doe-gpu.dev/config/numeric-stability-policy.schema.json",
  "title": "Doe numeric stability policy registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "registryVersion",
    "routeTaxonomyVersion",
    "proofArtifactPath",
    "defaultExecutionProfileId",
    "routeDecisions",
    "routeDecisionMetadata",
    "executionProfiles",
    "autoDetectProfiles",
    "triggerPolicies",
    "routingPolicies"
  ],
  "properties": {
    "schemaVersion": { "const": 3 },
    "registryVersion": { "type": "string", "minLength": 1 },
    "routeTaxonomyVersion": { "type": "string", "minLength": 1 },
    "proofArtifactPath": { "type": "string", "minLength": 1 },
    "defaultExecutionProfileId": { "type": "string", "minLength": 1 },
    "routeDecisions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": ["accept-fast", "prefer-stable", "abstain"]
      },
      "uniqueItems": true
    },
    "routeDecisionMetadata": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/routeDecisionMetadata" }
    },
    "executionProfiles": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/executionProfile" }
    },
    "autoDetectProfiles": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/autoDetectProfile" }
    },
    "triggerPolicies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/triggerPolicy" }
    },
    "routingPolicies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/routingPolicy" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "routeDecision": {
      "type": "string",
      "enum": ["accept-fast", "prefer-stable", "abstain"]
    },
    "selectionMode": {
      "type": "string",
      "enum": ["fast", "stable", "none"]
    },
    "committedResultMode": {
      "type": "string",
      "enum": ["fast", "stable", "none"]
    },
    "downstreamAction": {
      "type": "string",
      "enum": ["continue", "stop"]
    },
    "executionSurface": {
      "type": "string",
      "enum": ["ordinary-execution"]
    },
    "routeDecisionMetadata": {
      "type": "object",
      "required": [
        "decision",
        "selectionMode",
        "committedResultMode",
        "downstreamAction",
        "proofLinks"
      ],
      "properties": {
        "decision": { "$ref": "#/$defs/routeDecision" },
        "selectionMode": { "$ref": "#/$defs/selectionMode" },
        "committedResultMode": { "$ref": "#/$defs/committedResultMode" },
        "downstreamAction": { "$ref": "#/$defs/downstreamAction" },
        "proofLinks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proofLink" }
        }
      },
      "additionalProperties": false
    },
    "executionProfile": {
      "type": "object",
      "required": [
        "profileId",
        "surface",
        "description",
        "routingPolicyId"
      ],
      "properties": {
        "profileId": { "type": "string", "minLength": 1 },
        "surface": { "$ref": "#/$defs/executionSurface" },
        "description": { "type": "string", "minLength": 1 },
        "routingPolicyId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "autoDetectProfile": {
      "type": "object",
      "required": [
        "profileId",
        "enabled",
        "operatorFamily",
        "semanticOpId",
        "kernelBasenames",
        "triggerPolicyId",
        "routingPolicyId",
        "fastPolicyId",
        "stablePolicyId",
        "referencePolicyId",
        "capturePlanId",
        "decisionStrategyId"
      ],
      "properties": {
        "profileId": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "operatorFamily": { "type": "string", "minLength": 1 },
        "semanticOpId": { "type": "string", "minLength": 1 },
        "semanticStage": { "type": ["string", "null"], "minLength": 1 },
        "semanticPhase": { "type": ["string", "null"], "minLength": 1 },
        "kernelBasenames": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "triggerPolicyId": { "type": "string", "minLength": 1 },
        "routingPolicyId": { "type": "string", "minLength": 1 },
        "fastPolicyId": { "type": "string", "minLength": 1 },
        "stablePolicyId": { "type": "string", "minLength": 1 },
        "referencePolicyId": { "type": "string", "minLength": 1 },
        "capturePlanId": { "type": "string", "minLength": 1 },
        "decisionStrategyId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "triggerPolicy": {
      "type": "object",
      "required": [
        "triggerPolicyId",
        "requireFirstDivergence",
        "requireSelectedTokenDisagreement",
        "requireStableMatchesExactReference",
        "requireFastMissesExactReference",
        "allowedSensitiveOperators",
        "proofLinks"
      ],
      "properties": {
        "triggerPolicyId": { "type": "string", "minLength": 1 },
        "requireFirstDivergence": { "type": "boolean" },
        "requireSelectedTokenDisagreement": { "type": "boolean" },
        "requireStableMatchesExactReference": { "type": "boolean" },
        "requireFastMissesExactReference": { "type": "boolean" },
        "allowedSensitiveOperators": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "proofLinks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proofLink" }
        }
      },
      "additionalProperties": false
    },
    "routingPolicy": {
      "type": "object",
      "required": [
        "policyId",
        "triggerPolicyId",
        "triggeredDecision",
        "fallbackDecision",
        "proofLinks"
      ],
      "properties": {
        "policyId": { "type": "string", "minLength": 1 },
        "triggerPolicyId": { "type": "string", "minLength": 1 },
        "triggeredDecision": {
          "$ref": "#/$defs/routeDecision"
        },
        "fallbackDecision": {
          "$ref": "#/$defs/routeDecision"
        },
        "proofLinks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proofLink" }
        }
      },
      "additionalProperties": false
    },
    "proofLink": {
      "type": "object",
      "required": [
        "theorem",
        "module",
        "category",
        "relation",
        "artifactPath"
      ],
      "properties": {
        "theorem": { "type": "string", "minLength": 1 },
        "module": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "relation": { "type": "string", "minLength": 1 },
        "artifactPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
