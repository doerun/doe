{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fawn://config/browser-release-artifact-bundle.schema.json",
  "title": "Browser release artifact bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactKind",
    "bundleId",
    "releaseStatus",
    "browserBinary",
    "doeRuntime",
    "shaderCompiler",
    "contracts",
    "claimReports",
    "promotionReceipts",
    "policies",
    "failureCodes"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifactKind": { "type": "string", "const": "browser_release_artifact_bundle" },
    "bundleId": { "type": "string", "minLength": 1 },
    "releaseStatus": { "enum": ["diagnostic", "release_candidate"] },
    "browserBinary": { "$ref": "#/$defs/Artifact" },
    "doeRuntime": { "$ref": "#/$defs/Artifact" },
    "shaderCompiler": { "$ref": "#/$defs/Artifact" },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Artifact" }
    },
    "claimReports": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Artifact" }
    },
    "promotionReceipts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Artifact" }
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Artifact" }
    },
    "failureCodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Failure" }
    }
  },
  "$defs": {
    "Hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "Artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "kind"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/Hash" },
        "kind": { "type": "string", "minLength": 1 }
      }
    },
    "Failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
