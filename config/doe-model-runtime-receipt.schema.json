{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.doe.deco/doe-model-runtime-receipt.schema.json",
  "title": "Doe model runtime receipt",
  "description": "Binds execution manifest + host-plan + memory-plan + runtime-config + per-kernel CSL runtime fixtures into one artifact that answers 'can Doe run this model end-to-end'.",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactKind",
    "target",
    "modelId",
    "modelFamily",
    "grid",
    "residencyMode",
    "fits",
    "memorySummary",
    "artifactHashes",
    "kernels",
    "kernelCoverage",
    "phaseSummary",
    "laneStatus",
    "executionStatus",
    "executionBlocker"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "artifactKind": { "const": "doe_model_runtime_receipt" },
    "target": { "const": "wse3" },
    "modelId": { "type": "string", "minLength": 1 },
    "modelFamily": { "type": "string", "minLength": 1 },
    "modelConfig": { "type": "object" },
    "grid": {
      "type": "object",
      "required": ["width", "height", "peCount"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "peCount": { "type": "integer", "minimum": 1 }
      }
    },
    "residencyMode": {
      "type": "string",
      "enum": ["resident", "layer_streaming", "unknown"]
    },
    "fits": { "type": "boolean" },
    "memorySummary": {
      "type": "object",
      "required": [
        "totalModelBytes",
        "totalPersistentBytes",
        "totalStreamedBytes",
        "totalSramAvailable",
        "utilizationPct"
      ],
      "properties": {
        "totalModelBytes": { "type": "integer", "minimum": 0 },
        "totalPersistentBytes": { "type": "integer", "minimum": 0 },
        "totalStreamedBytes": { "type": "integer", "minimum": 0 },
        "totalSramAvailable": { "type": "integer", "minimum": 0 },
        "utilizationPct": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "artifactHashes": {
      "type": "object",
      "required": [
        "executionManifest",
        "hostPlan",
        "memoryPlan",
        "runtimeConfig",
        "simulatorPlan",
        "cslRuntimeFixtureRegistry"
      ],
      "additionalProperties": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "kernels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "pattern", "count", "runtimeStatus"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "pattern": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 1 },
          "runtimeStatus": {
            "type": "string",
            "enum": ["runtime_ready", "compile_ready", "missing", "unknown"]
          },
          "fixtureId": { "type": "string" },
          "reduceStrategy": {
            "type": "string",
            "enum": [
              "none",
              "on_device_fabric",
              "on_device_fabric_validated",
              "on_device_fabric_quarantined",
              "host_partial",
              "host_reduce_partial"
            ]
          },
          "reduceStrategyNote": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "kernelCoverage": {
      "type": "object",
      "required": ["total", "byStatus", "patternsCovered", "patternsMissing"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "byStatus": { "type": "object" },
        "patternsCovered": { "type": "array", "items": { "type": "string" } },
        "patternsMissing": { "type": "array", "items": { "type": "string" } }
      }
    },
    "phaseSummary": {
      "type": "object",
      "required": ["prefillLaunches", "decodeLaunches"],
      "properties": {
        "prefillLaunches": { "type": "integer", "minimum": 0 },
        "decodeLaunches": { "type": "integer", "minimum": 0 }
      }
    },
    "streamingMigration": {
      "type": "object",
      "description": "Derived fields that decide whether the simple memcpy RPC runtime path is sufficient or whether the SdkLayout streaming runtime (priority #6 — code regions, ports, streams, async send/receive, demux/mux, KV spill) must be adopted for this model. Computed from the memory plan + model config; no new memory-plan schema fields are required upstream.",
      "required": ["runtimePath", "streamingRuntimeRequired", "doubleBufferedFits", "numTransformerLayers"],
      "properties": {
        "perPeSramBudget": { "type": "integer", "minimum": 0 },
        "persistentBytesPerPe": { "type": "integer", "minimum": 0 },
        "streamedWorkingSetBytesPerPe": { "type": "integer", "minimum": 0 },
        "headroomBytesPerPe": { "type": "integer" },
        "kvCacheBytesPerPe": { "type": "integer", "minimum": 0 },
        "maxPerLayerStage": {
          "type": "object",
          "description": "Largest stream stage with repeatCount > 1 (per-transformer-layer). Double-buffering targets this stage.",
          "properties": {
            "name": { "type": "string" },
            "bytesPerPe": { "type": "integer", "minimum": 0 }
          }
        },
        "maxSetupStage": {
          "type": "object",
          "description": "Largest one-shot stream stage (repeatCount == 1). Loaded at init; not double-buffered.",
          "properties": {
            "name": { "type": "string" },
            "bytesPerPe": { "type": "integer", "minimum": 0 }
          }
        },
        "doubleBufferedWorkingSetPerPe": { "type": "integer", "minimum": 0 },
        "doubleBufferedFits": { "type": "boolean" },
        "numTransformerLayers": { "type": "integer", "minimum": 0 },
        "distinctLayerCompileShapes": { "type": "integer", "minimum": 0 },
        "compileArtifactReuseFactor": { "type": "integer", "minimum": 0 },
        "streamingRuntimeRequired": { "type": "boolean" },
        "runtimePath": {
          "type": "string",
          "enum": ["memcpy_rpc", "sdk_layout_streaming"]
        },
        "notes": { "type": "string" }
      }
    },
    "laneStatus": {
      "type": "string",
      "description": "Structural coverage — does every host-plan kernel resolve to a runtime-ready fixture, and does the memory plan fit? 'structural_full_coverage' does NOT mean the model executed end-to-end; that is captured separately in executionStatus. Kept alongside the legacy values so older receipts stay parseable.",
      "enum": [
        "structural_full_coverage",
        "structural_partial_coverage_kernel_gap",
        "structural_memory_plan_does_not_fit",
        "full_coverage",
        "partial_coverage_kernel_gap",
        "memory_plan_does_not_fit",
        "compile_failure",
        "runtime_failure"
      ]
    },
    "executionStatus": {
      "type": "string",
      "description": "Has this model been executed end-to-end through the simulator or hardware? Structural full-coverage is a precondition but not a proof of execution. 'real_weight_layer_block_success' is a stronger simulator-status variant: same as simulator_success, but the run consumed real Gemma-4 weight slices (syntheticWeightsAbsent=true) and the weightSetSha256 matched the fixture pin.",
      "enum": [
        "not_attempted",
        "simulator_success",
        "real_weight_layer_block_success",
        "simulator_failure",
        "hardware_success",
        "hardware_failure",
        "compile_failure"
      ]
    },
    "executionBlocker": {
      "type": "string",
      "description": "When executionStatus=not_attempted, names the missing prerequisite so follow-up work is explicit. 'none' means the model is ready to be executed. 'sdk_layout_streaming_executor_missing' and 'streaming_executor_not_bound_to_execution_plan' are legacy. The streaming-executor primitives exist on simfabric, and the layer-block runner now executes real pre-attn RMSNorm + scalar attention-inner-product + residual + post-attn RMSNorm + a gated MLP ReLU/GELU stub with all 3 streams flowing through compute. 'real_weights_absent' means the path to real_weight_layer_block_success is gated only on materialization of the --weights-dir contract.",
      "enum": [
        "none",
        "sdk_layout_streaming_executor_missing",
        "streaming_executor_not_bound_to_execution_plan",
        "cs_python_not_available_in_build_environment",
        "full_transformer_layer_block_incomplete",
        "hardware_endpoint_unavailable",
        "full_grid_compile_unattempted",
        "partial_kernel_coverage",
        "memory_plan_does_not_fit",
        "real_weights_absent",
        "real_weight_parity_failed"
      ]
    },
    "realWeightEvidence": {
      "type": "object",
      "description": "Optional block. When the external checkpoint-weight promotion artifact exists (not just synthetic data), this pins the fixture contract the run consumed, the weights-dir audit that validated the slice files, and the parity verdict that compared outputs across runtime lanes. Populated only when executionStatus is real_weight_layer_block_success or when executionBlocker names a real-weight-specific reason.",
      "properties": {
        "fixturePath": { "type": "string" },
        "fixtureSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "weightsDir": { "type": "string" },
        "weightsAuditPath": { "type": "string" },
        "weightSetSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "parityVerdictPath": { "type": "string" },
        "paritySummary": {
          "type": "object",
          "description": "Tolerance summary copied from the real-weight parity verdict so the model receipt is self-contained for claim checks.",
          "properties": {
            "outputDigestMatch": { "type": "boolean" },
            "tolerancePassed": { "type": "boolean" },
            "atol": { "type": "number", "minimum": 0 },
            "rtol": { "type": "number", "minimum": 0 },
            "layersCompared": { "type": "integer", "minimum": 0 },
            "maxAbsErrAcrossLayers": { "type": "number", "minimum": 0 },
            "maxRelErrAcrossLayers": { "type": "number", "minimum": 0 },
            "maxAllowedErrAcrossLayers": { "type": "number", "minimum": 0 },
            "meanAbsErrAcrossLayers": { "type": "number", "minimum": 0 }
          }
        },
        "promotionCriteriaMet": {
          "type": "object",
          "description": "Mirror of the parity verdict's 5 real-weight promotion criteria on the model-runtime receipt so downstream consumers see the honest status without cross-loading the parity file.",
          "properties": {
            "syntheticInputsAbsent": { "type": "boolean" },
            "syntheticWeightsAbsent": { "type": "boolean" },
            "weightHashMatched": { "type": "boolean" },
            "fullModelDepthExecuted": { "type": "boolean" },
            "outputParityPassed": { "type": "boolean" }
          }
        }
      }
    },
    "streamingExecutorPrimitivesEvidence": {
      "type": "object",
      "description": "Optional pointer block. When the SdkLayout streaming executor primitives (stream I/O, compute transform, region-to-region chain, multi-PE SPMD, compile cache, layer-block-shaped chain) have been proven on simfabric, this field lists where the traces live. Lets downstream consumers (e.g. the demo status page) show 'streaming executor primitives: pass' as a distinct row from 'full-model execution: blocked'.",
      "properties": {
        "description": { "type": "string" },
        "tracesDir": { "type": "string" },
        "tracesSample": { "type": "array", "items": { "type": "string" } },
        "primitivesProven": { "type": "array", "items": { "type": "string" } },
        "layerBlockKernelEvidence": {
          "type": "object",
          "description": "Positive simulator evidence for the generated E2B layer-block smoke runner. This does not by itself promote model-level executionStatus; it records which real layer stages have run under simfabric and what remains before a full model-level simulator_success claim is honest.",
          "properties": {
            "description": { "type": "string" },
            "kernelSourcePath": { "type": "string" },
            "kernelSourceSha256": { "type": "string" },
            "kernelIsStub": { "type": "boolean" },
            "kernelStage": { "type": "string" },
            "combineRule": { "type": "string" },
            "generatorPath": { "type": "string" },
            "generatedRunnerPath": { "type": "string" },
            "numericalParityTarget": { "type": "string" },
            "streamsExercisedInCompute": { "type": "array", "items": { "type": "string" } },
            "layerWeightsReshape": { "type": "string" },
            "pendingStages": { "type": "array", "items": { "type": "string" } },
            "tracePath": { "type": "string" },
            "traceSha256": { "type": "string" },
            "traceStatus": { "type": "string" },
            "executedRun": { "type": "object" }
          }
        }
      }
    },
    "sdkLayoutModelExecutionEvidence": {
      "type": "object",
      "description": "First-class model-level promotion block for the generated E2B SdkLayout layer-block smoke. This is narrower than full manifest-shape execution: it proves the generated SdkLayout program compiled and ran through local simfabric with direct-link send/receive telemetry, non-stub kernel identity, rt.stop completion, and parity evidence.",
      "required": [
        "promotionStatus",
        "claimScope",
        "streamExecutionPlan",
        "kernelSource",
        "regionPortStreamGraph",
        "hostIoLayout",
        "sendReceiveCounts",
        "hostSdkTelemetry",
        "simulatorArtifacts",
        "runtimeStop",
        "parity",
        "blockers",
        "remainingClaimBlockers"
      ],
      "properties": {
        "promotionStatus": {
          "type": "string",
          "enum": ["sdk_layout_layer_block_smoke_promoted", "blocked"]
        },
        "claimScope": { "type": "string", "minLength": 1 },
        "modelId": { "type": "string" },
        "executionStatusBinding": { "type": "string" },
        "streamExecutionPlan": {
          "type": "object",
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        },
        "kernelSource": {
          "type": "object",
          "required": ["path", "sha256", "kernelIsStub", "kernelStage"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "kernelIsStub": { "const": false },
            "kernelStage": { "type": "string", "minLength": 1 }
          }
        },
        "regionPortStreamGraph": {
          "type": "object",
          "required": [
            "targetMode",
            "regionName",
            "connectionGraph",
            "hostIoLayout",
            "ioBufferSizes",
            "sendReceiveCounts"
          ],
          "properties": {
            "targetMode": { "type": "string", "minLength": 1 },
            "regionName": { "type": "string", "minLength": 1 },
            "connectionGraph": { "type": "object" },
            "hostIoLayout": {
              "type": "array",
              "minItems": 4,
              "items": { "type": "object" }
            },
            "ioBufferSizes": { "type": "object" },
            "sendReceiveCounts": { "type": "object" }
          }
        },
        "hostIoLayout": {
          "type": "array",
          "minItems": 4,
          "items": { "type": "object" }
        },
        "sendReceiveCounts": {
          "type": "object",
          "required": ["sends", "receives"],
          "properties": {
            "sends": { "const": 3 },
            "receives": { "const": 1 }
          }
        },
        "hostSdkTelemetry": {
          "type": "object",
          "required": ["measurementSource", "streams", "streamEventsTailCount"],
          "properties": {
            "measurementSource": { "const": "host_sdk_task_handles" },
            "streams": {
              "type": "array",
              "minItems": 4,
              "items": { "type": "object" }
            },
            "streamEventsTailCount": { "type": "integer", "minimum": 1 }
          }
        },
        "simulatorArtifacts": {
          "type": "object",
          "required": ["compileDir", "trace", "output"],
          "properties": {
            "compileDir": {
              "type": "object",
              "required": ["path", "exists"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "exists": { "const": true },
                "fileCount": { "type": "integer", "minimum": 1 }
              }
            },
            "trace": {
              "type": "object",
              "required": ["path", "exists", "sha256"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "exists": { "const": true },
                "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
              }
            },
            "output": {
              "type": "object",
              "required": ["path", "exists", "sha256"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "exists": { "const": true },
                "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
              }
            },
            "runLogs": { "type": "array" },
            "coreFile": { "type": ["string", "null"] }
          }
        },
        "executedCompile": { "type": "object" },
        "executedRun": { "type": "object" },
        "runtimeStop": {
          "type": "object",
          "required": ["reached"],
          "properties": {
            "reached": { "const": true },
            "elapsedMs": { "type": ["number", "null"], "minimum": 0 },
            "error": { "type": ["string", "null"] }
          }
        },
        "parity": {
          "type": "object",
          "required": [
            "verdictPath",
            "verdictSha256",
            "verdict",
            "promotionEligible",
            "tolerancePassed"
          ],
          "properties": {
            "verdictPath": { "type": "string", "minLength": 1 },
            "verdictSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "verdict": { "type": "string", "minLength": 1 },
            "promotionEligible": { "const": true },
            "outputDigestMatch": { "type": "boolean" },
            "tolerancePassed": { "const": true },
            "layersCompared": { "type": "integer", "minimum": 1 },
            "maxAbsErrAcrossLayers": { "type": "number", "minimum": 0 },
            "maxAllowedErrAcrossLayers": { "type": "number", "minimum": 0 }
          }
        },
        "blockers": {
          "type": "array",
          "maxItems": 0,
          "items": { "type": "string" }
        },
        "remainingClaimBlockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "sdkLayoutDepthDiagnosticEvidence": {
      "type": "object",
      "description": "Model-level diagnostic block for full declared-depth E2B smoke-chain runs. This remains non-claimable until manifest-shape Doe/CSL runtime execution and hardware receipts land.",
      "required": [
        "status",
        "claimable",
        "claimScope",
        "declaredModelDepth",
        "manifestShapeRuntimeExecuted",
        "diagnostics",
        "blockers",
        "remainingClaimBlockers"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["full_depth_smoke_diagnostic_passed", "blocked"]
        },
        "claimable": { "const": false },
        "claimScope": { "type": "string", "minLength": 1 },
        "declaredModelDepth": { "const": 35 },
        "manifestShapeRuntimeExecuted": { "const": false },
        "diagnostics": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "sourceLabel",
              "numLayers",
              "claimable",
              "parity",
              "trace",
              "blockers"
            ],
            "properties": {
              "sourceLabel": {
                "type": "string",
                "enum": ["bf16_safetensors", "doppler_rdrr_q4k_int4ple"]
              },
              "numLayers": { "const": 35 },
              "claimable": { "const": false },
              "parity": {
                "type": "object",
                "required": ["path", "exists"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "exists": { "type": "boolean" },
                  "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                  "verdict": { "type": "string" },
                  "weightsSourceLabel": { "type": "string" },
                  "weightSetPinMode": { "type": "string" },
                  "weightsAudit": {
                    "type": "object",
                    "properties": {
                      "path": { "type": "string" },
                      "exists": { "type": "boolean" },
                      "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
                    }
                  },
                  "weightsDir": { "type": "string" },
                  "layersCompared": { "type": "integer", "minimum": 0 },
                  "tolerancePassed": { "type": "boolean" },
                  "maxAbsErrAcrossLayers": { "type": "number", "minimum": 0 },
                  "maxAllowedErrAcrossLayers": { "type": "number", "minimum": 0 },
                  "meanAbsErrAcrossLayers": { "type": "number", "minimum": 0 }
                }
              },
              "trace": {
                "type": "object",
                "required": ["path", "exists"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "exists": { "type": "boolean" },
                  "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                  "numLayersChained": { "type": "integer", "minimum": 0 },
                  "status": { "type": "string" },
                  "elapsedMs": { "type": "number", "minimum": 0 },
                  "runtimeStopReached": { "type": "boolean" },
                  "kernelIsStub": { "type": "boolean" },
                  "kernelStage": { "type": "string" },
                  "streamExecutionPlan": {
                    "type": "object",
                    "properties": {
                      "path": { "type": "string" },
                      "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
                    }
                  },
                  "sendReceiveCounts": {
                    "type": "object",
                    "properties": {
                      "sends": { "type": "integer" },
                      "receives": { "type": "integer" }
                    }
                  },
                  "hostIoLayout": {
                    "type": "array",
                    "items": { "type": "object" }
                  },
                  "hostSdkTelemetry": {
                    "type": "object",
                    "properties": {
                      "measurementSource": { "type": "string" },
                      "streamCount": { "type": "integer", "minimum": 0 },
                      "streamEventsTailCount": { "type": "integer", "minimum": 0 }
                    }
                  },
                  "output": {
                    "type": "object",
                    "properties": {
                      "path": { "type": "string" },
                      "exists": { "type": "boolean" },
                      "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
                    }
                  }
                }
              },
              "blockers": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "remainingClaimBlockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "fullGridCompileProbeEvidence": {
      "type": "object",
      "description": "Optional pointer to the cslc grid-probe aggregate documenting which PE counts cslc accepts for this arch. Captured once per repo; referenced by every model receipt so downstream consumers can correlate 'this model wants NN PEs' against 'cslc has been proven to handle up to MM PEs'.",
      "properties": {
        "description": { "type": "string" },
        "reportPath": { "type": "string" },
        "maxProvenPeCount1D": { "type": "integer", "minimum": 0 },
        "maxProvenPeCount2D": { "type": "integer", "minimum": 0 },
        "thirtyOneBFullGridCompileVerified": { "type": "boolean" },
        "thirtyOneBCompileSeconds2D": { "type": "number", "minimum": 0 }
      }
    },
    "chainParityEvidence": {
      "type": "object",
      "description": "Binds model-level chain-parity receipts to this model. Each chain-parity receipt proves that N specific kernels (of the model's host-plan patterns) compose end-to-end with bit-exact or bit-close numerical parity against numpy. The derived kernelPatternsChainProven array lists every classifier outcome that has appeared in at least one passing chain — it's the bridge between per-kernel parity (each kernel alone matches numpy) and model-level parity (the whole graph matches numpy).",
      "required": ["chains", "kernelPatternsChainProven", "kernelPatternsChainUnproven"],
      "properties": {
        "chains": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["chainName", "receiptPath", "kernelPatterns", "endToEndMaxAbsErr", "laneStatus"],
            "properties": {
              "chainName": { "type": "string" },
              "receiptPath": { "type": "string" },
              "kernelPatterns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "endToEndMaxAbsErr": { "type": "number", "minimum": 0 },
              "laneStatus": { "type": "string" }
            }
          }
        },
        "kernelPatternsChainProven": {
          "type": "array",
          "items": { "type": "string" },
