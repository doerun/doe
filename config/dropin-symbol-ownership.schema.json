{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Drop-in Symbol Ownership",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "symbols"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 3 },
    "tiers": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "minProperties": 1
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "owner"],
        "properties": {
          "symbol": { "type": "string", "pattern": "^wgpu[A-Za-z0-9_]+$" },
          "owner": { "type": "string", "enum": ["dawn_delegate", "doe_metal", "doe_vulkan", "doe_d3d12", "shared"] },
          "tier": { "type": "string", "enum": ["compute", "headless", "full"] }
        }
      }
    }
  }
}
