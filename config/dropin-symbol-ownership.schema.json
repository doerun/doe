{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Drop-in Symbol Ownership",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "symbols"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "owner", "requiredInStrict"],
        "properties": {
          "symbol": { "type": "string", "pattern": "^wgpu[A-Za-z0-9_]+$" },
          "owner": { "type": "string", "enum": ["dawn_oracle", "zig_metal", "zig_vulkan", "shared"] },
          "requiredInStrict": { "type": "boolean" }
        }
      }
    }
  }
}
