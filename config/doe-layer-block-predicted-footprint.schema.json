{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.doe.deco/doe-layer-block-predicted-footprint.schema.json",
  "title": "Doe layer-block predicted footprint",
  "description": "Per-pattern predicted cycle/byte footprint for one E2B layer block, derived from layerBlockSmoke.perKernelShapes + modelConfig. Baseline for predicted-vs-observed diffs against future simulator traces (plan Build-order step 3). Coarse prediction model — the interesting signal is divergence from observed, not prediction precision.",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactKind",
    "generatedFrom",
    "numLayers",
    "predictionModel",
    "perPattern",
    "aggregate"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "artifactKind": { "const": "doe_layer_block_predicted_footprint" },
    "generatedFrom": {
      "type": "object",
      "required": ["manifestPath", "manifestSha256"],
      "properties": {
        "tracePath": { "type": ["string", "null"] },
        "traceSha256": { "type": ["string", "null"] },
        "manifestPath": { "type": "string" },
        "manifestSha256": { "type": "string" },
        "shapesSource": { "type": "string", "enum": ["smoke_trace", "manifest_derived"] }
      }
    },
    "targetModel": { "type": "string", "enum": ["e2b", "31b"] },
    "modelId": { "type": "string" },
    "numLayers": { "type": "integer", "minimum": 0 },
    "predictionModel": {
      "type": "object",
      "required": ["name", "dtypeBytes", "cyclesPerElement"],
      "properties": {
        "name": { "type": "string" },
        "dtypeBytes": { "type": "integer", "minimum": 1 },
        "cyclesPerElement": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },
    "perPattern": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "object",
        "required": ["pattern", "invocationCount", "bytesPerPe", "cyclesPerPe"],
        "properties": {
          "pattern": { "type": "string" },
          "status": {
            "type": ["string", "null"],
            "enum": [
              null,
              "dormant_pattern_no_manifest_step",
              "audit_needs_deployment_generator"
            ]
          },
          "invocationCount": { "type": "integer", "minimum": 0 },
          "bytesPerPe": { "type": "integer", "minimum": 0 },
          "cyclesPerPe": { "type": "integer", "minimum": 0 },
          "invocations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["stepName", "elementsPerPe", "bytesPerPe", "cyclesPerPe"],
              "properties": {
                "stepName": { "type": "string" },
                "elementsPerPe": { "type": "integer", "minimum": 0 },
                "bytesPerPe": { "type": "integer", "minimum": 0 },
                "cyclesPerPe": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "predictedCslcParamsString": { "type": ["string", "null"] },
          "observedBytesPerPe": { "type": ["integer", "null"], "minimum": 0 },
          "observedCyclesPerPe": { "type": ["integer", "null"], "minimum": 0 },
          "predictedToObservedBytesRatio": { "type": ["number", "null"], "minimum": 0 },
          "observedFixtureEvidence": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": ["fixtureDir", "driverResultPath"],
                "properties": {
                  "fixtureDir": { "type": "string" },
                  "driverResultPath": { "type": "string" },
                  "driverResultSha256": { "type": "string" },
                  "observedCslcParamsString": { "type": ["string", "null"] },
                  "compileStatus": { "type": "string" },
                  "runStatus": { "type": "string" },
                  "tracePath": { "type": "string" },
                  "traceSha256": { "type": "string" },
                  "width": { "type": "integer" },
                  "chunkSize": { "type": "integer" },
                  "totalElements": { "type": "integer" },
                  "runtimePassed": { "type": "boolean" },
                  "runtimeMaxAbsErr": { "type": "number" }
                }
              }
            ]
          },
          "predictedMatchesObservedShape": { "type": ["boolean", "null"] },
          "divergenceClassification": {
            "type": ["string", "null"],
            "enum": [
              null,
              "exact_match",
              "expected_shape_divergence",
              "unexpected_divergence_formula_suspect"
            ]
          },
          "widthRatioHint": { "type": ["number", "null"], "minimum": 0 }
        }
      }
    },
    "aggregate": {
      "type": "object",
      "required": [
        "bytesPerLayerPerPe",
        "cyclesPerLayerPerPe",
        "bytesPerModelPerPe",
        "cyclesPerModelPerPe",
        "activePatternCount",
        "dormantPatternCount"
      ],
      "properties": {
        "bytesPerLayerPerPe": { "type": "integer", "minimum": 0 },
        "cyclesPerLayerPerPe": { "type": "integer", "minimum": 0 },
        "bytesPerModelPerPe": { "type": "integer", "minimum": 0 },
        "cyclesPerModelPerPe": { "type": "integer", "minimum": 0 },
        "activePatternCount": { "type": "integer", "minimum": 0 },
        "dormantPatternCount": { "type": "integer", "minimum": 0 },
        "observedEvidenceBoundCount": { "type": "integer", "minimum": 0 },
        "predictedMatchesObservedShapeCount": { "type": "integer", "minimum": 0 },
        "predictedToObservedBytesRatioSamples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pattern", "ratio"],
            "properties": {
              "pattern": { "type": "string" },
              "ratio": { "type": ["number", "null"], "minimum": 0 }
            }
          }
        },
        "divergenceClassificationTally": {
          "type": "object",
          "properties": {
            "exact_match": { "type": "integer", "minimum": 0 },
            "expected_shape_divergence": { "type": "integer", "minimum": 0 },
            "unexpected_divergence_formula_suspect": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
