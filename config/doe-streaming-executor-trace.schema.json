{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.doe.deco/doe-streaming-executor-trace.schema.json",
  "title": "Doe streaming-executor trace",
  "description": "Observed runtime trace from the SdkLayout streaming executor. Mirrors the dry-run trace shape so diff_dry_run_traces.py can compare predicted vs observed. Emitted by bench/runners/csl-runners/streaming_executor*.py, which builds a layout via SdkLayout, compiles, loads, runs send/receive against SdkLayout streams, and records wall clock + observed byte counts.",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactKind",
    "target",
    "executorIteration",
    "sourcePlan",
    "region",
    "executedCompile",
    "executedRun"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "artifactKind": { "const": "doe_streaming_executor_trace" },
    "target": { "const": "wse3" },
    "modelId": { "type": "string" },
    "executorIteration": {
      "type": "integer",
      "minimum": 1,
      "description": "Which iteration of the executor produced this trace. Iter-1 = compile+load+run+stop only. Iter-2 = real data flow via streams. Later iterations add multi-region, ring buffer, compile-artifact cache, KV spill."
    },
    "sourcePlan": {
      "type": "object",
      "required": ["kernelSourcePath"],
      "properties": {
        "streamGraphPath": { "type": "string" },
        "executionPlanPath": { "type": "string" },
        "kernelSourcePath": { "type": "string" }
      }
    },
    "region": {
      "type": "object",
      "required": ["regionId", "width", "height", "peCount"],
      "properties": {
        "regionId": { "type": "string" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "peCount": { "type": "integer", "minimum": 1 }
      }
    },
    "executedCompile": {
      "type": "object",
      "required": ["elapsedMs", "status"],
      "properties": {
        "compilePrefix": { "type": "string" },
        "elapsedMs": { "type": "number", "minimum": 0 },
        "status": { "type": "string", "enum": ["succeeded", "failed"] }
      }
    },
    "executedRun": {
      "type": "object",
      "required": ["status", "elapsedMs", "observedBytesTransferredTotal"],
      "properties": {
        "status": { "type": "string" },
        "elapsedMs": { "type": "number", "minimum": 0 },
        "observedBytesTransferredPerPe": { "type": "integer", "minimum": 0 },
        "observedBytesTransferredTotal": { "type": "integer", "minimum": 0 },
        "numericalParity": {
          "type": "object",
          "properties": {
            "maxAbsErr": { "type": "number" },
            "atol": { "type": "number", "minimum": 0 },
            "passed": { "type": "boolean" }
          }
        },
        "streams": {
          "type": "array",
          "description": "Per-stream host SDK task-handle telemetry for SdkLayout direct-link send/receive operations.",
          "items": {
            "type": "object",
            "required": [
              "streamId",
              "role",
              "operation",
              "issuedCount",
              "completedCount",
              "pendingCount",
              "maxQueueDepth",
              "droppedSendCount",
              "submissionFailureCount"
            ],
            "properties": {
              "streamId": { "type": "string" },
              "role": { "type": "string", "enum": ["input", "output"] },
              "operation": { "type": "string", "enum": ["send", "receive"] },
              "issuedCount": { "type": "integer", "minimum": 0 },
              "completedCount": { "type": "integer", "minimum": 0 },
              "pendingCount": { "type": "integer", "minimum": 0 },
              "maxQueueDepth": { "type": "integer", "minimum": 0 },
              "droppedSendCount": { "type": "integer", "minimum": 0 },
              "submissionFailureCount": { "type": "integer", "minimum": 0 },
              "doneBeforeWaitCount": { "type": "integer", "minimum": 0 },
              "taskWaitTotalMs": { "type": "number", "minimum": 0 },
              "taskWaitMaxMs": { "type": "number", "minimum": 0 },
              "lastErrorType": { "type": "string" },
              "lastErrorMessage": { "type": "string" }
            }
          }
        },
        "streamTelemetry": {
          "type": "object",
          "properties": {
            "measurementSource": { "type": "string" },
            "queueDepthDefinition": { "type": "string" },
            "droppedSendCountSource": { "type": "string" },
            "streamEventsTailCount": { "type": "integer", "minimum": 0 }
          }
        },
        "streamEventsTail": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "event",
              "streamId",
              "operation",
              "layerIndex",
              "pendingAfter"
            ],
            "properties": {
              "event": { "type": "string", "enum": ["issued", "completed"] },
              "streamId": { "type": "string" },
              "operation": { "type": "string", "enum": ["send", "receive"] },
              "layerIndex": { "type": "integer", "minimum": 0 },
              "pendingAfter": { "type": "integer", "minimum": 0 },
              "doneBeforeWait": { "type": ["boolean", "null"] },
              "taskWaitMs": { "type": "number", "minimum": 0 },
              "doneProbeError": { "type": "string" }
            }
          }
        },
        "failure": {
          "type": ["object", "null"],
          "properties": {
            "failedAtStage": { "type": "string" },
            "failedAtDispatchIndex": { "type": ["integer", "null"], "minimum": 0 },
            "lastActiveStreamId": { "type": ["string", "null"] },
            "lastActiveOperation": { "type": ["string", "null"] },
            "lastCompletedStreamSendReceive": { "type": ["object", "null"] },
            "streamCounters": { "type": "array" },
            "streamEventsTail": { "type": "array" },
            "errorType": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    },
    "streams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "color"],
        "properties": {
          "role": { "type": "string", "enum": ["input", "output"] },
          "color": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "dtype": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" },
    "layerBlockSmoke": {
      "type": "object",
      "description": "Plan step-1 layer-block smoke receipt emitted by bench/tools/generate_e2b_layer_block_runner.py. Carries the plan/kernel hashes, connection graph, hostIoLayout, io_buffer sizes, send/receive counts, simulator trace paths, target mode, and per-kernel --params shape emission for every emitter in runtime/zig/src/doe_wgsl/emit_csl_layout.zig. perKernelShapes has minItems:14 so schema_gate fails if the generator regresses any pattern's coverage.",
      "required": [
        "planPath",
        "planSha256",
        "kernelSourcePath",
        "kernelSourceSha256",
        "targetMode",
        "connectionGraph",
        "hostIoLayout",
        "ioBufferSizes",
        "sendReceiveCounts",
        "perKernelShapes"
      ],
      "properties": {
        "planPath": { "type": "string" },
        "planSha256": { "type": "string" },
        "layerIndex": { "type": "integer", "minimum": 0 },
        "regionName": { "type": "string" },
        "kernelSourcePath": { "type": "string" },
        "kernelSourceSha256": { "type": "string" },
        "kernelIsStub": { "type": "boolean" },
        "combineRule": { "type": "string" },
        "status": { "type": "string" },
        "targetMode": {
          "type": "string",
          "enum": [
            "local_simfabric",
            "direct_system_cmaddr",
            "wsc_appliance_simulator",
            "wsc_appliance_system"
          ]
        },
        "compileArtifactDir": { "type": "string" },
        "compileArtifactPrefix": { "type": "string" },
        "connectionGraph": {
          "type": "object",
          "required": ["region", "grid", "inputPorts", "outputPorts"],
          "properties": {
            "region": { "type": "string" },
            "grid": { "type": "object" },
            "inputPorts": { "type": "array" },
            "outputPorts": { "type": "array" },
            "crossRegionConnections": { "type": "array" }
          }
        },
        "hostIoLayout": {
          "type": "array",
          "items": { "type": "object" }
        },
        "ioBufferSizes": { "type": "object" },
        "sendReceiveCounts": {
          "type": "object",
          "required": ["sends", "receives"],
          "properties": {
            "sends": { "type": "integer", "minimum": 0 },
            "receives": { "type": "integer", "minimum": 0 }
          }
        },
        "simulatorArtifactPaths": { "type": "object" },
        "sourceModelReceiptPath": { "type": "string" },
        "perKernelShapes": {
          "type": "array",
          "minItems": 14,
          "description": "One entry per CSL emitter pub fn in emit_csl_layout.zig. Covers all 14 emitter patterns — schema_gate fails if the generator drops any. Each entry records the pattern, emitter, 2-D-widened status, one or more invocations with paramsShape + cslcParamsString, derivationSource pointer to the manifest-field derivation, and optional status (dormant_pattern_no_manifest_step / audit_needs_deployment_generator).",
          "items": {
            "type": "object",
            "required": ["pattern", "emitter", "emitterWidened2D"],
            "properties": {
              "pattern": { "type": "string" },
              "emitter": { "type": "string" },
              "emitterWidened2D": { "type": "boolean" },
              "paramsShape": { "type": "object" },
              "cslcParamsString": { "type": "string" },
              "derivationSource": { "type": "string" },
              "manifestSteps": { "type": "array", "items": { "type": "string" } },
              "status": {
                "type": "string",
                "enum": [
                  "dormant_pattern_no_manifest_step",
                  "audit_needs_deployment_generator"
                ]
              },
              "invocations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["cslcParamsString"],
                  "properties": {
                    "stepName": { "type": "string" },
                    "variant": { "type": "string" },
                    "paramsShape": { "type": "object" },
                    "cslcParamsString": { "type": "string" },
                    "weightMatrixShape": { "type": "string" },
                    "kvLenBound": { "type": "integer" },
                    "vocabSize": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "layerBlock": {
      "type": "object",
      "description": "Optional iter-7+ reporting on layer-block composition — which semantic stages the pipeline represents, what scale product the host should expect, and predicted-vs-observed byte accounting.",
      "properties": {
        "shape": { "type": "string" },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "scale"],
            "properties": {
              "name": { "type": "string" },
              "scale": { "type": "number" }
            }
          }
        },
        "expectedScaleProduct": { "type": "number" },
        "predictedFabricBytesTotal": { "type": "integer", "minimum": 0 },
        "predictedHostBytes": { "type": "integer", "minimum": 0 },
        "observedHostBytes": { "type": "integer", "minimum": 0 },
        "predictedMatchesObserved": { "type": "boolean" }
      }
    },
    "executorPrimitives": {
      "type": "object",
      "description": "Optional iter-6+ reporting on executor-level primitives (compile-artifact cache, ring-buffer prefetch) separately from the single-invocation executedCompile/executedRun measurements.",
      "properties": {
        "compileCache": {
          "type": "object",
          "properties": {
            "coldCompileMs": { "type": "number", "minimum": 0 },
            "coldRuntimeCtorMs": { "type": "number", "minimum": 0 },
            "coldPreRunMs": { "type": "number", "minimum": 0 },
            "warmSetupMs": { "type": "number", "minimum": 0 },
            "warmRuntimeCtorMs": { "type": "number", "minimum": 0 },
            "warmPreRunMs": { "type": "number", "minimum": 0 },
            "speedupRatioRaw": { "type": "number", "minimum": 0 },
            "speedupRatioEffective": { "type": "number", "minimum": 0 },
            "coldRunMs": { "type": "number", "minimum": 0 },
            "warmRunMs": { "type": "number", "minimum": 0 },
            "allBitExact": { "type": "boolean" }
          }
        },
        "ioBufferSizeKnob": {
          "type": "object",
          "properties": {
            "smallBytes": { "type": "integer", "minimum": 1 },
            "largeBytes": { "type": "integer", "minimum": 1 },
            "smallRunMs": { "type": "number", "minimum": 0 },
            "largeCompileMs": { "type": "number", "minimum": 0 },
            "largeRunMs": { "type": "number", "minimum": 0 },
            "bothBitExact": { "type": "boolean" }
          }
        },
        "wallMs": { "type": "number", "minimum": 0 }
      }
    }
  }
}
