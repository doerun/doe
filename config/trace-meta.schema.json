{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Trace Run Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "traceVersion",
    "module",
    "seqMax",
    "rowCount",
    "hash",
    "previousHash"
  ],
  "properties": {
    "traceVersion": { "type": "integer", "const": 1 },
    "module": { "type": "string" },
    "seqMax": { "type": "integer", "minimum": 0 },
    "rowCount": { "type": "integer", "minimum": 0 },
    "commandCount": { "type": "integer", "minimum": 0 },
    "matchedCount": { "type": "integer", "minimum": 0 },
    "blockingCount": { "type": "integer", "minimum": 0 },
    "requiresLeanCount": { "type": "integer", "minimum": 0 },
    "leanRequiredCount": { "type": "integer", "minimum": 0 },
    "hash": { "type": "string" },
    "previousHash": { "type": "string" },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "api", "driver"],
      "properties": {
        "vendor": { "type": "string" },
        "api": { "type": "string" },
        "deviceFamily": { "type": ["string", "null"] },
        "driver": { "type": "string" }
      }
    },
    "executionBackend": { "type": "string" },
    "backendId": { "type": "string" },
    "backendSelectionReason": { "type": "string" },
    "backendLane": { "type": "string" },
    "adapterOrdinal": { "type": "integer", "minimum": 0 },
    "adapterName": { "type": ["string", "null"] },
    "vendorId": { "type": ["string", "null"] },
    "deviceId": { "type": ["string", "null"] },
    "queueFamilyIndex": { "type": "integer", "minimum": 0 },
    "presentCapable": { "type": "boolean" },
    "fallbackUsed": { "type": "boolean" },
    "selectionPolicyHash": { "type": "string" },
    "shaderArtifactManifestPath": { "type": "string" },
    "shaderArtifactManifestHash": { "type": "string" },
    "hostPlanArtifactPath": { "type": "string" },
    "hostPlanArtifactHash": { "type": "string" },
    "queueSyncMode": { "type": "string" },
    "executionRowCount": { "type": "integer", "minimum": 0 },
    "executionSuccessCount": { "type": "integer", "minimum": 0 },
    "executionErrorCount": { "type": "integer", "minimum": 0 },
    "executionSkippedCount": { "type": "integer", "minimum": 0 },
    "executionUnsupportedCount": { "type": "integer", "minimum": 0 },
    "unsupportedCode": { "type": "string" },
    "unsupportedDetail": { "type": "string" },
    "executionTotalNs": { "type": "integer", "minimum": 0 },
    "executionSetupTotalNs": { "type": "integer", "minimum": 0 },
    "executionEncodeTotalNs": { "type": "integer", "minimum": 0 },
    "executionSubmitWaitTotalNs": { "type": "integer", "minimum": 0 },
    "executionDispatchCount": { "type": "integer", "minimum": 0 },
    "hostInputReadTotalNs": { "type": "integer", "minimum": 0 },
    "hostInputParseTotalNs": { "type": "integer", "minimum": 0 },
    "hostWorkloadPrepareTotalNs": { "type": "integer", "minimum": 0 },
    "hostExecutorInitTotalNs": { "type": "integer", "minimum": 0 },
    "hostUploadPrewarmTotalNs": { "type": "integer", "minimum": 0 },
    "hostKernelPrewarmTotalNs": { "type": "integer", "minimum": 0 },
    "hostCommandOrchestrationTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactFinalizeTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactTraceJsonlSerializeTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactTraceJsonlWriteTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactOperatorManifestFinalizeTotalNs": { "type": "integer", "minimum": 0 },
    "executionGpuTimestampTotalNs": { "type": "integer", "minimum": 0 },
    "executionGpuTimestampAttemptedCount": { "type": "integer", "minimum": 0 },
    "executionGpuTimestampValidCount": { "type": "integer", "minimum": 0 },
    "semanticTracingEnabled": { "type": "boolean" },
    "semanticOpRowCount": { "type": "integer", "minimum": 0 },
    "semanticCaptureCount": { "type": "integer", "minimum": 0 },
    "semanticReproCount": { "type": "integer", "minimum": 0 },
    "operatorRecordManifestPath": { "type": "string" },
    "operatorRecordManifestHash": { "type": "string" },
    "schema": { "type": "string" },
    "workload": { "type": "string" },
    "gtestFilter": { "type": "string" },
    "selectedFilter": { "type": "string" },
    "command": { "type": "string" },
    "timingSource": { "type": "string" },
    "timingClass": { "type": "string" },
    "timingMs": { "type": "number", "minimum": 0 },
    "elapsedMs": { "type": "number", "minimum": 0 },
    "processWallMs": { "type": "number", "minimum": 0 },
    "workloadUnitWallSource": {
      "type": "string",
      "enum": ["trace-meta-process-wall"]
    },
    "packagePreparedSession": { "type": "boolean" },
    "packageSetupIncludedInSelectedTiming": { "type": "boolean" },
    "packageSetupTotalNs": { "type": "integer", "minimum": 0 },
    "packageSetupBreakdownNs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bufferCreateTotalNs": { "type": "integer", "minimum": 0 },
        "initialDataWriteTotalNs": { "type": "integer", "minimum": 0 },
        "shaderModuleCreateTotalNs": { "type": "integer", "minimum": 0 },
        "bindGroupLayoutCreateTotalNs": { "type": "integer", "minimum": 0 },
        "pipelineLayoutCreateTotalNs": { "type": "integer", "minimum": 0 },
        "pipelineCreateTotalNs": { "type": "integer", "minimum": 0 },
        "bindGroupCreateTotalNs": { "type": "integer", "minimum": 0 }
      }
    },
    "packageStepBreakdownNs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "writeMaterializeTotalNs": { "type": "integer", "minimum": 0 },
        "writeQueueWriteTotalNs": { "type": "integer", "minimum": 0 },
        "dispatchEncodeApiTotalNs": { "type": "integer", "minimum": 0 },
        "copyEncodeApiTotalNs": { "type": "integer", "minimum": 0 },
        "submitCommandEncoderFinishTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueSubmitTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueWaitTotalNs": { "type": "integer", "minimum": 0 },
        "submitCommandPrepTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCallTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCommandReplayTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonQueueSubmitTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonFlushTotalNs": { "type": "integer", "minimum": 0 },
        "submitPostSubmitBookkeepingTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushWaitCompletedTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushDeferredCopyTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushDeferredResolveTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueWaitBookkeepingTotalNs": { "type": "integer", "minimum": 0 },
        "readbackTotalNs": { "type": "integer", "minimum": 0 }
      }
    },
    "determinism": {
      "oneOf": [
        { "$ref": "#/$defs/stableTokenDeterminismMeta" },
        { "$ref": "#/$defs/stableChoiceDeterminismMeta" },
        { "$ref": "#/$defs/reviewedChoiceDeterminismMeta" }
      ]
    },
    "numericStability": {
      "$ref": "#/$defs/numericStabilityMeta"
    },
    "benchmarkWallMsSamples": {
      "type": "array",
      "items": { "type": "number", "minimum": 0 }
    }
  },
  "$defs": {
    "determinismCommon": {
      "type": "object",
      "required": [
        "mode",
        "policyRegistryPath",
        "policyRegistryVersion",
        "comparator",
        "logitsSha256",
        "token",
        "proofArtifactPath",
        "proofTheorems"
      ],
      "properties": {
        "mode": { "type": "string" },
        "policyRegistryPath": { "type": "string", "minLength": 1 },
        "policyRegistryVersion": { "type": "string", "minLength": 1 },
        "comparator": { "const": "scalar-f32-greedy" },
        "logitsSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "token": { "type": "integer", "minimum": 0 },
        "proofArtifactPath": { "type": "string", "minLength": 1 },
        "proofTheorems": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stableTokenDeterminismMeta": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/determinismCommon" },
        {
          "type": "object",
          "required": ["policyId", "tieBreakRule", "selectedBy"],
          "properties": {
            "mode": { "const": "stable-token" },
            "policyId": { "type": "string", "minLength": 1 },
            "tieBreakRule": { "const": "lowest-index-among-max" },
            "selectedBy": { "const": "stable-token-policy" }
          }
        }
      ]
    },
    "stableChoiceDeterminismMeta": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/determinismCommon" },
        {
          "type": "object",
          "required": [
            "policyId",
            "baseRuleId",
            "evaluatorKind",
            "triggerPolicyId",
            "candidateSetId",
            "candidateSetSource",
            "selectedBy",
            "ambiguityTriggered",
            "ambiguityTopGap",
            "stableTokenToken"
          ],
          "properties": {
            "mode": { "const": "stable-choice" },
            "policyId": { "type": "string", "minLength": 1 },
            "baseRuleId": { "type": "string", "minLength": 1 },
            "evaluatorKind": { "const": "fixed-priority" },
            "triggerPolicyId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetSource": {
              "type": ["string", "null"],
              "enum": ["fixture-declared", "registry-resolved", "source-report-resolved", null]
            },
            "selectedBy": {
              "type": "string",
              "enum": ["stable-choice-policy", "stable-token-fallback"]
            },
            "ambiguityTriggered": { "type": "boolean" },
            "ambiguityTopGap": { "type": "number", "minimum": 0 },
            "stableTokenToken": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "reviewedChoiceDeterminismMeta": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/determinismCommon" },
        {
          "type": "object",
          "required": [
            "reviewPolicyId",
            "baseRuleId",
            "evaluatorKind",
            "triggerPolicyId",
            "candidateSetId",
            "candidateSetSource",
            "selectedBy",
            "ambiguityTriggered",
            "ambiguityTopGap",
            "stableTokenToken",
            "decisionAccepted",
            "decisionAcceptanceReason",
            "decisionToken",
            "decisionReviewerId"
          ],
          "properties": {
            "mode": { "const": "reviewed-choice" },
            "reviewPolicyId": { "type": "string", "minLength": 1 },
            "baseRuleId": { "type": "string", "minLength": 1 },
            "evaluatorKind": { "const": "explicit-review-decision" },
            "triggerPolicyId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetSource": {
              "type": ["string", "null"],
              "enum": ["fixture-declared", "registry-resolved", "source-report-resolved", null]
            },
            "selectedBy": {
              "type": "string",
              "enum": ["reviewed-choice-decision", "stable-token-fallback"]
            },
            "ambiguityTriggered": { "type": "boolean" },
            "ambiguityTopGap": { "type": "number", "minimum": 0 },
            "stableTokenToken": { "type": "integer", "minimum": 0 },
            "decisionAccepted": { "type": "boolean" },
            "decisionAcceptanceReason": {
              "type": "string",
              "enum": [
                "reviewed-choice-decision",
                "stable-token-fallback/not-triggered",
                "stable-token-fallback/not-in-candidate-set",
                "stable-token-fallback/not-ambiguous"
              ]
            },
            "decisionToken": { "type": "integer", "minimum": 0 },
            "decisionReviewerId": { "type": "string", "minLength": 1 },
            "decisionId": { "type": ["string", "null"], "minLength": 1 },
            "decisionRef": { "type": ["string", "null"], "minLength": 1 },
            "decisionSignature": { "type": ["string", "null"], "minLength": 1 }
          }
        }
      ]
    },
    "numericStabilityMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyRegistryPath",
        "policyRegistryVersion",
        "routeTaxonomyVersion",
        "receiptPath",
        "receiptCount",
        "decisionCounts",
        "firstDivergencePresentCount",
        "annotationCount",
        "autoDetectCount",
        "committedStableRewriteCount",
        "downstreamStopCount"
      ],
      "properties": {
        "policyRegistryPath": { "type": "string", "minLength": 1 },
        "policyRegistryVersion": { "type": "string", "minLength": 1 },
        "routeTaxonomyVersion": { "type": "string", "minLength": 1 },
        "executionProfileId": { "type": "string", "minLength": 1 },
        "receiptPath": { "type": "string", "minLength": 1 },
        "receiptCount": { "type": "integer", "minimum": 0 },
        "decisionCounts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["accept-fast", "prefer-stable", "abstain"],
          "properties": {
            "accept-fast": { "type": "integer", "minimum": 0 },
            "prefer-stable": { "type": "integer", "minimum": 0 },
            "abstain": { "type": "integer", "minimum": 0 }
          }
        },
        "firstDivergencePresentCount": { "type": "integer", "minimum": 0 },
        "annotationCount": { "type": "integer", "minimum": 0 },
        "autoDetectCount": { "type": "integer", "minimum": 0 },
        "committedStableRewriteCount": { "type": "integer", "minimum": 0 },
        "downstreamStopCount": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
