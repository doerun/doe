{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Trace Run Metadata",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    {
      "required": [
        "traceVersion",
        "module",
        "seqMax",
        "rowCount",
        "hash",
        "previousHash"
      ]
    },
    {
      "required": [
        "schemaVersion",
        "kind",
        "provider",
        "providerName",
        "executionBackend",
        "executionProvider",
        "executionProviderName",
        "executionRowCount",
        "executionSuccessCount",
        "executionErrorCount",
        "executionSkippedCount",
        "executionUnsupportedCount",
        "executionDispatchCount",
        "executionTotalNs",
        "executionSetupTotalNs",
        "executionEncodeTotalNs",
        "executionSubmitWaitTotalNs",
        "timingMs",
        "timingSource",
        "timingClass",
        "queueSyncMode",
        "queueWaitMode",
        "queueWaitScope",
        "queueWaitSubmitCadence",
        "workload",
        "canonicalWorkloadId",
        "planId",
        "planHash",
        "planSummary",
        "executionShape",
        "packagePreparedSession",
        "packageSetupIncludedInSelectedTiming",
        "packageSetupTotalNs",
        "packageSetupBreakdownNs",
        "packageStepBreakdownNs",
        "packageWriteBreakdown",
        "packageResidentBufferLoads",
        "packageResidentBufferLoadBreakdown",
        "packageReadbackMode",
        "samplesMs",
        "stats",
        "artifactHash"
      ],
      "properties": {
        "kind": { "const": "trace_meta" }
      }
    }
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "kind": { "type": "string" },
    "traceVersion": { "type": "integer", "const": 1 },
    "module": { "type": "string" },
    "seqMax": { "type": "integer", "minimum": 0 },
    "rowCount": { "type": "integer", "minimum": 0 },
    "commandCount": { "type": "integer", "minimum": 0 },
    "matchedCount": { "type": "integer", "minimum": 0 },
    "blockingCount": { "type": "integer", "minimum": 0 },
    "requiresLeanCount": { "type": "integer", "minimum": 0 },
    "leanRequiredCount": { "type": "integer", "minimum": 0 },
    "hash": { "type": "string" },
    "previousHash": { "type": "string" },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "api", "driver"],
      "properties": {
        "vendor": { "type": "string" },
        "api": { "type": "string" },
        "deviceFamily": { "type": ["string", "null"] },
        "driver": { "type": "string" }
      }
    },
    "executionBackend": { "type": "string" },
    "backendId": { "type": "string" },
    "backendSelectionReason": { "type": "string" },
    "backendLane": { "type": "string" },
    "adapterOrdinal": { "type": "integer", "minimum": 0 },
    "adapterName": { "type": ["string", "null"] },
    "vendorId": { "type": ["string", "null"] },
    "deviceId": { "type": ["string", "null"] },
    "queueFamilyIndex": { "type": "integer", "minimum": 0 },
    "presentCapable": { "type": "boolean" },
    "fallbackUsed": { "type": "boolean" },
    "selectionPolicyHash": { "type": "string" },
    "shaderArtifactManifestPath": { "type": "string" },
    "shaderArtifactManifestHash": { "type": "string" },
    "hostPlanArtifactPath": { "type": "string" },
    "hostPlanArtifactHash": { "type": "string" },
    "queueSyncMode": { "type": "string" },
    "queueWaitMode": { "type": "string" },
    "queueWaitScope": { "type": "string" },
    "queueWaitSubmitCadence": { "type": "integer", "minimum": 0 },
    "provider": { "type": "string" },
    "providerName": { "type": "string" },
    "executionProvider": { "type": "string" },
    "executionProviderName": { "type": "string" },
    "executionRowCount": { "type": "integer", "minimum": 0 },
    "executionSuccessCount": { "type": "integer", "minimum": 0 },
    "executionErrorCount": { "type": "integer", "minimum": 0 },
    "executionSkippedCount": { "type": "integer", "minimum": 0 },
    "executionUnsupportedCount": { "type": "integer", "minimum": 0 },
    "unsupportedCode": { "type": "string" },
    "unsupportedDetail": { "type": "string" },
    "executionTotalNs": { "type": "integer", "minimum": 0 },
    "executionSetupTotalNs": { "type": "integer", "minimum": 0 },
    "executionEncodeTotalNs": { "type": "integer", "minimum": 0 },
    "executionSubmitWaitTotalNs": { "type": "integer", "minimum": 0 },
    "executionDispatchCount": { "type": "integer", "minimum": 0 },
    "executionSubmitCount": { "type": "integer", "minimum": 0 },
    "hostInputReadTotalNs": { "type": "integer", "minimum": 0 },
    "hostInputParseTotalNs": { "type": "integer", "minimum": 0 },
    "hostWorkloadPrepareTotalNs": { "type": "integer", "minimum": 0 },
    "hostExecutorInitTotalNs": { "type": "integer", "minimum": 0 },
    "hostUploadPrewarmTotalNs": { "type": "integer", "minimum": 0 },
    "hostKernelPrewarmTotalNs": { "type": "integer", "minimum": 0 },
    "hostCommandOrchestrationTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactFinalizeTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactTraceJsonlSerializeTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactTraceJsonlWriteTotalNs": { "type": "integer", "minimum": 0 },
    "hostArtifactOperatorManifestFinalizeTotalNs": { "type": "integer", "minimum": 0 },
    "executionGpuTimestampTotalNs": { "type": "integer", "minimum": 0 },
    "executionGpuTimestampAttemptedCount": { "type": "integer", "minimum": 0 },
    "executionGpuTimestampValidCount": { "type": "integer", "minimum": 0 },
    "semanticTracingEnabled": { "type": "boolean" },
    "semanticOpRowCount": { "type": "integer", "minimum": 0 },
    "semanticCaptureCount": { "type": "integer", "minimum": 0 },
    "semanticReproCount": { "type": "integer", "minimum": 0 },
    "operatorRecordManifestPath": { "type": "string" },
    "operatorRecordManifestHash": { "type": "string" },
    "schema": { "type": "string" },
    "workload": { "type": "string" },
    "canonicalWorkloadId": { "type": "string" },
    "planId": { "type": "string" },
    "planHash": { "type": "string" },
    "artifactHash": { "type": "string" },
    "gtestFilter": { "type": "string" },
    "selectedFilter": { "type": "string" },
    "command": { "type": "string" },
    "timingSource": { "type": "string" },
    "timingClass": { "type": "string" },
    "timingMs": { "type": "number", "minimum": 0 },
    "elapsedMs": { "type": "number", "minimum": 0 },
    "processWallMs": { "type": "number", "minimum": 0 },
    "executionQueueSyncMode": { "type": "string" },
    "executionQueueWaitMode": { "type": "string" },
    "executionQueueWaitScope": { "type": "string" },
    "executionQueueWaitSubmitCadence": { "type": "integer", "minimum": 0 },
    "workloadUnitWallSource": {
      "type": "string",
      "enum": ["trace-meta-process-wall"]
    },
    "adapterInfo": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "adapterLimits": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "planSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "executionShape": {
      "type": "object",
      "additionalProperties": true
    },
    "samplesMs": {
      "type": "array",
      "items": { "type": "number", "minimum": 0 }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "min", "max", "median", "p95", "p99", "mean", "stdev"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 },
        "median": { "type": "number", "minimum": 0 },
        "p95": { "type": "number", "minimum": 0 },
        "p99": { "type": "number", "minimum": 0 },
        "mean": { "type": "number", "minimum": 0 },
        "stdev": { "type": "number", "minimum": 0 }
      }
    },
    "packagePreparedSession": { "type": "boolean" },
    "packageSetupIncludedInSelectedTiming": { "type": "boolean" },
    "packageResidentBufferLoads": { "type": "boolean" },
    "packageReadbackMode": {
      "type": "string",
      "enum": ["native-map-read-copy-unmap", "mapAsync"]
    },
    "packageSetupTotalNs": { "type": "integer", "minimum": 0 },
    "packageSetupBreakdownNs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bufferCreateTotalNs": { "type": "integer", "minimum": 0 },
        "initialDataWriteTotalNs": { "type": "integer", "minimum": 0 },
        "shaderModuleCreateTotalNs": { "type": "integer", "minimum": 0 },
        "bindGroupLayoutCreateTotalNs": { "type": "integer", "minimum": 0 },
        "pipelineLayoutCreateTotalNs": { "type": "integer", "minimum": 0 },
        "pipelineCreateTotalNs": { "type": "integer", "minimum": 0 },
        "bindGroupCreateTotalNs": { "type": "integer", "minimum": 0 }
      }
    },
    "packageStepBreakdownNs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "writeMaterializeTotalNs": { "type": "integer", "minimum": 0 },
        "writeQueueWriteTotalNs": { "type": "integer", "minimum": 0 },
        "dispatchEncodeApiTotalNs": { "type": "integer", "minimum": 0 },
        "copyEncodeApiTotalNs": { "type": "integer", "minimum": 0 },
        "submitCommandEncoderFinishTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueSubmitTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueWaitTotalNs": { "type": "integer", "minimum": 0 },
        "submitCommandPrepTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCallTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonCommandReplayTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonQueueSubmitTotalNs": { "type": "integer", "minimum": 0 },
        "submitAddonFlushTotalNs": { "type": "integer", "minimum": 0 },
        "submitPostSubmitBookkeepingTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushWaitCompletedTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushDeferredCopyTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueFlushDeferredResolveTotalNs": { "type": "integer", "minimum": 0 },
        "submitQueueWaitBookkeepingTotalNs": { "type": "integer", "minimum": 0 },
        "readbackTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapQueueWaitCompletedTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapDeferredCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapDeferredResolveTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapMapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapReadCopyUnmapUnmapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackMapAsyncTotalNs": { "type": "integer", "minimum": 0 },
        "readbackGetMappedRangeTotalNs": { "type": "integer", "minimum": 0 },
        "readbackHostCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackNativeReadCopyTotalNs": { "type": "integer", "minimum": 0 },
        "readbackUnmapTotalNs": { "type": "integer", "minimum": 0 },
        "readbackValidationTotalNs": { "type": "integer", "minimum": 0 },
        "readbackCaptureTotalNs": { "type": "integer", "minimum": 0 }
      }
    },
    "packageWriteBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalCount",
        "totalBytes",
        "staticBufferLoadCount",
        "staticBufferLoadBytes",
        "dynamicWriteCount",
        "dynamicWriteBytes",
        "byDataKind",
        "bySemanticPhase"
      ],
      "properties": {
        "totalCount": { "type": "integer", "minimum": 0 },
        "totalBytes": { "type": "integer", "minimum": 0 },
        "staticBufferLoadCount": { "type": "integer", "minimum": 0 },
        "staticBufferLoadBytes": { "type": "integer", "minimum": 0 },
        "dynamicWriteCount": { "type": "integer", "minimum": 0 },
        "dynamicWriteBytes": { "type": "integer", "minimum": 0 },
        "unbatchedWriteCount": { "type": "integer", "minimum": 0 },
        "batchCallCount": { "type": "integer", "minimum": 0 },
        "batchedWriteCount": { "type": "integer", "minimum": 0 },
        "batchMethod": { "type": "string" },
        "byDataKind": { "$ref": "#/$defs/packageWriteBuckets" },
        "bySemanticPhase": { "$ref": "#/$defs/packageWriteBuckets" }
      }
    },
    "packageResidentBufferLoadBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "bytes",
        "materializeTotalNs",
        "queueWriteTotalNs",
        "queueWaitTotalNs"
      ],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 },
        "materializeTotalNs": { "type": "integer", "minimum": 0 },
        "queueWriteTotalNs": { "type": "integer", "minimum": 0 },
        "queueWaitTotalNs": { "type": "integer", "minimum": 0 }
      }
    },
    "packageFastPathStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dispatchFlush",
        "flushAndMap",
        "commandBufferBuild"
      ],
      "properties": {
        "dispatchFlush": { "type": "integer", "minimum": 0 },
        "flushAndMap": { "type": "integer", "minimum": 0 },
        "commandBufferBuild": { "type": "integer", "minimum": 0 }
      }
    },
    "packageNativeFastPaths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appleFastPathCompiled",
        "queueFlush",
        "queueFlushBreakdown",
        "computeDispatchFlush",
        "computeDispatchFlushBreakdown",
        "computeDispatchBatchFlush",
        "computeDispatchBatchCopyFlush",
        "computeDispatchBatchCopyFlushBreakdown",
        "bufferMapReadCopyUnmap"
      ],
      "properties": {
        "appleFastPathCompiled": { "type": "boolean" },
        "queueFlush": { "type": "boolean" },
        "queueFlushBreakdown": { "type": "boolean" },
        "computeDispatchFlush": { "type": "boolean" },
        "computeDispatchFlushBreakdown": { "type": "boolean" },
        "computeDispatchBatchFlush": { "type": "boolean" },
        "computeDispatchBatchCopyFlush": { "type": "boolean" },
        "computeDispatchBatchCopyFlushBreakdown": { "type": "boolean" },
        "bufferMapReadCopyUnmap": { "type": "boolean" }
      }
    },
    "readbackCaptures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repeatIndex",
          "stepIndex",
          "stepId",
          "byteLength",
          "sha256"
        ],
        "properties": {
          "repeatIndex": { "type": "integer", "minimum": 0 },
          "stepIndex": { "type": "integer", "minimum": 0 },
          "stepId": { "type": "string", "minLength": 1 },
          "bufferId": { "type": "string", "minLength": 1 },
          "byteLength": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "decodedU32Le": { "type": "integer", "minimum": 0 },
          "semanticOpId": { "type": "string", "minLength": 1 },
          "semanticStage": { "type": "string", "minLength": 1 },
          "semanticPhase": { "type": "string", "minLength": 1 },
          "semanticTokenIndex": { "type": "integer", "minimum": 0 },
          "semanticLayerIndex": { "type": "integer", "minimum": 0 },
          "semanticExecutionPlanHash": { "type": "string", "minLength": 1 },
          "captureSourceBufferId": { "type": "string", "minLength": 1 },
          "captureOffset": { "type": "integer", "minimum": 0 },
          "captureSize": { "type": "integer", "minimum": 1 },
          "captureDecode": { "type": "string", "minLength": 1 }
        }
      }
    },
    "determinism": {
      "oneOf": [
        { "$ref": "#/$defs/stableTokenDeterminismMeta" },
        { "$ref": "#/$defs/stableChoiceDeterminismMeta" },
        { "$ref": "#/$defs/reviewedChoiceDeterminismMeta" }
      ]
    },
    "numericStability": {
      "$ref": "#/$defs/numericStabilityMeta"
    },
    "benchmarkWallMsSamples": {
      "type": "array",
      "items": { "type": "number", "minimum": 0 }
    }
  },
  "$defs": {
    "packageWriteBuckets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["count", "bytes"],
        "properties": {
          "count": { "type": "integer", "minimum": 0 },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "determinismCommon": {
      "type": "object",
      "required": [
        "mode",
        "policyRegistryPath",
        "policyRegistryVersion",
        "comparator",
        "logitsSha256",
        "token",
        "proofArtifactPath",
        "proofTheorems"
      ],
      "properties": {
        "mode": { "type": "string" },
        "policyRegistryPath": { "type": "string", "minLength": 1 },
        "policyRegistryVersion": { "type": "string", "minLength": 1 },
        "comparator": { "const": "scalar-f32-greedy" },
        "logitsSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "token": { "type": "integer", "minimum": 0 },
        "proofArtifactPath": { "type": "string", "minLength": 1 },
        "proofTheorems": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stableTokenDeterminismMeta": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/determinismCommon" },
        {
          "type": "object",
          "required": ["policyId", "tieBreakRule", "selectedBy"],
          "properties": {
            "mode": { "const": "stable-token" },
            "policyId": { "type": "string", "minLength": 1 },
            "tieBreakRule": { "const": "lowest-index-among-max" },
            "selectedBy": { "const": "stable-token-policy" }
          }
        }
      ]
    },
    "stableChoiceDeterminismMeta": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/determinismCommon" },
        {
          "type": "object",
          "required": [
            "policyId",
            "baseRuleId",
            "evaluatorKind",
            "triggerPolicyId",
            "candidateSetId",
            "candidateSetSource",
            "selectedBy",
            "ambiguityTriggered",
            "ambiguityTopGap",
            "stableTokenToken"
          ],
          "properties": {
            "mode": { "const": "stable-choice" },
            "policyId": { "type": "string", "minLength": 1 },
            "baseRuleId": { "type": "string", "minLength": 1 },
            "evaluatorKind": { "const": "fixed-priority" },
            "triggerPolicyId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetSource": {
              "type": ["string", "null"],
              "enum": ["fixture-declared", "registry-resolved", "source-report-resolved", null]
            },
            "selectedBy": {
              "type": "string",
              "enum": ["stable-choice-policy", "stable-token-fallback"]
            },
            "ambiguityTriggered": { "type": "boolean" },
            "ambiguityTopGap": { "type": "number", "minimum": 0 },
            "stableTokenToken": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "reviewedChoiceDeterminismMeta": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/determinismCommon" },
        {
          "type": "object",
          "required": [
            "reviewPolicyId",
            "baseRuleId",
            "evaluatorKind",
            "triggerPolicyId",
            "candidateSetId",
            "candidateSetSource",
            "selectedBy",
            "ambiguityTriggered",
            "ambiguityTopGap",
            "stableTokenToken",
            "decisionAccepted",
            "decisionAcceptanceReason",
            "decisionToken",
            "decisionReviewerId"
          ],
          "properties": {
            "mode": { "const": "reviewed-choice" },
            "reviewPolicyId": { "type": "string", "minLength": 1 },
            "baseRuleId": { "type": "string", "minLength": 1 },
            "evaluatorKind": { "const": "explicit-review-decision" },
            "triggerPolicyId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetId": { "type": ["string", "null"], "minLength": 1 },
            "candidateSetSource": {
              "type": ["string", "null"],
              "enum": ["fixture-declared", "registry-resolved", "source-report-resolved", null]
            },
            "selectedBy": {
              "type": "string",
              "enum": ["reviewed-choice-decision", "stable-token-fallback"]
            },
            "ambiguityTriggered": { "type": "boolean" },
            "ambiguityTopGap": { "type": "number", "minimum": 0 },
            "stableTokenToken": { "type": "integer", "minimum": 0 },
            "decisionAccepted": { "type": "boolean" },
            "decisionAcceptanceReason": {
              "type": "string",
              "enum": [
                "reviewed-choice-decision",
                "stable-token-fallback/not-triggered",
                "stable-token-fallback/not-in-candidate-set",
                "stable-token-fallback/not-ambiguous"
              ]
            },
            "decisionToken": { "type": "integer", "minimum": 0 },
            "decisionReviewerId": { "type": "string", "minLength": 1 },
            "decisionId": { "type": ["string", "null"], "minLength": 1 },
            "decisionRef": { "type": ["string", "null"], "minLength": 1 },
            "decisionSignature": { "type": ["string", "null"], "minLength": 1 }
          }
        }
      ]
    },
    "numericStabilityMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyRegistryPath",
        "policyRegistryVersion",
        "routeTaxonomyVersion",
        "receiptPath",
        "receiptCount",
        "decisionCounts",
        "firstDivergencePresentCount",
        "annotationCount",
        "autoDetectCount",
        "committedStableRewriteCount",
        "downstreamStopCount"
      ],
      "properties": {
        "policyRegistryPath": { "type": "string", "minLength": 1 },
        "policyRegistryVersion": { "type": "string", "minLength": 1 },
        "routeTaxonomyVersion": { "type": "string", "minLength": 1 },
        "executionProfileId": { "type": "string", "minLength": 1 },
        "receiptPath": { "type": "string", "minLength": 1 },
        "receiptCount": { "type": "integer", "minimum": 0 },
        "decisionCounts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["accept-fast", "prefer-stable", "abstain"],
          "properties": {
            "accept-fast": { "type": "integer", "minimum": 0 },
            "prefer-stable": { "type": "integer", "minimum": 0 },
            "abstain": { "type": "integer", "minimum": 0 }
          }
        },
        "firstDivergencePresentCount": { "type": "integer", "minimum": 0 },
        "annotationCount": { "type": "integer", "minimum": 0 },
        "autoDetectCount": { "type": "integer", "minimum": 0 },
        "committedStableRewriteCount": { "type": "integer", "minimum": 0 },
        "downstreamStopCount": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
