{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doe-gpu.dev/config/doe-numeric-stability-receipt.schema.json",
  "title": "Doe numeric stability receipt",
  "type": "object",
  "required": [
    "schemaVersion",
    "mode",
    "operatorFamily",
    "semanticOpId",
    "semanticStage",
    "semanticPhase",
    "policyRegistryPath",
    "policyRegistryVersion",
    "routeTaxonomyVersion",
    "proofArtifactPath",
    "triggerPolicyId",
    "routingPolicyId",
    "fastPolicyId",
    "stablePolicyId",
    "referencePolicyId",
    "candidates",
    "executionIdentity",
    "selectedToken",
    "trigger",
    "route"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "mode": { "const": "numeric-stability" },
    "operatorFamily": { "type": "string", "minLength": 1 },
    "semanticOpId": { "type": "string", "minLength": 1 },
    "semanticStage": { "type": "string", "minLength": 1 },
    "semanticPhase": { "type": "string", "minLength": 1 },
    "policyRegistryPath": { "type": "string", "minLength": 1 },
    "policyRegistryVersion": { "type": "string", "minLength": 1 },
    "routeTaxonomyVersion": { "type": "string", "minLength": 1 },
    "proofArtifactPath": { "type": "string", "minLength": 1 },
    "triggerPolicyId": { "type": "string", "minLength": 1 },
    "routingPolicyId": { "type": "string", "minLength": 1 },
    "fastPolicyId": { "type": "string", "minLength": 1 },
    "stablePolicyId": { "type": "string", "minLength": 1 },
    "referencePolicyId": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "executionIdentity": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/executionIdentity" }
      ]
    },
    "firstDivergence": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/firstDivergence" }
      ]
    },
    "decodeBoundary": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/decodeBoundary" }
      ]
    },
    "selectedToken": { "$ref": "#/$defs/selectedToken" },
    "trigger": { "$ref": "#/$defs/trigger" },
    "route": { "$ref": "#/$defs/route" }
  },
  "additionalProperties": false,
  "$defs": {
    "candidate": {
      "type": "object",
      "required": [
        "tokenId",
        "fastLogit",
        "stableLogit",
        "referenceLogit"
      ],
      "properties": {
        "tokenId": { "type": "integer", "minimum": 0 },
        "label": { "type": ["string", "null"] },
        "fastLogit": { "type": "number" },
        "stableLogit": { "type": "number" },
        "referenceLogit": { "type": "number" }
      },
      "additionalProperties": false
    },
    "firstDivergence": {
      "type": "object",
      "required": [
        "semanticOpId",
        "semanticStage",
        "semanticPhase",
        "fastDigest",
        "stableDigest"
      ],
      "properties": {
        "semanticOpId": { "type": "string", "minLength": 1 },
        "semanticStage": { "type": "string", "minLength": 1 },
        "semanticPhase": { "type": "string", "minLength": 1 },
        "fastDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "stableDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "selectedToken": {
      "type": "object",
      "required": [
        "fast",
        "stable",
        "reference",
        "fastMatchesReference",
        "stableMatchesReference"
      ],
      "properties": {
        "fast": { "type": "integer", "minimum": 0 },
        "stable": { "type": "integer", "minimum": 0 },
        "reference": { "type": "integer", "minimum": 0 },
        "fastMatchesReference": { "type": "boolean" },
        "stableMatchesReference": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "triggerChecks": {
      "type": "object",
      "required": [
        "firstDivergencePresent",
        "sensitiveOperatorMatched",
        "selectedTokenDisagreement",
        "stableMatchesExactReference",
        "fastMissesExactReference"
      ],
      "properties": {
        "firstDivergencePresent": { "type": "boolean" },
        "sensitiveOperatorMatched": { "type": "boolean" },
        "selectedTokenDisagreement": { "type": "boolean" },
        "stableMatchesExactReference": { "type": "boolean" },
        "fastMissesExactReference": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "trigger": {
      "type": "object",
      "required": ["fired", "checks", "proofLinks"],
      "properties": {
        "fired": { "type": "boolean" },
        "checks": { "$ref": "#/$defs/triggerChecks" },
        "proofLinks": {
          "type": "array",
          "items": { "$ref": "#/$defs/proofLink" }
        }
      },
      "additionalProperties": false
    },
    "route": {
      "type": "object",
      "required": [
        "decision",
        "selectionMode",
        "committedResultMode",
        "downstreamAction",
        "effectApplied",
        "proofLinks",
        "selectionProofLinks"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["accept-fast", "prefer-stable", "abstain"]
        },
        "selectionMode": {
          "type": "string",
          "enum": ["fast", "stable", "none"]
        },
        "committedResultMode": {
          "type": "string",
          "enum": ["fast", "stable", "none"]
        },
        "downstreamAction": {
          "type": "string",
          "enum": ["continue", "stop"]
        },
        "effectApplied": { "type": "boolean" },
        "selectedPolicyId": { "type": ["string", "null"] },
        "selectedToken": { "type": ["integer", "null"], "minimum": 0 },
        "proofLinks": {
          "type": "array",
          "items": { "$ref": "#/$defs/proofLink" }
        },
        "selectionProofLinks": {
          "type": "array",
          "items": { "$ref": "#/$defs/proofLink" }
        }
      },
      "additionalProperties": false
    },
    "executionIdentity": {
      "type": "object",
      "required": [
        "kernelPath",
        "kernelBasename",
        "layoutFingerprint",
        "compiledPlanHash",
        "backend",
        "backendLane",
        "adapterOrdinal",
        "queueFamilyIndex",
        "presentCapable",
        "profileVendor",
        "profileApi",
        "profileFamily",
        "profileDriver",
        "selectionPolicyHash",
        "hostPlanArtifactHash"
      ],
      "properties": {
        "kernelPath": { "type": ["string", "null"], "minLength": 1 },
        "kernelBasename": { "type": ["string", "null"], "minLength": 1 },
        "layoutFingerprint": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "compiledPlanHash": { "type": ["string", "null"], "minLength": 1 },
        "backend": { "type": ["string", "null"], "minLength": 1 },
        "backendLane": { "type": ["string", "null"], "minLength": 1 },
        "adapterOrdinal": { "type": ["integer", "null"], "minimum": 0 },
        "queueFamilyIndex": { "type": ["integer", "null"], "minimum": 0 },
        "presentCapable": { "type": ["boolean", "null"] },
        "profileVendor": { "type": ["string", "null"], "minLength": 1 },
        "profileApi": { "type": ["string", "null"], "minLength": 1 },
        "profileFamily": { "type": ["string", "null"], "minLength": 1 },
        "profileDriver": { "type": ["string", "null"], "minLength": 1 },
        "selectionPolicyHash": { "type": ["string", "null"], "minLength": 1 },
        "hostPlanArtifactHash": { "type": ["string", "null"], "minLength": 1 }
      },
      "additionalProperties": false
    },
    "upstreamReceiptLink": {
      "type": "object",
      "required": [
        "semanticOpId",
        "semanticStage",
        "semanticPhase",
        "decision"
      ],
      "properties": {
        "semanticOpId": { "type": "string", "minLength": 1 },
        "semanticStage": { "type": "string", "minLength": 1 },
        "semanticPhase": { "type": "string", "minLength": 1 },
        "selectedPolicyId": { "type": ["string", "null"] },
        "decision": {
          "type": "string",
          "enum": ["accept-fast", "prefer-stable", "abstain"]
        }
      },
      "additionalProperties": false
    },
    "decodeBoundary": {
      "type": "object",
      "required": [
        "decodeMode",
        "logitsCoverage",
        "vocabSize",
        "survivingTokenSetKind",
        "liveSelectedToken",
        "liveSelectedMatchesCommittedSelection",
        "metrics",
        "upstreamLinks"
      ],
      "properties": {
        "decodeMode": { "type": "string", "minLength": 1 },
        "logitsCoverage": { "type": "string", "minLength": 1 },
        "vocabSize": { "type": "integer", "minimum": 1 },
        "residualMassUpperBound": { "type": ["number", "null"] },
        "temperature": { "type": ["number", "null"] },
        "topK": { "type": ["integer", "null"], "minimum": 1 },
        "topP": { "type": ["number", "null"] },
        "rngSeed": { "type": ["integer", "null"], "minimum": 0 },
        "rngDraw": { "type": ["number", "null"] },
        "survivingTokenSetKind": { "type": "string", "minLength": 1 },
        "survivingTokenIds": {
          "type": ["array", "null"],
          "items": { "type": "integer", "minimum": 0 }
        },
        "liveSelectedToken": { "type": "integer", "minimum": 0 },
        "liveSelectedMatchesCommittedSelection": { "type": "boolean" },
        "metrics": {
          "type": "object",
          "required": [
            "fastTop1Margin",
            "stableTop1Margin",
            "referenceTop1Margin",
            "actualSelectedTokenChanged",
            "liveSelectedMatchesFast",
            "liveSelectedMatchesStable",
            "liveSelectedMatchesReference"
          ],
          "properties": {
            "fastTop1Margin": { "type": "number" },
            "stableTop1Margin": { "type": "number" },
            "referenceTop1Margin": { "type": "number" },
            "topKBoundaryGap": { "type": ["number", "null"] },
            "topPBoundaryGap": { "type": ["number", "null"] },
            "cdfDistanceToDraw": { "type": ["number", "null"] },
            "adjacentDecodePersistence": { "type": ["integer", "null"], "minimum": 0 },
            "actualSelectedTokenChanged": { "type": "boolean" },
            "liveSelectedMatchesFast": { "type": "boolean" },
            "liveSelectedMatchesStable": { "type": "boolean" },
            "liveSelectedMatchesReference": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "upstreamLinks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/upstreamReceiptLink" }
        }
      },
      "additionalProperties": false
    },
    "proofLink": {
      "type": "object",
      "required": [
        "theorem",
        "module",
        "category",
        "relation",
        "artifactPath"
      ],
      "properties": {
        "theorem": { "type": "string", "minLength": 1 },
        "module": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "relation": { "type": "string", "minLength": 1 },
        "artifactPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
