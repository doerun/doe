  "laneContracts": {
    "doe_csl": {
      "description": "Every Doppler/WGSL operator routed toward the CSL lane must terminate in exactly one of three outcomes: (1) supported CSL pattern with emitted HostPlan and CSL artifacts; (2) explicit csl_unsupported_* receipt carrying a code from `unsupportedCodes`; (3) hard compiler or runtime failure whose code matches one of the prefixes in `failureCodePatterns` (populated after SDK v1.4 diagnostics surface the concrete failure shapes). No fourth path: no Cerebras-only fork, no silent fallback, no directional promotion.",
      "unsupportedCodes": [
        "csl_unsupported_pattern",
        "csl_unsupported_shader_stage",
        "csl_unsupported_builtin",
        "csl_unrecognized_compute_pattern"
      ],
      "failureCodePatterns": [
        "csl_compile_*",
        "csl_simulator_run_*"
      ]
    }
  }
