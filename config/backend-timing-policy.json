{
  "schemaVersion": 1,
  "domains": {
    "upload": {
      "requiredTimingClass": "operation",
      "allowedTimingSources": [
        "doe-execution-row-total-ns",
        "doe-execution-row-total-ns+ignore-first-ops",
        "dawn-perf-wall-time",
        "dawn-perf-cpu-time",
        "dawn-perf-gpu-time",
        "dawn-perf-wall-ns"
      ],
      "allowedTimingSourcesByBackendId": {
        "doe_vulkan": [
          "doe-execution-dispatch-window-ns"
        ],
        "doe_d3d12": [
          "doe-execution-dispatch-window-ns"
        ],
        "dawn_delegate": [
          "doe-execution-dispatch-window-ns"
        ]
      },
      "requiredSyncModel": "deferred",
      "requireUploadIgnoreFirstSource": "doe-execution-row-total-ns"
    },
    "compute": {
      "requiredTimingClass": "operation",
      "allowedTimingSources": [
        "doe-execution-dispatch-window-ns",
        "doe-execution-total-ns",
        "doe-execution-gpu-timestamp-ns",
        "dawn-perf-wall-time",
        "dawn-perf-cpu-time",
        "dawn-perf-gpu-time",
        "dawn-perf-wall-ns"
      ],
      "requiredSyncModel": "per-command"
    },
    "render": {
      "requiredTimingClass": "operation",
      "allowedTimingSources": [
        "doe-execution-dispatch-window-ns",
        "doe-execution-encode-ns",
        "doe-execution-total-ns",
        "dawn-perf-wall-time",
        "dawn-perf-cpu-time",
        "dawn-perf-gpu-time",
        "dawn-perf-wall-ns"
      ],
      "allowedTimingSourcesByBackendId": {
        "dawn_delegate": [
          "doe-execution-encode-ns"
        ]
      },
      "requiredSyncModel": "per-command"
    },
    "render-bundle": {
      "requiredTimingClass": "operation",
      "allowedTimingSources": [
        "doe-execution-dispatch-window-ns",
        "doe-execution-encode-ns",
        "doe-execution-total-ns",
        "dawn-perf-wall-time",
        "dawn-perf-cpu-time",
        "dawn-perf-gpu-time",
        "dawn-perf-wall-ns"
      ],
      "allowedTimingSourcesByBackendId": {
        "dawn_delegate": [
          "doe-execution-encode-ns"
        ]
      },
      "requiredSyncModel": "per-command"
    },
    "surface": {
      "requiredTimingClass": "operation",
      "allowedTimingSources": [
        "doe-execution-total-ns",
        "dawn-perf-wall-time",
        "dawn-perf-cpu-time",
        "dawn-perf-gpu-time",
        "dawn-perf-wall-ns"
      ],
      "requiredSyncModel": "per-command"
    }
  }
}
