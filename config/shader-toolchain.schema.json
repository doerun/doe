{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fawn Shader Toolchain Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "platforms"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "platforms": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/platformContract" }
    }
  },
  "$defs": {
    "platformContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backends"],
      "properties": {
        "backends": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "doe_metal": { "$ref": "#/$defs/backendContract" },
            "doe_vulkan": { "$ref": "#/$defs/backendContract" },
            "doe_d3d12": { "$ref": "#/$defs/backendContract" }
          }
        }
      }
    },
    "backendContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredStages"],
      "properties": {
        "requiredStages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/toolStage" }
        },
        "optionalStages": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolStage" }
        }
      }
    },
    "toolStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "implementation"],
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "wgsl_parse",
            "sema",
            "ir_build",
            "ir_validate",
            "ir_to_msl",
            "msl_compile",
            "metallib_link",
            "ir_to_spirv",
            "spirv_validate",
            "ir_to_dxil",
            "dxil_validate"
          ]
        },
        "implementation": {
          "type": "string",
          "enum": ["native_zig", "external_tool"]
        },
        "tool": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } }
      },
      "allOf": [
        {
          "if": {
            "properties": { "implementation": { "const": "external_tool" } },
            "required": ["implementation"]
          },
          "then": { "required": ["tool", "version", "args"] }
        }
      ]
    }
  }
}
