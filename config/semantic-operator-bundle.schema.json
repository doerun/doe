{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doe semantic operator bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "source",
    "mode",
    "createdAt",
    "anchorPath",
    "provider",
    "providerInfo",
    "reportInfo",
    "divergence",
    "summary",
    "recordCount",
    "timeline"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "source": { "type": "string", "const": "doe-gpu" },
    "mode": { "type": "string" },
    "createdAt": { "type": "string" },
    "anchorPath": { "type": ["string", "null"] },
    "provider": { "type": ["string", "null"] },
    "providerInfo": { "type": ["object", "null"] },
    "reportInfo": { "type": ["object", "null"] },
    "divergence": { "type": ["object", "null"] },
    "summary": { "type": ["object", "null"] },
    "recordCount": { "type": "integer", "minimum": 0 },
    "timeline": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
