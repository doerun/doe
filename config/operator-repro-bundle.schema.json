{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doe operator repro bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reproMode",
    "bitwise",
    "commandsPath",
    "command",
    "semanticOpId",
    "profile",
    "execution",
    "commandShape"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "reproMode": { "type": "string", "const": "structural_same_device_backend" },
    "bitwise": { "type": "boolean", "const": false },
    "commandsPath": { "type": "string" },
    "command": { "type": "string" },
    "kernel": { "type": "string" },
    "semanticOpId": { "type": "string" },
    "semanticStage": { "type": "string" },
    "semanticPhase": { "type": "string" },
    "semanticTokenIndex": { "type": "integer", "minimum": 0 },
    "semanticLayerIndex": { "type": "integer", "minimum": 0 },
    "semanticExecutionPlanHash": { "type": "string" },
    "profile": { "type": "object" },
    "execution": { "type": ["object", "null"] },
    "commandShape": { "type": "object" }
  }
}
