{
  "workloads": "bench/workloads.apple.metal.extended.json",
  "left": {
    "name": "doe",
    "commandTemplate": "zig/zig-out/bin/doe-zig-runtime --commands {commands} --quirks {quirks} --vendor {vendor} --api {api} --family {family} --driver {driver} --backend native --backend-lane metal_local_comparable --execute --trace --queue-sync-mode {queue_sync_mode} --upload-buffer-usage {upload_buffer_usage} --upload-submit-every {upload_submit_every} --trace-jsonl {trace_jsonl} --trace-meta {trace_meta} {extra_args}"
  },
  "right": {
    "name": "dawn",
    "commandTemplate": "python3 bench/dawn_benchmark_adapter.py --dawn-state bench/dawn_runtime_state.json --dawn-filter-map bench/dawn_workload_map.local.autodiscover.json --workload {workload} --dawn-extra-args=--backend=metal --dawn-extra-args=--adapter-vendor-id=0x106b --queue-sync-mode {queue_sync_mode} --upload-buffer-usage {upload_buffer_usage} --upload-submit-every {upload_submit_every} --trace-jsonl {trace_jsonl} --trace-meta {trace_meta}"
  },
  "run": {
    "iterations": 8,
    "warmup": 1,
    "out": "bench/out/dawn-vs-doe.apple.metal.extended.comparable.json",
    "workspace": "bench/out/runtime-comparisons.apple.metal.extended.comparable",
    "workloadFilter": "",
    "includeExtendedWorkloads": true,
    "includeNoncomparableWorkloads": false,
    "emitShell": false
  },
  "comparability": {
    "mode": "strict",
    "requireTimingClass": "operation",
    "allowLeftNoExecution": false
  },
  "claimability": {
    "mode": "local",
    "minTimedSamples": 7
  },
  "resource": {
    "probe": "none",
    "sampleMs": 100,
    "sampleTargetCount": 0
  }
}
