{
  "scenarioId": "apple_metal_sample_only_tie_break_brakes_safe_unsafe_gemma270m",
  "description": "Apple Metal sample-only tie-break probe for a real Gemma 270M logits receipt from the prompt 'Driving without brakes is safe or unsafe. It is', with a controlled exact tie between the semantic answer tokens ' not' and ' safe'.",
  "kernelRoot": "bench/inference-pipeline/kernels",
  "profile": {
    "vendor": "apple",
    "api": "metal",
    "family": "m3",
    "driver": "1.0.0"
  },
  "queueWaitMode": "process-events",
  "queueSyncMode": "per-command",
  "sourceCases": [
    {
      "promptId": "brakes-safe-unsafe",
      "phase": "prefill",
      "stepIndex": 0
    }
  ],
  "doeStableToken": {
    "mode": "buffer-readback",
    "topCandidates": 5
  },
  "backendLanes": [
    {
      "id": "doe",
      "backendLane": "metal_doe_comparable"
    },
    {
      "id": "dawn",
      "backendLane": "metal_dawn_release"
    }
  ],
  "defaultRunCount": 10,
  "defaultCaseCount": 1,
  "mutations": [
    { "id": "as-captured", "kind": "identity" },
    {
      "id": "force-not-safe-exact-tie",
      "kind": "explicit_tokens_exact_tie",
      "tokenTexts": [" not", " safe"]
    }
  ]
}
