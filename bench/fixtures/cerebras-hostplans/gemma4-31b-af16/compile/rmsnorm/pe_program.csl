param memcpy_params;
param hidden_size: i16 = 1024;
const sys_mod = @import_module("<memcpy/memcpy>", memcpy_params);
const math = @import_module("<math>");
fn sqrt_nr(x: f16) f16 {
    const y0: f16 = math.sqrt(x);
    return 0.5 * (y0 + x / y0);
}

var input: [hidden_size]f16 = @zeros([hidden_size]f16);
var weight: [hidden_size]f16 = @zeros([hidden_size]f16);
var output: [hidden_size]f16 = @zeros([hidden_size]f16);
var output_chunk_0000: [128]u32 = @zeros([128]u32);
var output_chunk_0001: [128]u32 = @zeros([128]u32);
