var output_chunk_0018: [128]u32 = @zeros([128]u32);
var output_chunk_0019: [128]u32 = @zeros([128]u32);
var output_chunk_0020: [128]u32 = @zeros([128]u32);
var input_ptr: [*]f16 = &input;
var weight_ptr: [*]f16 = &weight;
var output_ptr: [*]f16 = &output;
var output_chunk_0000_ptr: [*]u32 = &output_chunk_0000;
var output_chunk_0001_ptr: [*]u32 = &output_chunk_0001;
