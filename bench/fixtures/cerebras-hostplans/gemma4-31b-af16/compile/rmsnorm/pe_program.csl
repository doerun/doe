    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1664;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0013[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0013[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1792;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0014[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0014[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1920;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0015[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0015[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 2048;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0016[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0016[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 2176;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0017[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0017[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 2304;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0018[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0018[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 2432;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0019[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0019[@as(u32, word)] = 0;
