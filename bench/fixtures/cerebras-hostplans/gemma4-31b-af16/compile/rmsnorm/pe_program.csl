var output_chunk_0014_ptr: [*]u32 = &output_chunk_0014;
var output_chunk_0015_ptr: [*]u32 = &output_chunk_0015;
var output_chunk_0016_ptr: [*]u32 = &output_chunk_0016;
var output_chunk_0017_ptr: [*]u32 = &output_chunk_0017;
var output_chunk_0018_ptr: [*]u32 = &output_chunk_0018;
var output_chunk_0019_ptr: [*]u32 = &output_chunk_0019;
var output_chunk_0020_ptr: [*]u32 = &output_chunk_0020;

fn compute() void {
    var sum_sq: f16 = 0.0;
    for (@range(i16, hidden_size)) |i| {
        const v = input[@as(u32, i)];
        sum_sq += v * v;
    }
    const mean_sq = sum_sq / @as(f16, hidden_size);
    const inv_rms = 1.0 / sqrt_nr(mean_sq + 0.000001);
    for (@range(i16, hidden_size)) |d| {
        output[@as(u32, d)] = input[@as(u32, d)] * inv_rms * (1.0 + weight[@as(u32, d)]);
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 0;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0000[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0000[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 128;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0001[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0001[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 256;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0002[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0002[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 384;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0003[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0003[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 512;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0004[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0004[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 640;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0005[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0005[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 768;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0006[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0006[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 896;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0007[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0007[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1024;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0008[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0008[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1152;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0009[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0009[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1280;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0010[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0010[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1408;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0011[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0011[@as(u32, word)] = 0;
        }
    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 1536;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0012[@as(u32, word)] = lo | (hi << 16);
