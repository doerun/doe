    }
    for (@range(i16, 128)) |word| {
        const pair = @as(u32, word) + 2560;
        const base = pair * 2;
        if (base + 1 < @as(u32, hidden_size)) {
            const lo: u32 = @as(u32, @bitcast(u16, output[base]));
            const hi: u32 = @as(u32, @bitcast(u16, output[base + 1]));
            output_chunk_0020[@as(u32, word)] = lo | (hi << 16);
        } else {
            output_chunk_0020[@as(u32, word)] = 0;
        }
    }
    sys_mod.unblock_cmd_stream();
}

comptime {
    @export_symbol(input_ptr, "input");
    @export_symbol(weight_ptr, "weight");
    @export_symbol(output_ptr, "output");
