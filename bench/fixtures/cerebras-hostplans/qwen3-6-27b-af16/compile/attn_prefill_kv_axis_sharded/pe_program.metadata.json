  "compileTimeConstants": [
    {"kind":"const","name":"head_dim","type":"i16","expr":"256"},
    {"kind":"const","name":"query_seq_len","type":"u32","expr":"8"},
    {"kind":"const","name":"attn_scale","type":"f16","expr":"6.25e-2"},
    {"kind":"const","name":"local_kv_len","type":"u32","expr":"@as(u32, slots_per_pe) * @as(u32, head_dim)"},
