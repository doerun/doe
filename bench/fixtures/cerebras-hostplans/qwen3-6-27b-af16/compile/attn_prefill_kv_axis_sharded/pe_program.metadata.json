    {"kind":"const","name":"pe_id","type":"u32","expr":"@as(u32, pe_y) * @as(u32, width) + @as(u32, pe_x)"},
    {"kind":"const","name":"slot_base","type":"u32","expr":"@as(u32, pe_id) * @as(u32, slots_per_pe)"},
    {"kind":"const","name":"q_row_offset","type":"u32","expr":"q * @as(u32, head_dim)"},
    {"kind":"const","name":"out_row_offset","type":"u32","expr":"q * partials_len"},
    {"kind":"const","name":"q_pos","type":"u32","expr":"@as(u32, kv_len) - query_seq_len + q"},
    {"kind":"const","name":"gk","type":"u32","expr":"slot_base + @as(u32, k)"}
  ]
