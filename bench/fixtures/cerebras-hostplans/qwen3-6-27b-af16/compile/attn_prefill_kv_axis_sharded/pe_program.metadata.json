  "pointers": [
    {"name":"query_ptr","backing":"query","elemType":"f16"},
    {"name":"key_ptr","backing":"key","elemType":"f16"},
    {"name":"value_ptr","backing":"value","elemType":"f16"},
    {"name":"output_ptr","backing":"output","elemType":"f16"}
  ],
  "exports": [
    {"symbol":"query","pointer":"query_ptr","backing":"query","sizeExpr":"query_seq_len * @as(u32, head_dim)","elemType":"f16"},
    {"symbol":"key","pointer":"key_ptr","backing":"key","sizeExpr":"local_kv_len","elemType":"f16"},
    {"symbol":"value","pointer":"value_ptr","backing":"value","sizeExpr":"local_kv_len","elemType":"f16"},
    {"symbol":"output","pointer":"output_ptr","backing":"output","sizeExpr":"query_seq_len * partials_len","elemType":"f16"}
