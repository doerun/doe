{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doe benchmark IR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "scenarios"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "shared": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kernelRoot": {
          "type": "string",
          "minLength": 1
        },
        "timingScope": {
          "type": "string",
          "minLength": 1
        },
        "syntheticReadonlyBufferPolicy": {
          "$ref": "#/$defs/syntheticReadonlyBufferPolicy"
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "planPath",
        "commandsPath",
        "commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "planPath": {
          "type": "string",
          "minLength": 1
        },
        "commandsPath": {
          "type": "string",
          "minLength": 1
        },
        "irPath": {
          "type": "string",
          "minLength": 1
        },
        "timingScope": {
          "type": "string",
          "minLength": 1
        },
        "matmulGemvVariant": {
          "type": "string",
          "enum": [
            "default",
            "row2_helper_exact"
          ]
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/command"
          }
        }
      }
    },
    "syntheticReadonlyBufferPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cacheNamespace",
        "generator",
        "seed"
      ],
      "properties": {
        "cacheNamespace": {
          "type": "string",
          "minLength": 1
        },
        "generator": {
          "type": "string",
          "enum": [
            "splitmix64_f16_nonzero_v1",
            "splitmix64_f32_nonzero_v1"
          ]
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "scale": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
