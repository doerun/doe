{
  "workloads": "bench/workloads/workloads.local.d3d12.json",
  "left": {
    "name": "doe",
    "commandTemplate": "runtime/zig/zig-out/bin/doe-zig-runtime.exe --commands {commands} --quirks {quirks} --vendor {vendor} --api {api} --family {family} --driver {driver} --backend native --backend-lane d3d12_doe_release --execute --trace --queue-sync-mode {queue_sync_mode} --upload-buffer-usage {upload_buffer_usage} --upload-submit-every {upload_submit_every} --trace-jsonl {trace_jsonl} --trace-meta {trace_meta} {extra_args}"
  },
  "right": {
    "name": "dawn_delegate",
    "commandTemplate": "runtime/zig/zig-out/bin/doe-zig-runtime.exe --commands {commands} --quirks {quirks} --vendor {vendor} --api {api} --family {family} --driver {driver} --backend native --backend-lane d3d12_dawn_release --execute --trace --queue-sync-mode {queue_sync_mode} --upload-buffer-usage {upload_buffer_usage} --upload-submit-every {upload_submit_every} --trace-jsonl {trace_jsonl} --trace-meta {trace_meta} {extra_args}"
  },
  "run": {
    "iterations": 16,
    "warmup": 1,
    "out": "bench/out/dawn-vs-doe.local.d3d12.release.json",
    "workspace": "bench/out/runtime-comparisons.local.d3d12.release",
    "workloadFilter": "",
    "emitShell": false
  },
  "comparability": {
    "mode": "strict",
    "requireTimingClass": "operation",
    "allowLeftNoExecution": false
  },
  "claimability": {
    "mode": "release",
    "minTimedSamples": 15
  },
  "resource": {
    "probe": "none",
    "sampleMs": 100,
    "sampleTargetCount": 0
  },
  "selector": {
    "cohorts": [
      "governed"
    ],
    "benchmarkClass": [
      "comparable"
    ],
    "claimEligibleOnly": true,
    "domains": [],
    "ids": [],
    "excludeIds": []
  }
}
