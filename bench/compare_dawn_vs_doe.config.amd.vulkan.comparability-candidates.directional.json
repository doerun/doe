{
  "workloads": "bench/workloads.amd.vulkan.extended.json",
  "left": {
    "name": "doe",
    "commandTemplate": "env LD_LIBRARY_PATH=bench/vendor/dawn/out/Release:$LD_LIBRARY_PATH zig/zig-out/bin/doe-zig-runtime --commands {commands} --quirks {quirks} --vendor {vendor} --api {api} --family {family} --driver {driver} --backend native --execute --trace --trace-jsonl {trace_jsonl} --trace-meta {trace_meta} {extra_args}"
  },
  "right": {
    "name": "dawn",
    "commandTemplate": "python3 bench/dawn_benchmark_adapter.py --dawn-state bench/dawn_runtime_state.json --dawn-filter-map bench/dawn_workload_map.amd.extended.json --workload {workload} --dawn-extra-args=--backend=vulkan --dawn-extra-args=--adapter-vendor-id=0x1002 --trace-jsonl {trace_jsonl} --trace-meta {trace_meta}"
  },
  "run": {
    "iterations": 8,
    "warmup": 1,
    "out": "bench/out/dawn-vs-doe.amd.vulkan.comparability-candidates.directional.json",
    "workspace": "bench/out/runtime-comparisons.amd.vulkan.comparability-candidates.directional",
    "workloadFilter": "",
    "workloadCohort": "comparability-candidates",
    "includeExtendedWorkloads": true,
    "includeNoncomparableWorkloads": true,
    "emitShell": false
  },
  "comparability": {
    "mode": "warn",
    "requireTimingClass": "operation",
    "allowLeftNoExecution": false
  },
  "claimability": {
    "mode": "off",
    "minTimedSamples": 0
  },
  "resource": {
    "probe": "none",
    "sampleMs": 100,
    "sampleTargetCount": 0
  }
}
